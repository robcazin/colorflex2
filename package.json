{
  "name": "colorFlex-shopify",
  "version": "1.0.0",
  "description": "ColorFlex wallpaper customization system for Shopify",
  "main": "src/index.js",
  "scripts": {
    "status": "cat PROJECT_STATUS.md",
    "quickref": "cat QUICK_REF.md",
    "inventory": "cat INVENTORY-UPDATE-WORKFLOW.md",
    "inventory:sync": "cd manual-deploy/assets && node cf-dl.js false null shopify",
    "inventory:full": "cd manual-deploy/assets && node cf-dl.js true null shopify",
    "dev": "webpack --mode=development --watch",
    "build": "NODE_ENV=production webpack --mode=production",
    "build:dev": "webpack --mode=development",
    "build:wallpaper": "NODE_ENV=production webpack --mode=production --env mode=wallpaper",
    "build:furniture": "NODE_ENV=production webpack --mode=production --env mode=furniture",
    "build:clothing": "NODE_ENV=production webpack --mode=production --env mode=clothing",
    "build:furniture-simple": "NODE_ENV=production webpack --mode=production --env mode=furniture-simple",
    "build:clothing-simple": "NODE_ENV=production webpack --mode=production --env mode=clothing-simple",
    "build:simple": "NODE_ENV=production webpack --mode=production --env mode=simple",
    "build:all": "NODE_ENV=production webpack --mode=production --env mode=all",
    "build:protected": "./protect-css.sh",
    "clean": "rm -rf dist/*",
    "start": "npm run dev",
    "migrate:scan": "node migration/upload-assets.js",
    "migrate:convert": "node migration/create-metafields.js",
    "test": "echo \"No tests specified\" && exit 0",
    "backup": "node scripts/backup.js create",
    "backup:list": "node scripts/backup.js list",
    "deploy:test": "node scripts/deploy-enhanced.js test",
    "deploy:prod": "node scripts/deploy-enhanced.js prod",
    "deploy:both": "node scripts/deploy-enhanced.js both",
    "shopify:test": "node scripts/shopify-deploy.js test",
    "shopify:prod": "node scripts/shopify-deploy.js prod",
    "shopify:setup": "node scripts/shopify-deploy.js setup-dev",
    "shopify:auth": "node scripts/shopify-deploy.js auth",
    "deploy:v3:auth": "node scripts/shopify-deploy-v3.js auth",
    "deploy:v3:test": "node scripts/shopify-deploy-v3.js deploy test",
    "deploy:v3:prod": "node scripts/shopify-deploy-v3.js deploy production",
    "deploy:hybrid:test": "node scripts/hybrid-deploy.js deploy test",
    "deploy:hybrid:prod": "node scripts/hybrid-deploy.js deploy production",
    "deploy:manual": "node scripts/hybrid-deploy.js deploy test --manual-only",
    "products:update": "node scripts/product-update.js update",
    "products:english-cottage": "node scripts/product-update.js update \"3 - english cottage\"",
    "products:test": "node scripts/product-update.js update null test",
    "rollback": "node scripts/rollback.js",
    "rollback:list": "node scripts/rollback.js list",
    "setup": "node scripts/setup-guide.js",
    "setup:store": "node scripts/setup-guide.js store",
    "setup:config": "node scripts/setup-guide.js config",
    "setup:auth": "node scripts/setup-guide.js auth",
    "setup:status": "node scripts/setup-guide.js status",
    "test:connection": "node scripts/test-connection.js test",
    "manual:deploy": "node scripts/manual-deploy.js test",
    "manual:prod": "node scripts/manual-deploy.js production"
  },
  "keywords": [
    "shopify",
    "wallpaper",
    "customization",
    "colorFlex",
    "canvas"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@babel/core": "^7.27.7",
    "@babel/plugin-bugfix-firefox-class-in-computed-class-key": "^7.28.5",
    "@babel/preset-env": "^7.27.2",
    "babel-loader": "^10.0.0",
    "clean-webpack-plugin": "^4.0.0",
    "css-loader": "^7.1.2",
    "mini-css-extract-plugin": "^2.9.2",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.3.14",
    "webpack": "^5.99.9",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "airtable": "^0.12.2",
    "dotenv": "^17.2.3",
    "lodash": "^4.17.21",
    "sharp": "^0.33.0"
  }
}
