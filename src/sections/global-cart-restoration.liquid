                                    productImage.src = latestPattern.thumbnail;
                                    productImage.alt = `Custom Pattern: ${latestPattern.patternName}`;
                                    console.log('✅ Checkout thumbnail updated via existing image!');
                                } else {
                                    // Create new image if none exists
                                    const newImg = document.createElement('img');
                                    newImg.src = latestPattern.thumbnail;
                                    newImg.alt = `Custom Pattern: ${latestPattern.patternName}`;
                                    newImg.style.cssText = 'max-width: 60px; height: 60px; object-fit: cover; border-radius: 4px;';

                                    // Try to insert the image
                                    if (item.querySelector('.product-image, .line-item-image')) {
                                        item.querySelector('.product-image, .line-item-image').appendChild(newImg);
                                    } else {
                                        item.insertBefore(newImg, item.firstChild);
                                    }
                                    console.log('✅ Checkout thumbnail created and inserted!');
                                }
                            }
                        }
                    }
                }
            });
        };

        // Run immediately and setup observers
        checkoutRestoration();

        // Setup mutation observer for dynamic content
        const checkoutObserver = new MutationObserver(() => {
            console.log('🔄 Checkout content changed, retrying thumbnail restoration...');
            setTimeout(checkoutRestoration, 500);
        });

        checkoutObserver.observe(document.body, {
            childList: true,
            subtree: true
        });

        // Periodic checkout restoration disabled to prevent flashing
        // setInterval(() => {
        //     console.log('🔄 Periodic checkout thumbnail check...');
        //     checkoutRestoration();
        // }, 2000);

        // Additional universal checkout approach - try to find ANY images on checkout
        const universalCheckoutRestore = () => {
            console.log('🎯 Universal checkout image search...');

            // Get all images on the page
            const allImages = document.querySelectorAll('img');
            console.log(`🔍 Found ${allImages.length} total images on checkout page`);

            allImages.forEach((img, index) => {
                // Check if image src contains generic Custom Wallpaper patterns
                if (img.src && (
                    img.src.includes('custom-wallpaper') ||
                    img.src.includes('custom_wallpaper') ||
                    img.alt && img.alt.toLowerCase().includes('custom wallpaper')
                )) {
                    console.log(`🎯 Found potential Custom Wallpaper image ${index}:`, img.src.substring(0, 100));

                    // Get the latest pattern thumbnail
                    const savedPatterns = JSON.parse(localStorage.getItem('colorflexSavedPatterns') || '[]');
                    if (savedPatterns.length > 0) {
                        const latestPattern = savedPatterns[savedPatterns.length - 1];
                        if (latestPattern.thumbnail) {
                            console.log(`🔄 Replacing with pattern: ${latestPattern.patternName}`);
                            img.src = latestPattern.thumbnail;
                            img.alt = `Custom Pattern: ${latestPattern.patternName}`;
                            console.log('✅ Universal checkout thumbnail replacement successful!');
                        }
                    }
                }
            });

            // Also try to find images by size (checkout images are often small thumbnails)
            allImages.forEach((img, index) => {
                if (img.offsetWidth > 0 && img.offsetWidth <= 80 && img.offsetHeight > 0 && img.offsetHeight <= 80) {
                    console.log(`🔍 Found small image (${img.offsetWidth}x${img.offsetHeight}) - potential checkout thumbnail`);

                    // Check if this could be a product image based on context
                    const parentText = img.parentElement?.textContent || '';
                    if (parentText.toLowerCase().includes('custom wallpaper') || parentText.toLowerCase().includes('custom fabric')) {
                        const savedPatterns = JSON.parse(localStorage.getItem('colorflexSavedPatterns') || '[]');
                        if (savedPatterns.length > 0) {
                            const latestPattern = savedPatterns[savedPatterns.length - 1];
                            if (latestPattern.thumbnail) {
                                console.log(`🎯 Updating small image for: ${latestPattern.patternName}`);
                                img.src = latestPattern.thumbnail;
                                img.alt = `Custom Pattern: ${latestPattern.patternName}`;
                                console.log('✅ Small image checkout thumbnail updated!');
                            }
                        }
                    }
                }
            });
        };

        // Run universal approach with delays
        setTimeout(universalCheckoutRestore, 1000);
        setTimeout(universalCheckoutRestore, 3000);
        setTimeout(universalCheckoutRestore, 5000);

        // Periodic universal checkout restore disabled to prevent flashing
        // setInterval(universalCheckoutRestore, 10000);

        console.log('✅ Checkout thumbnail restoration setup complete');
    }

    // Function to enhance cart data for better checkout display
    function enhanceCartDataForCheckout() {
        console.log('🔧 Enhancing cart data for checkout display...');

        // This function runs on cart pages to improve data that flows to checkout
        if (window.location.pathname.includes('/cart') || document.querySelector('.cart-item')) {
            // Try to add line item properties that might be visible in checkout
            const cartItems = document.querySelectorAll('.cart-item');

            cartItems.forEach((item, index) => {
                const detailsText = item.textContent || '';

                if (detailsText.includes('Custom Pattern') || detailsText.includes('ColorFlex')) {
                    console.log(`🎯 Enhancing cart item ${index} data for checkout...`);

                    // Look for forms or update mechanisms
                    const updateForm = item.querySelector('form, [data-cart-item-key]');
                    if (updateForm) {
                        // Try to add additional properties that might flow to checkout
                        console.log('📝 Found update mechanism, considering enhancements...');
                    }
                }
            });
        }
    }
    
    // Initialize when DOM is ready - MULTIPLE ATTEMPTS FOR RELIABILITY
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initializeCartThumbnailRestoration);
    } else {
        initializeCartThumbnailRestoration();
    }

    // Single delayed initialization to ensure DOM is ready
    setTimeout(() => {
        if (!window.cartSystemInitialized) {
            window.cartSystemInitialized = true;
            initializeCartThumbnailRestoration();
        }
    }, 1000);

    // IMMEDIATE CART RESTORATION (run right now)
    console.log('🔥 Running immediate cart restoration...');

    // Define a simple cart restoration function that we know will work
    function simpleCartRestore() {
        console.log('🔧 Simple cart restore triggered');
        const cartItems = document.querySelectorAll('.cart-item');
        console.log(`🔍 Found ${cartItems.length} cart items for simple restore`);

        cartItems.forEach((item, index) => {
            console.log(`🔍 Processing cart item ${index}`);
            const img = item.querySelector('img');
            if (img) {
                console.log(`🖼️ Found image in item ${index}: ${img.src.substring(0, 50)}...`);

                // Check if this is a ColorFlex item
                const detailsText = item.textContent || '';
                if (detailsText.includes('Custom Pattern') || detailsText.includes('ColorFlex')) {
                    console.log(`✅ ColorFlex item detected in cart item ${index}`);

                    const savedPatterns = JSON.parse(localStorage.getItem('colorflexSavedPatterns') || '[]');
                    var pidDom = (detailsText.match(/Pattern ID[:\s]+([a-zA-Z0-9-]+)/) || [])[1];
                    var pNameDom = (detailsText.match(/Custom Pattern[:\s]+([^\n\r]+?)(?=\n|Pattern Collection|Pattern ID|$)/i) || [])[1];
                    if (pNameDom) pNameDom = pNameDom.trim();
                    var collDom = (detailsText.match(/Pattern Collection[:\s]+([^\n\r]+?)(?=\n|Custom Pattern|Pattern ID|$)/i) || [])[1];
                    if (collDom) collDom = collDom.trim();
                    var pick = findSavedPatternForCartFallback(savedPatterns, {
                        patternId: pidDom,
                        patternName: pNameDom,
                        collectionName: collDom || 'unknown'
                    });
                    if (pick && pick.thumbnail) {
                        console.log(`🎯 Updating cart image with: ${pick.patternName}`);
                        img.src = pick.thumbnail;
                        img.alt = 'Custom Pattern: ' + pick.patternName;
                        console.log('✅ Simple cart thumbnail updated!');
                    }
                }
            }
        });
    }

    // Single immediate restore only
    setTimeout(() => {
        if (!window.cartRestorationInProgress) {
            console.log('🎯 Single immediate cart restoration triggered');
            restoreCartThumbnails();
        }
    }, 500);
    
})();
</script>

