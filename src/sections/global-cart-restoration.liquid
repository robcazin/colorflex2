{% comment %}
GLOBAL CART THUMBNAIL RESTORATION
Add this section to your theme.liquid or cart template
This enables cart thumbnail restoration on all pages
{% endcomment %}

<script>
/**
 * GLOBAL CART THUMBNAIL RESTORATION SYSTEM
 * Restores custom pattern thumbnails in cart items
 */

(function() {
    'use strict';

    console.log('🛒 Global Cart: Setting up thumbnail restoration...');

    /**
     * Parse cart_thumbnail_* keys:
     * - Legacy: cart_thumbnail_<pattern name>_<collection> (split on last underscore in suffix)
     * - Current: cart_thumbnail_<patternId> where patternId is hyphenated (no extra underscore) — encodes colorway
     */
    function parseCartThumbnailKey(key) {
        if (!key || typeof key !== 'string') return null;
        var prefix = 'cart_thumbnail_';
        if (key.indexOf(prefix) !== 0) return null;
        var rest = key.slice(prefix.length);
        var li = rest.lastIndexOf('_');
        if (li <= 0) {
            return { patternId: rest, patternName: null, collectionName: null };
        }
        return {
            patternName: rest.slice(0, li).trim(),
            collectionName: rest.slice(li + 1).trim(),
            patternId: null
        };
    }

    function normPatternIdKey(s) {
        return String(s || '').toLowerCase().replace(/[^a-z0-9]/g, '');
    }

    /** Prefer Pattern ID / Thumbnail Key match over "latest saved" when picking a fallback thumbnail. */
    function findSavedPatternForCartFallback(savedPatterns, opts) {
        opts = opts || {};
        var pid = opts.patternId;
        var thumbKey = opts.thumbnailKey;
        var patternName = opts.patternName;
        var collectionName = opts.collectionName;
        if (!savedPatterns || !savedPatterns.length) return null;
        if (pid) {
            var want = normPatternIdKey(pid);
            var byId = savedPatterns.filter(function (p) {
                return p && p.id && normPatternIdKey(p.id) === want;
            });
            if (byId.length) {
                byId.sort(function (a, b) { return new Date(b.timestamp) - new Date(a.timestamp); });
                return byId[0];
            }
        }
        if (thumbKey && thumbKey.indexOf('cart_thumbnail_') === 0) {
            var pk = parseCartThumbnailKey(thumbKey);
            if (pk && pk.patternId) {
                var want2 = normPatternIdKey(pk.patternId);
                var byKey = savedPatterns.filter(function (p) {
                    return p && p.id && normPatternIdKey(p.id) === want2;
                });
                if (byKey.length) {
                    byKey.sort(function (a, b) { return new Date(b.timestamp) - new Date(a.timestamp); });
                    return byKey[0];
                }
            }
        }
        if (patternName) {
            var matches = savedPatterns.filter(function (p) {
                return p.patternName === patternName && (!collectionName || p.collectionName === collectionName || collectionName === 'unknown');
            });
            if (matches.length) {
                matches.sort(function (a, b) { return new Date(b.timestamp) - new Date(a.timestamp); });
                return matches[0];
            }
        }
        return null;
    }

    // Clean up old localStorage data on page load
    try {
        // Remove stale autoload data (older than 5 minutes)
        const autoLoadData = localStorage.getItem('colorflexAutoLoad');
        if (autoLoadData) {
            const parsed = JSON.parse(autoLoadData);
            const age = Date.now() - (parsed.timestamp || 0);
            if (age > 5 * 60 * 1000) {
                console.log('🧹 Cleaning up stale autoload data');
                localStorage.removeItem('colorflexAutoLoad');
            }
        }

        // Remove stale thumbnail data (older than 1 hour)
        const thumbnailKey = localStorage.getItem('colorflexCurrentThumbnail');
        if (thumbnailKey && thumbnailKey.length > 100000) { // > 100KB
            console.log('🧹 Cleaning up large thumbnail data');
            localStorage.removeItem('colorflexCurrentThumbnail');
        }
    } catch (error) {
        console.warn('⚠️ Error during localStorage cleanup:', error);
    }

    // Function to build saved pattern data from cart properties (for loadSavedPatternToUI)
    function buildSavedPatternFromCartData(cartItem) {
        try {
            const patternName = cartItem.properties['Custom Pattern'];
            const collectionName = cartItem.properties['Pattern Collection'];
            const customColors = cartItem.properties['Custom Colors'];
            const patternScale = cartItem.properties['Pattern Scale'] || 'Normal';
            const patternId = cartItem.properties['Pattern ID'];

            if (!patternName || !collectionName) {
                console.warn('⚠️ Missing required pattern data in cart item');
                return null;
            }

            // Parse colors from cart data (e.g., "HONORABLE BLUE, LUPINE, HORORABLE BLUE")
            let colors = [];
            if (customColors) {
                const colorNames = customColors.split(',').map(c => c.trim());
                colors = colorNames.map((colorName, index) => {
                    // Fix common typos from cached cart data
                    let fixedColorName = colorName;
                    if (colorName.includes('HORORABLE BLUE')) {
                        fixedColorName = colorName.replace('HORORABLE BLUE', 'HONORABLE BLUE');
                        console.log(`🔧 Fixed color typo: "${colorName}" → "${fixedColorName}"`);
                    }

                    return {
                        color: fixedColorName,
                        label: `Layer ${index + 1}`,
                        name: fixedColorName
                    };
                });
                console.log(`🎨 Parsed ${colors.length} colors from cart data:`, colors);
            }

            // Get thumbnail from localStorage if available (prefer exact key from line item — includes colorway id)
            const thumbnailKey = cartItem.properties['Thumbnail Key'] || (patternId
                ? ('cart_thumbnail_' + String(patternId).replace(/[^a-zA-Z0-9-]/g, '_'))
                : (patternName && collectionName ? `cart_thumbnail_${patternName}_${collectionName}` : ''));
            const storedThumbnail = localStorage.getItem(thumbnailKey);
            let thumbnail = null;
            if (storedThumbnail) {
                try {
                    const thumbnailInfo = JSON.parse(storedThumbnail);
                    thumbnail = thumbnailInfo.thumbnail;
                } catch (e) {
                    console.warn('⚠️ Could not parse stored thumbnail for saved pattern');
                }
            }

            // Parse scale information from cart properties
            let currentScale = 100;
            let scaleMultiplier = 1.0;

            if (cartItem.properties['Scale Value']) {
                currentScale = parseInt(cartItem.properties['Scale Value']) || 100;
            } else if (patternScale) {
                // Fallback to parsing from Pattern Scale text
                if (patternScale.includes('0.5X')) currentScale = 50;
                else if (patternScale.includes('2X')) currentScale = 200;
                else if (patternScale.includes('3X')) currentScale = 300;
                else if (patternScale.includes('4X')) currentScale = 400;
            }

            if (cartItem.properties['Scale Multiplier']) {
                scaleMultiplier = parseFloat(cartItem.properties['Scale Multiplier']) || 1.0;
            }

            // Build saved pattern object in the same format as "My Designs"
            const savedPattern = {
                id: patternId || `cart-${patternName}-${Date.now()}`,
                patternName: patternName,
                collectionName: collectionName,
                colors: colors,
                currentScale: currentScale,
                scaleMultiplier: scaleMultiplier,
                thumbnail: thumbnail,
                timestamp: new Date().toISOString(),
                source: 'cart_restoration',
                layers: colors // Include layers for compatibility
            };

            console.log('🔧 Built saved pattern from cart data:', {
                patternName: savedPattern.patternName,
                collectionName: savedPattern.collectionName,
                colorCount: savedPattern.colors.length,
                hasThunbnail: !!savedPattern.thumbnail,
                currentScale: savedPattern.currentScale
            });

            return savedPattern;

        } catch (error) {
            console.error('❌ Error building saved pattern from cart data:', error);
            return null;
        }
    }

    // Function to restore thumbnail using cart API data
    function restoreCartThumbnailFromData(cartItem, itemIndex) {
        console.log(`🎯 Restoring thumbnail for ColorFlex item ${itemIndex}:`, cartItem.title);
        
        const patternName = cartItem.properties['Custom Pattern'];
        const collection = cartItem.properties['Pattern Collection'] || 'unknown';
        const thumbnailKey = cartItem.properties['Thumbnail Key'];
        
        console.log(`📋 Pattern: "${patternName}", Collection: "${collection}", Key: "${thumbnailKey}"`);
        
        // Try to get thumbnail data
        let thumbnailData = null;
        
        if (thumbnailKey) {
            const storedThumbnail = localStorage.getItem(thumbnailKey);
            if (storedThumbnail) {
                try {
                    const thumbnailInfo = JSON.parse(storedThumbnail);
                    thumbnailData = thumbnailInfo.thumbnail;
                    console.log('💾 Found stored cart thumbnail via key');
                } catch (e) {
                    console.warn('⚠️ Could not parse stored thumbnail');
                }
            }
        }

        if (!thumbnailData && cartItem.properties && cartItem.properties['Pattern ID']) {
            var altKey = 'cart_thumbnail_' + String(cartItem.properties['Pattern ID']).replace(/[^a-zA-Z0-9-]/g, '_');
            var stAlt = localStorage.getItem(altKey);
            if (stAlt) {
                try {
                    var infoAlt = JSON.parse(stAlt);
                    thumbnailData = infoAlt.thumbnail;
                    console.log('💾 Found stored cart thumbnail via Pattern ID-derived key');
                } catch (e1) {
                    console.warn('⚠️ Could not parse thumbnail for Pattern ID key');
                }
            }
        }
        
        // Fallback: check saved patterns (prefer Pattern ID / Thumbnail Key — not "any same name")
        if (!thumbnailData && patternName) {
            const savedPatterns = JSON.parse(localStorage.getItem('colorflexSavedPatterns') || '[]');
            const matchingPattern = findSavedPatternForCartFallback(savedPatterns, {
                patternId: cartItem.properties && cartItem.properties['Pattern ID'],
                thumbnailKey: thumbnailKey,
                patternName: patternName,
                collectionName: collection
            });
            if (matchingPattern && matchingPattern.thumbnail) {
                thumbnailData = matchingPattern.thumbnail;
                console.log('🎨 Using saved pattern thumbnail (matched by id or name)');
            }
        }
        
        if (thumbnailData) {
            // Find the cart row: /cart.js uses 1-based `line` matching Liquid id CartItem-{{ item.index }}
            var lineNo = (cartItem.line != null && cartItem.line !== '') ? cartItem.line : (itemIndex + 1);
            var cartItemElement = document.getElementById('CartItem-' + lineNo);
            if (!cartItemElement) {
                cartItemElement = document.querySelector('.cart-item.colorflex-cart-item:nth-of-type(' + lineNo + ')') ||
                    document.querySelectorAll('.cart-item')[itemIndex];
            }
            if (cartItemElement) {
                updateCartItemImageFromData(cartItemElement, thumbnailData, patternName);
            } else {
                console.warn('❌ Could not find cart item element for line', lineNo);
            }
        } else {
            console.warn(`❌ No thumbnail data found for: ${patternName}`);
        }
    }

    // Function to update cart item image using thumbnail data
    function updateCartItemImageFromData(cartItemElement, thumbnailData, patternName) {
        var preferred = cartItemElement.querySelectorAll('img.colorflex-cart-thumb-target');
        if (preferred && preferred.length) {
            preferred.forEach(function (img) {
                if (!img.dataset.originalSrc) img.dataset.originalSrc = img.src;
                img.src = thumbnailData;
                img.alt = 'Custom Pattern: ' + patternName;
                if (img.srcset) img.srcset = thumbnailData;
            });
            console.log('✅ updateCartItemImageFromData: updated .colorflex-cart-thumb-target');
            return;
        }
        const images = cartItemElement.querySelectorAll('img');
        
        console.log(`🖼️ Found ${images.length} images in cart item`);
        
        images.forEach((img, index) => {
            console.log(`🔍 Updating cart item image ${index}: ${img.alt || 'No alt text'}`);
            
            // Store original src for potential restoration
            if (!img.dataset.originalSrc) {
                img.dataset.originalSrc = img.src;
            }
            
            // Update the image
            img.src = thumbnailData;
            img.alt = `Custom Pattern: ${patternName}`;
            
            // Update srcset if it exists
            if (img.srcset) {
                img.srcset = thumbnailData;
            }
            
            console.log(`✅ Updated cart thumbnail for: ${patternName}`);
        });
    }

    // Function to restore thumbnails in cart
    function restoreCartThumbnails() {
        // Prevent multiple simultaneous executions
        if (window.cartRestorationInProgress) {
            console.log('🔒 Cart restoration already in progress, skipping duplicate call');
            return;
        }

        window.cartRestorationInProgress = true;
        console.log('🔍 Scanning for cart items to restore thumbnails...');

        // First, try to access Shopify's cart data directly
        if (window.fetch) {
            fetch('/cart.js')
                .then(response => response.json())
                .then(cartData => {
                    console.log('🛒 Shopify cart data:', cartData);
                    if (cartData.items) {
                        cartData.items.forEach((item, index) => {
                            console.log(`📦 Cart item ${index}:`, {
                                title: item.title,
                                properties: item.properties,
                                variant_title: item.variant_title,
                                id: item.id,
                                key: item.key
                            });

                            // Show properties in detail
                            if (item.properties && Object.keys(item.properties).length > 0) {
                                console.log(`🔍 Properties for item ${index}:`);
                                Object.entries(item.properties).forEach(([key, value]) => {
                                    console.log(`  "${key}": "${value}"`);
                                });

                                // Check if this is a ColorFlex item
                                const isColorFlex = item.properties['Custom Pattern'] ||
                                                   item.properties['ColorFlex Source'] ||
                                                   item.properties['Pattern Collection'];

                                if (isColorFlex) {
                                    console.log(`✅ Found ColorFlex item in cart data!`);

                                    // Build complete saved pattern data from cart properties for loadSavedPatternToUI
                                    const cartSavedPattern = buildSavedPatternFromCartData(item);
                                    if (cartSavedPattern) {
                                        // Store this as a saved pattern for click restoration
                                        const cartPatternKey = `cart_saved_${item.properties['Custom Pattern']}_${item.properties['Pattern Collection']}`;
                                        localStorage.setItem(cartPatternKey, JSON.stringify(cartSavedPattern));
                                        console.log('💾 Created saved pattern from cart data for loadSavedPatternToUI:', cartSavedPattern.patternName);
                                    }

                                    // Try to restore thumbnail using cart data
                                    restoreCartThumbnailFromData(item, index);
                                } else {
                                    console.log(`❌ Not a ColorFlex item - missing expected properties`);
                                }
                            } else {
                                console.log(`❌ No properties found for item ${index}`);
                            }
                        });
                    }

                    // Release the lock after processing
                    setTimeout(() => {
                        window.cartRestorationInProgress = false;
                    }, 2000);
                })
                .catch(error => {
                    console.warn('⚠️ Could not fetch cart data:', error);
                    window.cartRestorationInProgress = false;
                });
        } else {
            window.cartRestorationInProgress = false;
        }
        
        // Based on debug results, we know the cart structure uses .cart-item
        const cartItems = document.querySelectorAll('.cart-item');
        
        console.log(`🔍 Found ${cartItems.length} cart items using .cart-item selector`);
        
        cartItems.forEach((item, index) => {
            console.log(`🔍 Checking cart item ${index}:`, item.id || item.className);
            
            // Debug: Show the full HTML structure of this cart item
            console.log(`🏗️ Cart item ${index} HTML structure:`, item.outerHTML.substring(0, 500) + '...');
            
            // Look for the details section which contains pattern information
            const detailsSection = item.querySelector('.cart-item__details');
            if (!detailsSection) {
                console.log(`❌ No details section found for item ${index}`);
                return;
            }
            
            // Get text content from details section
            const detailsText = detailsSection.textContent || detailsSection.innerText || '';
            console.log(`📝 Details text preview: ${detailsText.substring(0, 200)}...`);
            
            // Debug: Look for ALL possible property-related elements
            const allPropertyElements = item.querySelectorAll('*[class*="property"], *[data*="property"], input[name*="properties"]');
            console.log(`🔍 Found ${allPropertyElements.length} potential property elements in cart item ${index}`);
            allPropertyElements.forEach((el, i) => {
                console.log(`  Property element ${i}:`, el.tagName, el.className, el.dataset, el.name, el.value, el.textContent?.substring(0, 50));
            });
            
            // Look for ColorFlex pattern products - check visible text AND cart line item data
            const hasColorFlexSource = detailsText.includes('ColorFlex Source') || detailsText.includes('Custom Pattern');
            const hasPatternCollection = detailsText.includes('Pattern Collection');
            const hasThumbnailKey = detailsText.includes('cart_thumbnail_');
            
            // Also check for cart line item data attributes (Shopify stores properties here)
            let isColorFlexProduct = false;
            let lineItemData = null;
            
            // Try multiple approaches to find cart properties
            
            // Approach 1: Check data attributes on cart item
            const lineItemElement = item.querySelector('[data-cart-item-key], [data-line-item-key], [data-index]');
            if (lineItemElement) {
                const possibleDataAttrs = ['data-properties', 'data-item-properties', 'data-cart-properties'];
                for (const attr of possibleDataAttrs) {
                    const dataAttr = lineItemElement.getAttribute(attr);
                    if (dataAttr) {
                        try {
                            lineItemData = JSON.parse(dataAttr);
                            console.log(`📊 Found line item data via ${attr}:`, lineItemData);
                            break;
                        } catch (e) {
                            console.log(`⚠️ Could not parse ${attr}:`, dataAttr);
                        }
                    }
                }
            }
            
            // Approach 2: Look for hidden form fields in the cart item (some themes store properties this way)
            if (!lineItemData) {
                const hiddenFields = item.querySelectorAll('input[type="hidden"][name*="properties"]');
                if (hiddenFields.length > 0) {
                    lineItemData = {};
                    hiddenFields.forEach(field => {
                        const nameMatch = field.name.match(/properties\[([^\]]+)\]/);
                        if (nameMatch) {
                            lineItemData[nameMatch[1]] = field.value;
                        }
                    });
                    console.log(`📊 Found line item data via hidden fields:`, lineItemData);
                }
            }
            
            // Approach 3: Check for property display elements (some themes show properties as text)
            if (!lineItemData) {
                const propertyElements = item.querySelectorAll('.cart-item__property, .line-item-property, [data-cart-item-property]');
                if (propertyElements.length > 0) {
                    lineItemData = {};
                    propertyElements.forEach(el => {
                        const text = el.textContent || el.innerText || '';
                        const propMatch = text.match(/([^:]+):\s*(.+)/);
                        if (propMatch) {
                            lineItemData[propMatch[1].trim()] = propMatch[2].trim();
                        }
                    });
                    console.log(`📊 Found line item data via property elements:`, lineItemData);
                }
            }
            
            // Check if this is a ColorFlex product based on visible text OR line item data
            if (lineItemData) {
                isColorFlexProduct = lineItemData['Custom Pattern'] || 
                                   lineItemData['ColorFlex Source'] || 
                                   lineItemData['Pattern Collection'] ||
                                   Object.keys(lineItemData).some(key => key.includes('cart_thumbnail_'));
            }
            
            if (!hasColorFlexSource && !hasPatternCollection && !hasThumbnailKey && !isColorFlexProduct) {
                console.log(`❌ Not a ColorFlex pattern item - no pattern properties found in visible text or line item data`);
                return;
            }
            
            console.log(`✅ ColorFlex pattern detected via:`, {
                hasColorFlexSource,
                hasPatternCollection, 
                hasThumbnailKey,
                hasLineItemData: !!lineItemData,
                isColorFlexProduct
            });
            
            // Extract pattern information using multiple approaches
            const patternMatch = detailsText.match(/Custom Pattern:\s*([^\n\r]+?)(?=\n|\r|Pattern Collection|Texture|ColorFlex|$)/i);
            const collectionMatch = detailsText.match(/Pattern Collection:\s*([^\n\r]+?)(?=\n|\r|Custom Pattern|Texture|ColorFlex|$)/i);
            const thumbnailKeyMatch = detailsText.match(/cart_thumbnail_([^_\n\r]+)_([^\s\n\r]+)/i);
            
            // Also try to get pattern name from product title (for items like "Thalweg")
            const titleElement = item.querySelector('.cart-item__name, .cart-item__title, h3, .product-title');
            const productTitle = titleElement ? titleElement.textContent.trim() : '';
            
            console.log(`🔍 Pattern matching results for item ${index}:`);
            console.log(`  Product title:`, productTitle);
            console.log(`  Pattern match:`, patternMatch);
            console.log(`  Collection match:`, collectionMatch);
            console.log(`  Thumbnail key match:`, thumbnailKeyMatch);
            
            let patternName = null;
            let collectionName = 'unknown';
            
            // Try multiple sources for pattern name
            if (patternMatch) {
                patternName = patternMatch[1].trim();
            } else if (lineItemData && lineItemData['Custom Pattern']) {
                // Use line item data if available
                patternName = lineItemData['Custom Pattern'];
                console.log(`📊 Using line item data for pattern name: "${patternName}"`);
            } else if (productTitle && !productTitle.toLowerCase().includes('custom wallpaper')) {
                // Use product title as pattern name if it's not "Custom Wallpaper"
                patternName = productTitle;
                console.log(`📝 Using product title as pattern name: "${patternName}"`);
            }
            
            if (collectionMatch) {
                collectionName = collectionMatch[1].trim();
            } else if (lineItemData && lineItemData['Pattern Collection']) {
                // Use line item data if available
                collectionName = lineItemData['Pattern Collection'];
                console.log(`📊 Using line item data for collection: "${collectionName}"`);
            }
            
            // Fallback to thumbnail key if needed
            if (!patternName && thumbnailKeyMatch) {
                patternName = thumbnailKeyMatch[1].trim();
                collectionName = thumbnailKeyMatch[2].trim();
            }
            
            // Additional fallback: check line item data for thumbnail key
            if (lineItemData && lineItemData['Thumbnail Key']) {
                const thumbnailKey = lineItemData['Thumbnail Key'];
                const keyMatch = thumbnailKey.match(/cart_thumbnail_([^_]+)_(.+)/);
                if (keyMatch && !patternName) {
                    patternName = keyMatch[1];
                    collectionName = keyMatch[2];
                    console.log(`🔑 Using thumbnail key from line item data: "${patternName}" from "${collectionName}"`);
                }
            }
            
            if (patternName) {
                console.log(`🎯 Found ColorFlex pattern: "${patternName}" from "${collectionName}"`);
                
                // Try to restore thumbnail for this item
                restoreThumbnailForItem(item, patternName, collectionName);

                // Also fix the product link
                fixCartItemLink(item, patternName, collectionName);

                // Clean up visible properties display
                cleanupCartItemProperties(item);
            } else {
                console.log(`❌ No pattern info found in ColorFlex item ${index} - could not extract pattern name`);
            }
        });
    }
    
    // Function to restore thumbnail for a specific cart item
    function restoreThumbnailForItem(cartItem, patternName, collectionName) {
        if (!patternName) return;

        console.log(`🖼️ Restoring thumbnail for: ${patternName} from ${collectionName}`);

        // Prefer exact Thumbnail Key from DOM (matches add-to-cart), else build key (pattern names may contain spaces)
        var dataThumbEl = cartItem.querySelector && cartItem.querySelector('[data-thumbnail-key]');
        var propKeyFromDom = dataThumbEl && dataThumbEl.getAttribute('data-thumbnail-key');
        var cartKey = propKeyFromDom || ('cart_thumbnail_' + patternName + '_' + collectionName);
        console.log('🔍 Cart restoration debug:', {
            patternName: patternName,
            collectionName: collectionName,
            cartKey: cartKey,
            searchingFor: 'localStorage.getItem(\'' + cartKey + '\')'
        });

        var storedThumbnail = localStorage.getItem(cartKey);
        if (!storedThumbnail && cartKey) {
            var pk = parseCartThumbnailKey(cartKey);
            if (pk) {
                var canonKey = null;
                if (pk.patternId) {
                    canonKey = 'cart_thumbnail_' + pk.patternId;
                } else if (pk.patternName && pk.collectionName) {
                    canonKey = 'cart_thumbnail_' + pk.patternName + '_' + pk.collectionName;
                }
                if (canonKey && canonKey !== cartKey) {
                    storedThumbnail = localStorage.getItem(canonKey);
                    if (storedThumbnail) cartKey = canonKey;
                }
            }
        }
        console.log('📦 Retrieved from localStorage:', {
            key: cartKey,
            found: !!storedThumbnail,
            dataLength: storedThumbnail ? storedThumbnail.length : 0
        });

        let thumbnailData = null;
        if (storedThumbnail) {
            try {
                const thumbnailInfo = JSON.parse(storedThumbnail);
                thumbnailData = thumbnailInfo.thumbnail;
                console.log('💾 Found stored cart thumbnail:', {
                    hasThumbnail: !!thumbnailData,
                    thumbnailLength: thumbnailData ? thumbnailData.length : 0,
                    colors: thumbnailInfo.colors ? thumbnailInfo.colors.length : 0,
                    timestamp: thumbnailInfo.timestamp
                });
            } catch (e) {
                console.warn('⚠️ Could not parse stored thumbnail:', e.message);
            }
        }
        if (!storedThumbnail) {
            var allKeys = Object.keys(localStorage);
            var cartKeys = allKeys.filter(function (k) { return k.indexOf('cart_thumbnail_') === 0; });
            console.log('🔍 Available cart thumbnail keys:', cartKeys);
            var similarKeys = allKeys.filter(function (k) {
                return k.toLowerCase().indexOf(patternName.toLowerCase()) !== -1 ||
                    k.toLowerCase().indexOf(collectionName.toLowerCase()) !== -1;
            });
            console.log('🔍 Keys containing pattern/collection name:', similarKeys);
        }

        // Fallback: check saved patterns (prefer Pattern ID from Thumbnail Key)
        if (!thumbnailData) {
            const savedPatterns = JSON.parse(localStorage.getItem('colorflexSavedPatterns') || '[]');
            console.log(`🔍 Searching ${savedPatterns.length} saved patterns for fallback...`);

            var pkThumb = parseCartThumbnailKey(cartKey);
            var matchingPattern = findSavedPatternForCartFallback(savedPatterns, {
                patternId: pkThumb && pkThumb.patternId,
                thumbnailKey: cartKey,
                patternName: patternName,
                collectionName: collectionName
            });

            if (matchingPattern && matchingPattern.thumbnail) {
                thumbnailData = matchingPattern.thumbnail;
                console.log('🎨 Using saved pattern thumbnail:', {
                    patternId: matchingPattern.id,
                    timestamp: matchingPattern.timestamp,
                    hasColors: matchingPattern.colors ? matchingPattern.colors.length : 0
                });
            } else {
                console.log('❌ No matching saved pattern found for fallback');
            }
        }

        if (thumbnailData) {
            // Single update with success tracking to prevent redundant retries
            const success = updateCartItemImage(cartItem, thumbnailData, patternName);

            // Only retry once if the first attempt failed
            if (!success) {
                setTimeout(() => {
                    console.log(`🔄 Single retry for: ${patternName}`);
                    updateCartItemImage(cartItem, thumbnailData, patternName);
                }, 1000);
            }
        } else {
            console.warn(`❌ No thumbnail data found for: ${patternName}`);
        }

        // ✅ FIX: Always add "Edit Design" button for ColorFlex items, even if thumbnail fails
        // The edit button should be available regardless of thumbnail restoration success
        addCartEditButton(cartItem, patternName, collectionName, thumbnailData);
    }
    
    // Function to update cart item image
    function updateCartItemImage(cartItem, thumbnailData, patternName) {
        // Prefer explicit ColorFlex target from main-cart-items.liquid
        var preferred = cartItem.querySelectorAll('img.colorflex-cart-thumb-target, .colorflex-cart-thumb-target');
        if (preferred && preferred.length) {
            preferred.forEach(function (img) {
                if (img.tagName === 'IMG') {
                    if (!img.dataset.originalSrc) img.dataset.originalSrc = img.src;
                    img.src = thumbnailData;
                    img.alt = 'Custom Pattern: ' + patternName;
                    if (img.srcset) img.srcset = thumbnailData;
                }
            });
            console.log('✅ Updated .colorflex-cart-thumb-target');
            return true;
        }
        // Enhanced image detection - try multiple selectors
        let images = cartItem.querySelectorAll('img');

        console.log(`🖼️ Found ${images.length} images with standard selector`);
        console.log(`📸 Thumbnail data length: ${thumbnailData.length} characters`);

        // If no images found, try alternative selectors
        if (images.length === 0) {
            // Try looking in media container specifically
            const mediaContainer = cartItem.querySelector('.cart-item__media, .cart-item__image-container, .cart__item-media');
            if (mediaContainer) {
                images = mediaContainer.querySelectorAll('img');
                console.log(`🔍 Found ${images.length} images in media container`);
            }
        }

        // If still no images, try looking for lazy-loaded images
        if (images.length === 0) {
            images = cartItem.querySelectorAll('[data-src], [src*="image"], .cart-item img, .product-image img');
            console.log(`🔍 Found ${images.length} images with expanded selectors`);
        }

        // Debug the DOM structure if still no images
        if (images.length === 0) {
            console.warn('❌ No images found in cart item');
            console.log('🔍 Cart item HTML structure for debugging:', cartItem.outerHTML.substring(0, 1000));

            // Try to create an image element if media container exists
            const mediaContainer = cartItem.querySelector('.cart-item__media, .cart-item__image-container');
            if (mediaContainer) {
                console.log('🎯 Attempting to inject image into media container...');
                const existingImage = mediaContainer.querySelector('img, [style*="background-image"]');

                if (existingImage) {
                    // Update existing image
                    if (existingImage.tagName === 'IMG') {
                        existingImage.src = thumbnailData;
                        existingImage.alt = `Custom Pattern: ${patternName}`;
                        console.log('✅ Updated existing image element');
                        return;
                    }
                } else {
                    // Create new image element
                    const newImg = document.createElement('img');
                    newImg.src = thumbnailData;
                    newImg.alt = `Custom Pattern: ${patternName}`;
                    newImg.style.cssText = 'width: 100%; height: 100%; object-fit: cover; border-radius: 8px; border: 2px solid #d4af37;';

                    // Clear container and add our image
                    mediaContainer.innerHTML = '';
                    mediaContainer.appendChild(newImg);
                    console.log('✅ Created and injected new image element');
                    return;
                }
            }
            return;
        }
        
        let imageUpdated = false;
        
        images.forEach((img, index) => {
            console.log(`🔍 Image ${index}: src="${img.src.substring(0, 50)}...", alt="${img.alt}"`);
            
            // Since each cart item has exactly one product image, update it
            const shouldUpdate = true; // Update all images in Custom Wallpaper cart items
            
            if (shouldUpdate) {
                console.log(`🎯 Updating cart item image ${index}: ${img.alt || 'No alt text'}`);
                
                // Store original src for potential restoration
                if (!img.dataset.originalSrc) {
                    img.dataset.originalSrc = img.src;
                }
                
                // Update the image
                img.src = thumbnailData;
                img.alt = `Custom Pattern: ${patternName}`;
                
                // Update srcset if it exists
                if (img.srcset) {
                    img.srcset = thumbnailData;
                }
                
                console.log(`✅ Updated cart thumbnail for: ${patternName}`);
                imageUpdated = true;
            }
        });
        
        if (!imageUpdated) {
            console.warn(`⚠️ No suitable images found to update in cart item`);
        }

        return imageUpdated; // Return success status for retry logic
    }

    // Function to add "Edit Item" button functionality for cart edit modal
    function addCartEditButton(cartItem, patternName, collectionName, thumbnailData) {
        console.log(`🛠️ Adding cart edit functionality for: ${patternName} from ${collectionName}`);

        // Get the cart item data for editing
        const cartPatternKey = `cart_saved_${patternName}_${collectionName}`;
        let savedPatternData = null;

        const cartSavedPattern = localStorage.getItem(cartPatternKey);
        if (cartSavedPattern) {
            try {
                savedPatternData = JSON.parse(cartSavedPattern);
                console.log('🎯 Found cart-saved pattern data for editing:', savedPatternData.patternName);
            } catch (e) {
                console.warn('⚠️ Could not parse cart saved pattern');
            }
        }

        // Fallback to regular saved patterns
        if (!savedPatternData) {
            const savedPatterns = JSON.parse(localStorage.getItem('colorflexSavedPatterns') || '[]');
            savedPatternData = savedPatterns.find(p =>
                p.patternName === patternName &&
                (p.collectionName === collectionName || collectionName === 'unknown')
            );
            console.log('🔄 Using regular saved pattern for editing:', !!savedPatternData);
        }

        // Find the cart item details/buttons area
        const cartItemDetails = cartItem.querySelector('.cart-item__details, .cart-item__content, .cart-item-details');
        if (!cartItemDetails) {
            console.warn(`❌ Could not find cart item details area for: ${patternName}`);
            return;
        }

        // Check if edit button already exists
        if (cartItem.querySelector('.cart-edit-button')) {
            console.log('ℹ️ Edit button already exists, skipping...');
            return;
        }

        // Create edit button
        const editButton = document.createElement('button');
        editButton.className = 'cart-edit-button';
        editButton.textContent = '✏️ Edit Design';
        editButton.style.cssText = `
            background: linear-gradient(135deg, #d4af37, #b8941f);
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 6px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            margin-top: 8px;
            transition: all 0.3s ease;
            box-shadow: 0 2px 4px rgba(212, 175, 55, 0.3);
        `;

        // Add hover effects
        editButton.addEventListener('mouseenter', () => {
            editButton.style.transform = 'translateY(-2px)';
            editButton.style.boxShadow = '0 4px 8px rgba(212, 175, 55, 0.4)';
        });

        editButton.addEventListener('mouseleave', () => {
            editButton.style.transform = 'translateY(0)';
            editButton.style.boxShadow = '0 2px 4px rgba(212, 175, 55, 0.3)';
        });

        // Add click handler to open cart edit modal
        editButton.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();

            console.log(`🛠️ Opening cart edit modal for: ${patternName}`);

            // Check if cart edit modal system is available
            if (window.colorFlexCartEditor) {
                window.colorFlexCartEditor.openEditModal({
                    cartItem: cartItem,
                    patternName: patternName,
                    collectionName: collectionName,
                    savedPattern: savedPatternData,
                    thumbnailData: thumbnailData
                });
                console.log('✅ Cart edit modal opened successfully');
            } else {
                console.warn('⚠️ Cart edit modal not available, falling back to ColorFlex navigation');

                // Fallback: navigate to ColorFlex page for editing
                if (window.location.pathname.includes('colorflex')) {
                    // On ColorFlex page - load pattern directly
                    if (window.loadSavedPatternToUI && savedPatternData) {
                        try {
                            window.loadSavedPatternToUI(savedPatternData);
                            console.log('✅ Pattern loaded for editing in ColorFlex');
                        } catch (error) {
                            console.error('❌ Error loading pattern for editing:', error);
                        }
                    }
                } else {
                    // Navigate to ColorFlex page
                    if (savedPatternData) {
                        try {
                            // Clear old autoload data first
                            localStorage.removeItem('colorflexAutoLoad');

                            // Create a lightweight copy without thumbnail (too large for localStorage)
                            const lightweightData = {
                                patternName: savedPatternData.patternName,
                                collectionName: savedPatternData.collectionName,
                                colors: savedPatternData.colors,
                                currentScale: savedPatternData.currentScale,
                                scaleMultiplier: savedPatternData.scaleMultiplier,
                                id: savedPatternData.id
                                // Intentionally omit thumbnail to save space
                            };

                            localStorage.setItem('colorflexAutoLoad', JSON.stringify({
                                pattern: lightweightData,
                                source: 'cart_edit',
                                timestamp: Date.now()
                            }));
                            console.log('✅ Stored lightweight pattern data for autoload');
                        } catch (quotaError) {
                            console.warn('⚠️ localStorage quota exceeded, continuing without autoload data');
                            // Continue anyway - ColorFlex will load from URL params
                        }
                    }
                    // Build URL with scale parameters
                    let colorflexUrl = `/pages/colorflex?collection=${collectionName}&pattern=${encodeURIComponent(patternName)}&source=cart_edit`;

                    // Add scale parameters if available
                    if (savedPatternData && savedPatternData.currentScale !== undefined) {
                        colorflexUrl += `&scale=${savedPatternData.currentScale}`;
                    }
                    if (savedPatternData && savedPatternData.scaleMultiplier !== undefined) {
                        colorflexUrl += `&scaleMultiplier=${savedPatternData.scaleMultiplier}`;
                    }

                    console.log('🔗 Navigating to ColorFlex with scale info:', colorflexUrl);
                    window.location.href = colorflexUrl;
                }
            }
        });

        // Add the edit button to cart item
        cartItemDetails.appendChild(editButton);
        console.log(`✅ Added cart edit button for: ${patternName}`);

        // Also make the image clickable for quick edit (secondary action)
        const imageContainer = cartItem.querySelector('.cart-item__media, .cart-item__image-container, img');
        if (imageContainer) {
            imageContainer.style.cursor = 'pointer';
            imageContainer.title = 'Click to edit this design';

            imageContainer.addEventListener('click', (e) => {
                e.preventDefault();
                editButton.click(); // Trigger the same edit action
            });

            console.log(`✅ Made cart image clickable for editing: ${patternName}`);
        }
    }
    
    // Function to fix cart item product links
    function fixCartItemLink(cartItem, patternName, collectionName) {
        const links = cartItem.querySelectorAll('a[href*="custom-wallpaper"]');
        
        links.forEach(link => {
            // Get the saved pattern data from localStorage
            const savedPatterns = JSON.parse(localStorage.getItem('colorflexSavedPatterns') || '[]');
            const matchingPattern = savedPatterns.find(p => 
                p.patternName === patternName && 
                (p.collectionName === collectionName || collectionName === 'unknown')
            );
            
            if (matchingPattern) {
                console.log(`🔗 Found saved pattern data for: ${patternName}`, matchingPattern);
                
                // Instead of going to Custom Wallpaper, redirect to ColorFlex page with pattern loaded
                // This matches exactly how the "Load Pattern" button works in unified modal
                
                // Normalize collection name for URL (lowercase-hyphenated)
                const normalizedCollectionName = collectionName.toLowerCase().replace(/\s+/g, '-');
                
                // Build ColorFlex URL with full pattern data
                const params = new URLSearchParams({
                    collection: normalizedCollectionName,
                    pattern: patternName,
                    source: 'cart_saved_pattern',
                    saved_pattern_id: matchingPattern.id
                });
                
                // Add saved pattern colors if available
                if (matchingPattern.colors && matchingPattern.colors.length > 0) {
                    const savedLayers = JSON.stringify(matchingPattern.colors.map((color, index) => ({
                        index: index,
                        color: color.color,
                        label: color.label,
                        isShadow: false
                    })));
                    params.append('saved_layers', savedLayers);
                    
                    const colorString = matchingPattern.colors.map(c => c.color).join(',');
                    params.append('colors', colorString);
                    
                    console.log(`🎨 Added ${matchingPattern.colors.length} saved colors to URL`);
                }
                
                // Change the link to go to ColorFlex page instead of Custom Wallpaper
                const colorFlexUrl = `${window.location.origin}/pages/colorflex?${params.toString()}`;
                link.href = colorFlexUrl;
                
                console.log(`🔗 Updated cart link to ColorFlex: ${link.href.substring(0, 80)}...`);
            } else {
                console.warn(`⚠️ No saved pattern data found for: ${patternName} from ${collectionName}`);
                console.log('📝 Available saved patterns:', savedPatterns.map(p => `${p.patternName} (${p.collectionName})`));
                
                // Fallback to original Custom Wallpaper link with basic parameters
                const currentHref = link.href;
                const url = new URL(currentHref);
                
                url.searchParams.set('pattern_name', patternName);
                url.searchParams.set('collection', collectionName);
                url.searchParams.set('source', 'cart');
                
                link.href = url.toString();
                console.log(`🔗 Updated cart link (fallback): ${link.href.substring(0, 80)}...`);
            }
        });
    }
    
