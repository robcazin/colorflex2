    // Initialize cart thumbnail restoration
    function initializeCartThumbnailRestoration() {
        console.log('🔧 Initializing cart thumbnail restoration system...');

        // Check if we're on a page with cart items (but don't exit early)
        const hasCartItems = document.querySelectorAll('.cart-item').length > 0;

        if (!hasCartItems) {
            console.log('🛒 No cart items detected initially, but setting up system anyway...');
        } else {
            console.log('🛒 Cart items detected, initializing restoration system...');
        }
        
        // Run restoration immediately
        restoreCartThumbnails();
        
        // Set up mutation observer for dynamic cart updates
        const observer = new MutationObserver(function(mutations) {
            let shouldRestore = false;
            
            mutations.forEach(function(mutation) {
                if (mutation.type === 'childList' && mutation.addedNodes.length > 0) {
                    // Check if cart items were added
                    mutation.addedNodes.forEach(function(node) {
                        if (node.nodeType === 1) { // Element node
                            if (node.classList && (
                                node.classList.toString().includes('cart') ||
                                node.classList.toString().includes('item') ||
                                node.classList.toString().includes('line')
                            )) {
                                shouldRestore = true;
                            }
                        }
                    });
                }
            });
            
            if (shouldRestore) {
                console.log('🔄 Cart content changed, restoring thumbnails...');
                setTimeout(restoreCartThumbnails, 500);
            }
        });
        
        observer.observe(document.body, {
            childList: true,
            subtree: true
        });
        
        // Periodic restoration disabled to prevent flashing
