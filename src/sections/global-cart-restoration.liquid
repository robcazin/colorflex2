    // Function to setup thumbnail restoration on checkout pages
    function setupCheckoutThumbnailRestoration() {
        console.log('🔧 Setting up checkout thumbnail restoration...');

        // Method 1: Try to find and update product images in checkout
        const checkoutRestoration = () => {
            // Try multiple selectors for checkout items
            const selectors = [
                '[data-product-line-item]',
                '.product-line-item',
                '.line-item',
                '.checkout-line-item',
                '.order-line-item',
                '[class*="line-item"]',
                '[class*="product"]'
            ];

            let productItems = [];
            for (const selector of selectors) {
                productItems = document.querySelectorAll(selector);
                if (productItems.length > 0) {
                    console.log(`🔍 Found ${productItems.length} items using selector: ${selector}`);
                    break;
                }
            }

            if (productItems.length === 0) {
                // Try a broader search
                productItems = document.querySelectorAll('*');
                productItems = Array.from(productItems).filter(el => {
                    const text = el.textContent || '';
                    return text.toLowerCase().includes('custom wallpaper') || text.toLowerCase().includes('custom fabric');
                });
                console.log(`🔍 Found ${productItems.length} items via text search`);
            }

            productItems.forEach((item, index) => {
                // Try multiple ways to find title and image
                const titleSelectors = ['.product-title', '.line-item-title', '[data-product-title]', 'h1', 'h2', 'h3', '.title'];
                const imageSelectors = ['img', '.product-image img', '.line-item-image img', '[style*="background-image"]'];

                let productTitle = null;
                let productImage = null;

                // Find title
                for (const selector of titleSelectors) {
                    productTitle = item.querySelector(selector);
                    if (productTitle) break;
                }

                // Find image
                for (const selector of imageSelectors) {
                    productImage = item.querySelector(selector);
                    if (productImage) break;
                }

                // Also check if the item itself contains the title/image
                if (!productTitle) {
                    const text = item.textContent || item.innerText || '';
                    if (text.toLowerCase().includes('custom wallpaper') || text.toLowerCase().includes('custom fabric')) {
                        productTitle = { textContent: text.substring(0, 100) }; // Mock title element
                    }
