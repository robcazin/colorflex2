                if (!productImage) {
                    productImage = item.querySelector('*');
                    if (productImage && !productImage.src) {
                        productImage = null;
                    }
                }

                if (productTitle) {
                    const title = productTitle.textContent || productTitle.innerText || '';
                    console.log(`🔍 Checkout item ${index}: "${title.substring(0, 50)}..."`);

                    // Check if this is a Custom Wallpaper/Fabric item
                    if (title.toLowerCase().includes('custom wallpaper') || title.toLowerCase().includes('custom fabric')) {
                        console.log('✅ Found ColorFlex item in checkout, attempting restoration...');

                        // Try to get pattern data from localStorage
                        const savedPatterns = JSON.parse(localStorage.getItem('colorflexSavedPatterns') || '[]');
                        if (savedPatterns.length > 0) {
                            // Use the most recent pattern (or try to match by cart data)
                            const latestPattern = savedPatterns[savedPatterns.length - 1];
