<!-- Font imports -->
<link href="https://fonts.googleapis.com/css2?family=IM+Fell+English:ital@0;1&family=Island+Moments&family=Special+Elite&display=swap" rel="stylesheet">

<!-- All styling now handled by built CSS: color-flex-core.min.css -->

<div class="colorflex-section" {{ section.shopify_attributes }}>
  <div style="background: #1a202c; color: white; padding: 0.5rem; border-radius: 8px; margin: 0.25rem 0;">
    
    <!-- Hidden main title -->
    <h2 style="display: none;">{{ section.settings.title }}</h2>
    
    <!-- ColorFlex App -->
    <div id="mainContainer" style="position: relative; min-height: 70vh;">
      
      <div style="display: grid; grid-template-columns: 1fr 280px 1fr; gap: 2rem; max-width: 1500px; margin: 0 auto; margin-left: 160px; padding: 0 1rem; position: relative; z-index: 1;">
        
        <!-- MOVED: Curated Colors Section - Compact Version -->
        <div style="grid-column: 1 / -1; margin-bottom: 0;" data-tooltip="Click a color to apply it to the selected layer">
          <section id="curatedColorsSection" style="width: 100%; padding: 0.125rem 0 0 0; text-align: center;">
            <div id="curatedColorsContainer" style="display: flex; flex-wrap: wrap; justify-content: center; gap: 6px; max-width: 1300px; margin: 0 auto; min-height: 30px;"></div>
          </section>
        </div>
        
        <!-- Pattern Preview -->
        <div style="text-align: center; margin-top: -22px;">
          <h3 style="margin-bottom: 0.5rem; font-size: 2.4rem; font-family: 'Island Moments', cursive !important;" data-tooltip="Your pattern with current colors and scale">Pattern Preview</h3>
          <div id="preview" style="max-width: 700px; min-height: 200px; background: #434341; margin: 0 auto; display: flex; justify-content: center; align-items: center;"></div>
          <h3 id="patternName" style="margin: 0.5rem .5rem; font-size: 1.4rem; font-family: 'Special Elite', monospace !important;">Pattern Name</h3>
          <div style="display: flex; justify-content: center; gap: 0.5rem; margin-top: 0.5rem; margin-bottom: 3rem; padding-bottom: 2rem; position: relative; z-index: 150;">
            <button id="printButton" class="py-4" aria-label="Print Pattern" data-tooltip="Click to print this pattern" style="padding: 0.5rem 1rem; font-size: 0.85rem; background: #e2e8f0; border: none; border-radius: 4px; position: relative; z-index: 150; pointer-events: auto !important; display: flex; align-items: center; gap: 0.5rem;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6,9 6,2 18,2 18,9"></polyline>
                <path d="m6,18 h4"></path>
                <path d="m10,18 h4"></path>
                <rect x="3" y="14" width="18" height="4"></rect>
                <path d="m14,18 h4"></path>
              </svg>
              Print Pattern
            </button>
            <button id="saveToListButton" class="py-4" aria-label="Save to List" data-tooltip="Save this pattern to your custom list" onclick="saveToMyList()" style="padding: 0.5rem 1rem; font-size: 0.85rem; background: #e2e8f0; border: none; border-radius: 4px; position: relative; z-index: 150; pointer-events: auto !important; display: flex; align-items: center; gap: 0.5rem;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 4h2a2 2 0 0 1 2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path>
                <rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect>
                <path d="M12 11h4"></path>
                <path d="M12 16h4"></path>
                <path d="M8 11h.01"></path>
                <path d="M8 16h.01"></path>
              </svg>
              Save to my list
            </button>
          </div>
        </div>
        
        <!-- Color Controls -->
        <div id="colorControls" style="display: flex; flex-direction: column; width: 100%; margin-left: -1rem;">
          <h3 style="text-align: center; color: #d4af37; font-size: 1.5rem; font-family: 'Special Elite', monospace !important;" data-tooltip="Choose a color for each layer; type a name or SW number">Color Layers</h3>

          <div id="layerInputsContainer" style="width: 100%; min-width: 280px;"></div>
        </div>
        
        <!-- Room Mockup -->
        <div style="text-align: center; margin-top: -15px;">
          <h3 style="margin-bottom: 0.5rem; font-size: 2.4rem; font-family: 'Island Moments', cursive !important;" data-tooltip="Pattern shown in a room scene">Room Mockup Preview</h3>
          <div id="roomMockup" style="width: 550px; height: 400px; background: #434341; margin: 0 auto;" data-tooltip="Click for full size, click again to close"></div>
          
          <div id="scaleControls" style="margin-top: 0.75rem;">
            <button data-multiplier="1" data-tooltip="One repeat (baseline size)" onclick="setPatternScale(1)" style="margin: 0 0.25rem; padding: 0.4rem 0.8rem; background: #e2e8f0; border: none; border-radius: 4px; font-size: 0.85rem;">Normal</button>
            <button data-multiplier="0.5" data-tooltip="More repeats, smaller on wall" onclick="setPatternScale(0.5)" style="margin: 0 0.25rem; padding: 0.4rem 0.8rem; background: #e2e8f0; border: none; border-radius: 4px; font-size: 0.85rem;">2X</button>
            <button data-multiplier="0.25" data-tooltip="Even more repeats" onclick="setPatternScale(0.25)" style="margin: 0 0.25rem; padding: 0.4rem 0.8rem; background: #e2e8f0; border: none; border-radius: 4px; font-size: 0.85rem;">3X</button>
            <button data-multiplier="0.125" data-tooltip="Maximum density" onclick="setPatternScale(0.125)" style="margin: 0 0.25rem; padding: 0.4rem 0.8rem; background: #e2e8f0; border: none; border-radius: 4px; font-size: 0.85rem;">4X</button>
          </div>
          <div style="text-align: center;">
            <h3 style="margin-top: 1.9rem; font-size: 2rem; font-family: 'Island Moments', cursive !important;" data-tooltip="Coordinating paint colors for this pattern">Matching Coordinates</h3>
            <div id="coordinatesContainer" style="margin-top: 3rem; min-height: 100px; max-width: 550px; margin-left: auto; margin-right: auto;"></div>
          </div>
          
        </div>
        
      </div>
      
      <!-- Collection Header - Fixed Position -->
      <div id="collectionHeaderContainer" style="position: fixed; left: 0; top: 180px; width: 140px; background: #2d3748; padding: 0.75rem 0.75rem 0.5rem 0.75rem; z-index: 26; border-radius: 8px 8px 0 0; text-align: center; margin-left: 5px;" data-tooltip="Current collection">
        <h6 id="collectionHeader" style="background: #2d3748; margin: 0 0 0.25rem 0; font-family: 'IM Fell English', serif !important; font-size: 1.1rem !important; color: white !important; font-weight: normal !important; text-transform: uppercase !important;">BOMBAY</h6>
        <div style="font-family: 'Special Elite', monospace !important; font-size: 0.8rem; color: #d4af37 !important; text-transform: uppercase; letter-spacing: 0.5px;">Collection</div>
      </div>
      
      <!-- Left Sidebar - Scrollable Thumbnails Only -->
      <div id="leftSidebar" style="position: fixed; left: 0; top: 160px; width: 140px; background: #2d3748; padding: 0.75rem; z-index: 25; border-radius: 0 0 8px 8px; overflow-y: auto; overflow-x: hidden; height: 760px; max-height: calc(100vh - 180px); -webkit-overflow-scrolling: touch; overscroll-behavior-y: contain; scrollbar-width: thin; -ms-overflow-style: scrollbar;" data-tooltip="Click a pattern to customize colors">
        <div id="collectionThumbnails"></div>
      </div>

      
    </div>
    
    <div id="colorPopup" style="display: none;">
      <div>
        <p>🎨 Click a curated color to set this background color.</p>
        <label><input type="checkbox" id="disablePopup"> Don't show this message again</label>
        <button id="popupOkButton">OK</button>
      </div>
    </div>
    
  </div>
</div>

  {{ 'color-flex-core.min.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'color-flex-core.min-bu.js' | asset_url }}" defer></script>
<script>
// Shopify Customer Authentication Integration
{% if customer %}
window.ShopifyCustomer = {
  id: {{ customer.id | json }},
  authenticated: true,
  email: {{ customer.email | json }},
  first_name: {{ customer.first_name | json }},
  last_name: {{ customer.last_name | json }}
};
console.log('🔐 Shopify customer authenticated:', window.ShopifyCustomer.id);
console.log('👤 Customer:', window.ShopifyCustomer.first_name, window.ShopifyCustomer.last_name);
{% else %}
window.ShopifyCustomer = null;
console.log('👤 Guest user - patterns will save to localStorage');
{% endif %}

// Set up asset URLs for ColorFlex to use
window.ColorFlexAssets = {
  colorsUrl: "{{ 'colors.json' | asset_url }}",
  collectionsUrl: "{{ 'collections.json' | asset_url }}",
  furnitureConfigUrl: "{{ 'furniture-config.json' | asset_url }}"
};

// Clean initialization - load app once DOM is ready
document.addEventListener('DOMContentLoaded', function() {
  console.log('🎨 ColorFlex DOM ready');
  console.log('📁 Asset URLs configured:', window.ColorFlexAssets);
  
  // Wait for CFM.js to load
  if (typeof window.startApp === 'function') {
    console.log('✅ Starting ColorFlex immediately');
    window.startApp();
  } else {
    console.log('⏳ Waiting for CFM.js to load...');
    // Check every 100ms for startApp to become available
    const checkInterval = setInterval(function() {
      if (typeof window.startApp === 'function') {
        console.log('✅ CFM.js loaded, starting app');
        clearInterval(checkInterval);
        window.startApp();
      }
    }, 100);
    
    // Safety timeout after 5 seconds
    setTimeout(function() {
      clearInterval(checkInterval);
      if (typeof window.startApp !== 'function') {
        console.error('❌ CFM.js failed to load within 5 seconds');
      }
    }, 5000);
  }
});

// Save to My List functionality
function saveToMyList() {
    try {
        // Get current pattern data
        const patternData = {
            collectionName: appState.selectedCollection?.name || 'Unknown',
            patternName: appState.currentPattern?.name || 'Unknown Pattern',
            thumbnail: appState.currentPattern?.thumbnail || null,
            colors: appState.currentLayers?.map(layer => ({
                label: layer.label,
                color: layer.color
            })) || [],
            timestamp: new Date().toISOString(),
            id: Date.now() // Simple ID generation
        };
        
        // Get existing saved patterns from localStorage
        const existingSaved = JSON.parse(localStorage.getItem('colorflexSavedPatterns') || '[]');
        
        // Always add as new pattern to allow multiple color variations
        existingSaved.push(patternData);
        showNotification('Pattern saved to your list!', 'success');
        
        // Limit to last 20 patterns to prevent storage bloat
        const limitedPatterns = existingSaved.slice(-20);
        
        // Save back to localStorage
        localStorage.setItem('colorflexSavedPatterns', JSON.stringify(limitedPatterns));
        
        // Update button text temporarily
        const button = document.getElementById('saveToListButton');
        const originalText = button.innerHTML;
        button.innerHTML = button.innerHTML.replace('Save to my list', 'Saved!');
        
        setTimeout(() => {
            button.innerHTML = originalText;
        }, 2000);
        
    } catch (error) {
        console.error('Error saving pattern:', error);
        showNotification('Error saving pattern. Please try again.', 'error');
    }
}

// Show notification function
function showNotification(message, type = 'info') {
    // Create notification element
    const notification = document.createElement('div');
    notification.style.cssText = `
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 1000;
        padding: 12px 20px;
        border-radius: 4px;
        font-family: 'Special Elite', monospace;
        font-size: 14px;
        max-width: 300px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        transform: translateX(100%);
        transition: transform 0.3s ease;
        ${type === 'success' ? 'background: #4CAF50; color: white;' : ''}
        ${type === 'error' ? 'background: #f44336; color: white;' : ''}
        ${type === 'info' ? 'background: #2196F3; color: white;' : ''}
    `;
    notification.textContent = message;
    
    // Add to page
    document.body.appendChild(notification);
    
    // Animate in
    setTimeout(() => {
        notification.style.transform = 'translateX(0)';
    }, 100);
    
    // Remove after 3 seconds
    setTimeout(() => {
        notification.style.transform = 'translateX(100%)';
        setTimeout(() => {
            document.body.removeChild(notification);
        }, 300);
    }, 3000);
}

// View My List functionality (for future enhancement)
function viewMyList() {
    const savedPatterns = JSON.parse(localStorage.getItem('colorflexSavedPatterns') || '[]');
    
    if (savedPatterns.length === 0) {
        showNotification('No saved patterns yet!', 'info');
        return;
    }
    
    console.log('Your saved patterns:', savedPatterns);
    // Future: Show modal with saved patterns
    showNotification(`You have ${savedPatterns.length} saved patterns!`, 'info');
}

// Collection thumbnails auto-scroll functionality
function setupCollectionAutoScroll() {
    const sidebar = document.getElementById('leftSidebar');
    
    if (!sidebar) {
        console.log('❌ leftSidebar element not found');
        return;
    }
    
    console.log('✅ Setting up auto-scroll for sidebar');
    
    // Enable smooth scrolling for Magic Mouse
    sidebar.style.scrollBehavior = 'smooth';
    
    // Debug: Check if scrolling is possible
    setTimeout(() => {
        const canScroll = sidebar.scrollHeight > sidebar.clientHeight;
        console.log('📏 Sidebar scroll info:', {
            scrollHeight: sidebar.scrollHeight,
            clientHeight: sidebar.clientHeight,
            canScroll: canScroll
        });
    }, 3000);
    
    // Simple continuous auto-scroll
    let isAutoScrolling = false;
    let scrollDirection = 1;
    let scrollSpeed = 0.5;
    
    function autoScroll() {
        if (!isAutoScrolling) return;
        
        const maxScroll = sidebar.scrollHeight - sidebar.clientHeight;
        if (maxScroll <= 0) {
            console.log('❌ Auto-scroll stopped - no scrollable content');
            return;
        }
        
        const currentScroll = sidebar.scrollTop;
        const oldScrollTop = sidebar.scrollTop;
        
        // Reverse direction at boundaries
        if (currentScroll >= maxScroll && scrollDirection === 1) {
            scrollDirection = -1;
            console.log('🔄 Reversed direction: scrolling up');
        } else if (currentScroll <= 0 && scrollDirection === -1) {
            scrollDirection = 1;
            console.log('🔄 Reversed direction: scrolling down');
        }
        
        sidebar.scrollTop += scrollSpeed * scrollDirection;
        
        // Debug: Check if scroll actually changed
        if (sidebar.scrollTop !== oldScrollTop) {
            console.log('📜 Scrolled:', {
                from: oldScrollTop,
                to: sidebar.scrollTop,
                direction: scrollDirection === 1 ? 'down' : 'up'
            });
        }
        
        requestAnimationFrame(autoScroll);
    }
    
    // Start auto-scroll on hover
    sidebar.addEventListener('mouseenter', () => {
        console.log('🖱️ Mouse entered sidebar');
        console.log('📏 Scroll dimensions:', {
            scrollHeight: sidebar.scrollHeight,
            clientHeight: sidebar.clientHeight,
            canScroll: sidebar.scrollHeight > sidebar.clientHeight
        });
        if (sidebar.scrollHeight > sidebar.clientHeight) {
            console.log('✅ Starting auto-scroll');
            isAutoScrolling = true;
            autoScroll();
        } else {
            console.log('❌ Cannot scroll - not enough content');
        }
    });
    
    // Stop auto-scroll on mouse leave
    sidebar.addEventListener('mouseleave', () => {
        console.log('🖱️ Mouse left sidebar');
        isAutoScrolling = false;
    });
    
    // Handle Magic Mouse interaction
    sidebar.addEventListener('wheel', (e) => {
        isAutoScrolling = false;
        
        // Resume auto-scroll after interaction
        setTimeout(() => {
            if (sidebar.matches(':hover')) {
                isAutoScrolling = true;
                autoScroll();
            }
        }, 2000);
    }, { passive: true });
}

// Initialize auto-scroll independently of main app
document.addEventListener('DOMContentLoaded', function() {
    console.log('🎨 DOM ready, setting up auto-scroll');
    // Try immediately
    setupCollectionAutoScroll();
    
    // Also try after elements are populated
    setTimeout(() => {
        console.log('🔄 Retry auto-scroll setup after delay');
        setupCollectionAutoScroll();
    }, 3000);
    
    // Try again after a longer delay
    setTimeout(() => {
        console.log('🔄 Final retry auto-scroll setup');
        setupCollectionAutoScroll();
    }, 5000);
});
  // Color Preservation Fix for "Back to Pattern" functionality
function patchCoordinateClickHandlers() {
    const coordinateImages = document.querySelectorAll('.coordinate-image');
    
    if (coordinateImages.length === 0) {
        console.log('❌ No coordinate images found. The fix will be applied when they load.');
        return false;
    }
    
    console.log(`🔍 Found ${coordinateImages.length} coordinate images`);
    
    coordinateImages.forEach(image => {
        // Remove existing event listeners by cloning the element
        const newImage = image.cloneNode(true);
        image.parentNode.replaceChild(newImage, image);
        
        // Add our patched event handler
        newImage.addEventListener('click', function() {
            console.log('>>> PATCHED handleCoordinateClick START <<<');
            
            // Always store current state before switching to coordinate (preserves user's custom colors)
            if (window.appState || window.v) {
                const appState = window.appState || window.v;
                
                appState.originalPattern = { ...appState.currentPattern };
                appState.originalCoordinates = appState.selectedCollection?.coordinates ? [...appState.selectedCollection.coordinates] : [];
                appState.originalLayerInputs = appState.layerInputs.map((layer, index) => ({
                    id: `layer-${index}`,
                    label: layer.label,
                    inputValue: layer.input.value,
                    hex: layer.circle.style.backgroundColor,
                    isBackground: layer.isBackground
                }));
                appState.originalCurrentLayers = appState.currentLayers.map(layer => ({ ...layer }));
                
                console.log("✅ Stored current state (with user colors):", {
                    pattern: appState.originalPattern.name,
                    layerInputs: appState.originalLayerInputs.length,
                    currentLayers: appState.originalCurrentLayers.length
                });
            }
            
            // Highlight selected image
            document.querySelectorAll(".coordinate-image").forEach(img => img.classList.remove("selected"));
            newImage.classList.add("selected");
            
            // Continue with coordinate selection logic
            const filename = newImage.dataset.filename;
            console.log(`Coordinate image clicked: ${filename}`);
            
            // Trigger the rest of the coordinate handling
            if (window.startApp && window.startApp.handleCoordinateSelection) {
                window.startApp.handleCoordinateSelection(filename);
            } else {
                // Fallback: try to trigger existing functionality
                newImage.dispatchEvent(new Event('coordinate-selected', { bubbles: true }));
            }
        });
    });
    
    return true;
}

// Apply color preservation fix
function applyColorPreservationFix() {
    console.log('🔧 Applying color preservation fix...');
    
    if (patchCoordinateClickHandlers()) {
        console.log('✅ Color preservation fix applied successfully!');
        console.log('Now when you click "Back to Pattern", your custom colors will be preserved.');
    } else {
        console.log('⏳ Coordinate images not found yet. Setting up observer...');
        
        // Set up a mutation observer to apply the fix when coordinates load
        const observer = new MutationObserver((mutations) => {
            mutations.forEach((mutation) => {
                if (mutation.type === 'childList') {
                    mutation.addedNodes.forEach((node) => {
                        if (node.nodeType === 1) { // Element node
                            const coordinateImages = node.querySelectorAll ? node.querySelectorAll('.coordinate-image') : [];
                            if (coordinateImages.length > 0 || node.classList?.contains('coordinate-image')) {
                                console.log('🔄 Coordinate images detected, applying fix...');
                                setTimeout(() => {
                                    if (patchCoordinateClickHandlers()) {
                                        console.log('✅ Color preservation fix applied successfully!');
                                        observer.disconnect();
                                    }
                                }, 100);
                            }
                        }
                    });
                }
            });
        });
        
        observer.observe(document.body, {
            childList: true,
            subtree: true
        });
        
        console.log('👀 Watching for coordinate images to load...');
    }
}

// Initialize color preservation fix
document.addEventListener('DOMContentLoaded', function() {
    setTimeout(applyColorPreservationFix, 4000); // Apply after main app loads
});

</script>

