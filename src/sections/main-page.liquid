{%- if request.path == '/pages/contact' -%}
  <link href="https://fonts.googleapis.com/css2?family=IM+Fell+English:ital@0;1&family=Island+Moments&family=Special+Elite&display=swap" rel="stylesheet">
  <style>
    .sc-contact-hero {
      max-width: 1120px;
      margin: 1.8rem auto 1rem;
      padding: 1.8rem 1.25rem;
      border: 1px solid rgba(212, 175, 55, 0.35);
      border-radius: 16px;
      background: rgba(0, 0, 0, 0.3);
      box-shadow: 0 10px 26px rgba(0, 0, 0, 0.3);
      text-align: center;
    }

    .sc-contact-hero h1 {
      margin: 0;
      color: #f3ead4;
      font-family: 'Island Moments', cursive;
      font-size: clamp(2.5rem, 6vw, 4.3rem);
      line-height: 1;
    }

    .sc-contact-hero .rte {
      max-width: 760px;
      margin: 0.85rem auto 0;
      color: #d8d3c7;
      font-family: 'IM Fell English', serif;
      font-size: 1.1rem;
      line-height: 1.5;
    }
  </style>
  <div class="sc-contact-hero">
    <h1>{{ page.title }}</h1>
    <div class="rte">{{ page.content }}</div>
  </div>
{%- else -%}
  <div class="page-width">
    <h1>{{ page.title }}</h1>
    <div>{{ page.content }}</div>
  </div>
{%- endif -%}
{% schema %}
{ "name": "Page", "tag": "section", "settings": [] }
{% endschema %}
