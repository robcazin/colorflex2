  const customColors = rawCustomColors ? rawCustomColors.split(',')
    .map(color => color.trim().replace(/^(SW|SC|SWs|SCs|Sw|Sc|swsw|SWsw|SCsc|SCcs|Swsc|swsc)\d+\s*/i, "").trim())
    .join(', ') : '';
