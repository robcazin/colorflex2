          for (let [key, value] of formData.entries()) {
            if (key.includes('properties') || key.includes('quantity') || key.includes('id') || key.includes('Wallpaper')) {
              console.log(`  📦 FormData: ${key} = "${value}"`);
            }
          }
        } catch (e) {
          console.warn('⚠️ FormData test failed:', e);
        }
      }

      // Also protect against addEventListener form submissions
      const originalAddEventListener = productForm.addEventListener;
      productForm.addEventListener = function(type, listener, options) {
        if (type === 'submit') {
          const protectedListener = function(event) {
            console.log('🛡️ Submit event intercepted - verifying ColorFlex properties');

            // Double-check properties are still present
            Object.keys(protectedProperties).forEach(name => {
              let field = productForm.querySelector(`input[name="${name}"]`);
              if (!field || field.value !== protectedProperties[name]) {
                // Restore if missing or changed
                if (!field) {
                  field = document.createElement('input');
                  field.type = 'hidden';
                  field.name = name;
                  productForm.appendChild(field);
                }
                field.value = protectedProperties[name];
                console.log('🛡️ Event protection restored:', name);
              }
            });

            return listener.apply(this, arguments);
          };

          return originalAddEventListener.call(this, type, protectedListener, options);
        } else {
          return originalAddEventListener.apply(this, arguments);
        }
      };

      // Also intercept FormData creation to ensure properties are included
      const originalFormData = window.FormData;
      window.FormData = function(form) {
        const formData = new originalFormData(form);

        // If this is our product form, ensure ColorFlex properties are included
        if (form === productForm && Object.keys(protectedProperties).length > 0) {
          console.log('🛡️ FormData creation intercepted - adding ColorFlex properties');

          Object.entries(protectedProperties).forEach(([name, value]) => {
            // Extract the property key from the name (e.g., "properties[Custom Pattern]" -> "Custom Pattern")
            const propertyKey = name.match(/\[([^\]]+)\]/)?.[1];
            if (propertyKey && !formData.has(name)) {
              formData.append(name, value);
              console.log('🛡️ Added to FormData:', name, '=', value);
            }
          });

          // Debug what's in the final FormData
          console.log('🛡️ Final FormData entries:');
          for (let [key, value] of formData.entries()) {
            if (key.includes('properties')) {
              console.log('  📦', key, '=', value);
            }
          }
        }

        return formData;
      };

      // Intercept fetch requests to cart/add to ensure properties are included
      const originalFetch = window.fetch;
      window.fetch = async function(url, options) {
        // Check if this is a cart add request (handle both string URLs and Request objects)
        const urlString = typeof url === 'string' ? url : (url?.url || '');
        const isCartAdd = urlString && (urlString.includes('/cart/add') || urlString.includes('/cart/add.js'));
        
        if (isCartAdd && options && options.body) {
          console.log('🛡️ Fetch to cart/add intercepted:', urlString);
          console.log('🛡️ Body type:', typeof options.body, 'Is FormData:', options.body instanceof FormData);
          console.log('🛡️ Constructor name:', options.body?.constructor?.name);
          
          // Upload thumbnail if needed before cart add
          // PRIORITY 1: Use MyDesigns method - capture thumbnail using capturePatternThumbnail()
          let thumbnail = null;
          
          if (typeof window.capturePatternThumbnail === 'function') {
            console.log('📸 Fetch interceptor: Capturing thumbnail with MyDesigns method...');
            try {
              thumbnail = window.capturePatternThumbnail();
              if (thumbnail) {
                console.log('✅ Thumbnail captured in fetch interceptor using MyDesigns method');
                localStorage.setItem('colorflexCurrentThumbnail', thumbnail);
              }
            } catch (error) {
              console.error('❌ Error capturing thumbnail in fetch interceptor:', error);
            }
          }
          
          // PRIORITY 2: Fall back to localStorage
          if (!thumbnail) {
            thumbnail = localStorage.getItem('colorflexCurrentThumbnail');
          }
          
          // PRIORITY 3: Try to get from cart thumbnail storage using URL params
          if (!thumbnail) {
            try {
              const currentUrlParams = new URLSearchParams(window.location.search);
              const patternName = currentUrlParams.get('pattern_name') || currentUrlParams.get('custom_pattern') || '';
              const collection = currentUrlParams.get('collection') || currentUrlParams.get('pattern_collection') || '';
              
              if (patternName && collection) {
                const cartThumbnailKey = `cart_thumbnail_${patternName}_${collection}`;
                const cartThumbnailData = localStorage.getItem(cartThumbnailKey);
                if (cartThumbnailData) {
                  try {
                    const parsed = JSON.parse(cartThumbnailData);
                    if (parsed.thumbnail) {
                      thumbnail = parsed.thumbnail;
                      console.log('🛡️ Found thumbnail in cart storage:', cartThumbnailKey);
                    }
                  } catch (e) {
                    console.warn('🛡️ Could not parse cart thumbnail data:', e);
                  }
                }
              }
            } catch (e) {
              console.warn('🛡️ Error reading URL params for thumbnail lookup:', e);
            }
          }
          
          // PRIORITY 4: Also try to extract from FormData if it's already there
          if (!thumbnail && options.body instanceof FormData) {
            const thumbnailKey = options.body.get('properties[Thumbnail Key]');
            if (thumbnailKey) {
              const cartThumbnailData = localStorage.getItem(thumbnailKey);
              if (cartThumbnailData) {
                try {
                  const parsed = JSON.parse(cartThumbnailData);
                  if (parsed.thumbnail) {
                    thumbnail = parsed.thumbnail;
                    console.log('🛡️ Found thumbnail using Thumbnail Key from FormData:', thumbnailKey);
                  }
                } catch (e) {
                  console.warn('🛡️ Could not parse thumbnail from Thumbnail Key:', e);
                }
              }
            }
          }
          
          console.log('🛡️ Thumbnail check:', thumbnail ? `Found (${thumbnail.length} chars, starts with: ${thumbnail.substring(0, 30)}...)` : 'Not found');
          
          if (thumbnail && thumbnail.startsWith('data:image') && thumbnail.length > 255) {
            // patternName may not be in scope here (only set in PRIORITY 3 block) - get from URL
            const uploadParams = new URLSearchParams(window.location.search);
            const uploadPatternName = uploadParams.get('pattern_name') || uploadParams.get('custom_pattern') || 'pattern';
            const apiUrl = window.COLORFLEX_API_URL || '/api/upload-thumbnail';
            const filename = `colorflex-${uploadPatternName}-${Date.now()}.jpg`;
            
            if (!window.COLORFLEX_API_URL) {
              console.warn('⚠️ COLORFLEX_API_URL not set – set window.COLORFLEX_API_URL in theme.liquid (e.g. your API server + /api/upload-thumbnail)');
            }
            console.log('📤 Uploading thumbnail via API server (fetch interceptor)...');
            console.log('📤 API URL:', apiUrl);
            
            try {
              const uploadResponse = await originalFetch(apiUrl, {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                  thumbnail: thumbnail,
                  filename: filename
                })
              });
              
              console.log('📤 Upload response status:', uploadResponse.status);
              
              if (uploadResponse.ok) {
                const uploadData = await uploadResponse.json();
                console.log('📤 Upload response data:', uploadData);
                console.log('📤 Upload success:', uploadData.success);
                console.log('📤 Upload URL:', uploadData.url);
                
                if (uploadData.success && uploadData.url) {
                  const thumbnailUrl = uploadData.url;
                  console.log('✅ Thumbnail uploaded successfully! URL:', thumbnailUrl);
                  console.log('✅ URL length:', thumbnailUrl.length);
                  console.log('✅ URL starts with:', thumbnailUrl.substring(0, 50));
                  
                  // For /cart/add.js, the body is JSON
                  if (urlString.includes('/cart/add.js')) {
                    try {
                      let cartData;
                      if (typeof options.body === 'string') {
                        cartData = JSON.parse(options.body);
                      } else {
                        cartData = options.body;
                      }
                      
                      console.log('🛡️ Cart data structure:', Object.keys(cartData));
                      
                      // Handle different cart data structures
                      if (cartData.items && Array.isArray(cartData.items)) {
                        // Multiple items format
                        cartData.items.forEach(item => {
                          if (!item.properties) item.properties = {};
                          item.properties['_pattern_preview'] = thumbnailUrl;
                          console.log('✅ Added _pattern_preview to item:', item.id || item.variant_id);
                        });
                      } else if (cartData.id || cartData.variant_id) {
                        // Single item format - add properties object
                        if (!cartData.properties) cartData.properties = {};
                        cartData.properties['_pattern_preview'] = thumbnailUrl;
                        console.log('✅ Added _pattern_preview to single item');
                      } else {
                        // Fallback: try to add at root level
                        if (!cartData.properties) cartData.properties = {};
                        cartData.properties['_pattern_preview'] = thumbnailUrl;
                        console.log('✅ Added _pattern_preview to root properties');
                      }
                      
                      options.body = JSON.stringify(cartData);
                      console.log('✅ Updated cart body with _pattern_preview');
                      console.log('✅ Final cart body preview:', JSON.stringify(cartData).substring(0, 200));
                      console.log('✅ _pattern_preview in body:', options.body.includes('_pattern_preview'));
                      console.log('✅ _pattern_preview URL in body:', options.body.includes(thumbnailUrl));
                    } catch (e) {
                      console.error('❌ Error parsing cart body:', e);
                      // Fallback: add to protected properties for FormData handling
                      protectedProperties['properties[_pattern_preview]'] = thumbnailUrl;
                    }
                  } else {
                    // For regular form submission (FormData), add to protected properties
                    protectedProperties['properties[_pattern_preview]'] = thumbnailUrl;
                    console.log('✅ Added _pattern_preview to protected properties for FormData');
                    console.log('✅ Protected properties now include:', Object.keys(protectedProperties));
                    console.log('✅ _pattern_preview URL:', thumbnailUrl);
                  }
                } else {
                  console.warn('⚠️ Upload succeeded but no URL in response:', uploadData);
                }
              } else {
                const errorText = await uploadResponse.text();
                console.error('❌ Thumbnail upload failed:', uploadResponse.status, errorText);
                console.warn('⚠️ Falling back to Thumbnail Key storage');
              }
            } catch (error) {
              console.error('❌ Thumbnail upload error in fetch interceptor:', error);
              console.warn('⚠️ Falling back to Thumbnail Key storage');
            }
          } else if (thumbnail && !thumbnail.startsWith('data:image')) {
            // Already a URL, add directly
            const thumbnailUrl = thumbnail;
            console.log('🛡️ Thumbnail is already a URL, adding directly:', thumbnailUrl);
            
            if (urlString.includes('/cart/add.js')) {
              try {
                let cartData = typeof options.body === 'string' ? JSON.parse(options.body) : options.body;
                if (!cartData.properties) cartData.properties = {};
                cartData.properties['_pattern_preview'] = thumbnailUrl;
                options.body = JSON.stringify(cartData);
                console.log('✅ Added existing URL to cart body');
              } catch (e) {
                protectedProperties['properties[_pattern_preview]'] = thumbnailUrl;
              }
            } else {
              protectedProperties['properties[_pattern_preview]'] = thumbnailUrl;
            }
          }

          // Handle different body types - use multiple detection methods for FormData
          const isFormData = options.body instanceof FormData ||
                            (options.body && options.body.constructor && options.body.constructor.name === 'FormData') ||
                            (options.body && typeof options.body.append === 'function');

          if (isFormData && Object.keys(protectedProperties).length > 0) {
            console.log('🛡️ FormData detected! Adding ColorFlex properties to body');
            console.log('🛡️ Detection methods:', {
              instanceof: options.body instanceof FormData,
              constructor: options.body?.constructor?.name === 'FormData',
              hasAppend: typeof options.body?.append === 'function'
            });

            Object.entries(protectedProperties).forEach(([name, value]) => {
              if (!options.body.has(name)) {
                options.body.append(name, value);
                console.log('🛡️ Added to FormData:', name, '=', value);
              } else {
                console.log('🛡️ Property already exists in FormData:', name);
              }
            });

            // Debug final FormData contents
            console.log('🛡️ Final FormData contents:');
            for (let [key, value] of options.body.entries()) {
              console.log(`  📦 ${key} = "${value}"`);
            }

          } else if (typeof options.body === 'string' && Object.keys(protectedProperties).length > 0) {
            console.log('🛡️ Body is string, attempting to parse and modify');
            console.log('🛡️ Original body:', options.body);

            try {
              // Try to append properties to URL-encoded string
              let bodyString = options.body;
              Object.entries(protectedProperties).forEach(([name, value]) => {
                const encodedName = encodeURIComponent(name);
                const encodedValue = encodeURIComponent(value);
                if (!bodyString.includes(encodedName)) {
                  bodyString += `&${encodedName}=${encodedValue}`;
                  console.log('🛡️ Added to string body:', name, '=', value);
                }
              });
              options.body = bodyString;
              console.log('🛡️ Modified body:', options.body);
            } catch (e) {
              console.warn('⚠️ Failed to modify string body:', e);
            }

          } else {
            console.log('🛡️ Unsupported body type or no properties to add');
            if (options.body) {
              console.log('🛡️ Body content preview:', String(options.body).substring(0, 200));
            }
          }
          
          // Final verification: log what we're sending
          console.log('🛡️ FINAL CART REQUEST DEBUG:');
          if (options.body instanceof FormData) {
            console.log('🛡️ FormData entries:');
            for (let [key, value] of options.body.entries()) {
              if (key.includes('_pattern_preview') || key.includes('pattern')) {
                console.log(`  ✅ ${key} = ${value.substring(0, 100)}...`);
              }
            }
          } else if (typeof options.body === 'string') {
            if (options.body.includes('_pattern_preview')) {
              console.log('✅ _pattern_preview found in request body');
              const match = options.body.match(/["']_pattern_preview["']\s*:\s*["']([^"']+)["']/);
              if (match) {
                console.log('✅ Thumbnail URL in request:', match[1]);
              }
            } else {
              console.warn('⚠️ _pattern_preview NOT found in request body');
            }
          }
        }

        return originalFetch.apply(this, arguments);
      };

      console.log('🛡️ ColorFlex property protection system activated');
      clearInterval(protectionInterval); // Stop checking once protection is set up
    }
  }, 500); // Check every 500ms for ColorFlex properties

  // Stop checking after 30 seconds (give users time to select material)
  setTimeout(() => {
    clearInterval(protectionInterval);
    console.log('🛡️ ColorFlex protection setup timeout');
  }, 30000);
}

// 🔄 SHOPIFY VARIANT CHANGE HOOK SYSTEM
// Hooks into Shopify's variant changes to re-populate ColorFlex properties after form rebuilding
let storedColorFlexProperties = {};

function storeColorFlexProperties() {
  const productForm = document.querySelector('form[action*="/cart/add"]');
  if (!productForm) return;

  const colorflexFields = productForm.querySelectorAll('input[name*="properties"][name*="Custom"], input[name*="properties"][name*="Pattern"], input[name*="properties"][name*="ColorFlex"]');

  if (colorflexFields.length > 0) {
    storedColorFlexProperties = {};
    colorflexFields.forEach(field => {
      storedColorFlexProperties[field.name] = field.value;
      console.log('💾 Stored ColorFlex property:', field.name, '=', field.value);
    });
    console.log('💾 Stored', colorflexFields.length, 'ColorFlex properties in memory');
  }
}

function restoreColorFlexProperties() {
  const productForm = document.querySelector('form[action*="/cart/add"]');
  if (!productForm || Object.keys(storedColorFlexProperties).length === 0) return;

  console.log('🔄 Restoring ColorFlex properties after variant change...');

  Object.entries(storedColorFlexProperties).forEach(([name, value]) => {
    // Remove existing field if present
    const existingField = productForm.querySelector(`input[name="${name}"]`);
    if (existingField) {
      existingField.remove();
    }

    // Add restored field
    const field = document.createElement('input');
    field.type = 'hidden';
    field.name = name;
    field.value = value;
    productForm.appendChild(field);
    console.log('🔄 Restored ColorFlex property:', name, '=', value);
  });

  console.log('✅ ColorFlex properties restored after variant change');
}

// 🎯 MATERIAL SELECTION & VARIANT CHANGE DETECTION
function setupVariantChangeDetection() {
  // Store initial ColorFlex properties if present
  storeColorFlexProperties();

  // Hook into Shopify's variant picker changes
  const variantPickers = document.querySelectorAll('variant-radios, variant-selects, input[name*="id"], select[name*="id"]');
  console.log('🔍 Found variant pickers:', variantPickers.length);

  // Look for ALL variant option selectors (radio buttons, fieldset buttons, labels)
  const materialRadios = document.querySelectorAll(`
    input[type="radio"][name*="options"],
    input[type="radio"][name*="Wallpaper"],
    input[type="radio"][name*="Texture"],
    input[type="radio"][name*="Material"],
    input[type="radio"][name*="Fabric"],
    fieldset input[type="radio"]
  `);
  console.log('🔍 Found material radio options:', materialRadios.length);

  const variantButtons = document.querySelectorAll(`
    fieldset button[type="button"],
    button[data-variant-option],
    button[data-value]
  `);
  console.log('🔍 Found variant buttons:', variantButtons.length);

  // Pre-select variant based on preferred_material URL parameter
  const urlParams = new URLSearchParams(window.location.search);
  const preferredMaterial = urlParams.get('preferred_material');
  if (preferredMaterial) {
    console.log('🎯 Preferred material from URL:', preferredMaterial);

    // Map material IDs to variant titles (search terms)
    const materialToVariantMap = {
      'wallpaper-prepasted': ['prepasted', 'pre-pasted', 'pre pasted'],
      'wallpaper-peel-stick': ['peel', 'stick', 'peel & stick', 'peel and stick', 'removable'],
      'wallpaper-unpasted': ['unpasted', 'un-pasted', 'un pasted'],
      'wallpaper-grasscloth': ['grasscloth', 'grass cloth', 'grass-cloth'],
      'fabric-soft-velvet': ['soft velvet', 'soft-velvet', 'velvet'],
      'fabric-decorator-linen': ['decorator linen', 'decorator-linen', 'linen', 'decorator'],
      'fabric-drapery-sheer': ['drapery sheer', 'drapery-sheer', 'sheer'],
      'fabric-lightweight-linen': ['lightweight linen', 'lightweight-linen', 'light linen', 'lightweight'],
      'fabric-faux-suede': ['faux suede', 'faux-suede', 'suede'],
      'fabric-drapery-light-block': ['light block', 'lightblock', 'light-block', 'blackout', 'drapery light']
    };

    const searchTerms = materialToVariantMap[preferredMaterial];
    if (searchTerms) {
      console.log('🔍 Searching for terms:', searchTerms);

      // Try to find matching radio button
      let found = false;
      materialRadios.forEach(radio => {
        if (found) return; // Already found a match

        const label = radio.labels && radio.labels[0] ? radio.labels[0].textContent.toLowerCase().trim() : '';
        const value = radio.value ? radio.value.toLowerCase().trim() : '';

        console.log(`  Radio: label="${label}", value="${value}", checked=${radio.checked}`);

        const matchesAny = searchTerms.some(term =>
          label.includes(term) || value.includes(term)
        );

        if (matchesAny) {
          console.log('✅ Pre-selecting radio:', label || value, '(already checked:', radio.checked + ')');
          // ✅ FIX: Click even if already checked to trigger price update
          radio.checked = true;
          radio.click(); // Trigger Shopify's variant change handler

          // Dispatch multiple events to ensure Shopify updates price
          radio.dispatchEvent(new Event('change', { bubbles: true }));
          document.dispatchEvent(new CustomEvent('variant:change'));

          found = true;
        }
      });

      // If no radio found, try buttons
      if (!found) {
        variantButtons.forEach(button => {
          if (found) return; // Already found a match

          const buttonText = button.textContent.toLowerCase().trim();
          console.log(`  Button: text="${buttonText}", active=${button.classList.contains('active')}`);

          const matchesAny = searchTerms.some(term => buttonText.includes(term));

          if (matchesAny) {
            console.log('✅ Pre-selecting button:', buttonText, '(already active:', button.classList.contains('active') + ')');
            // ✅ FIX: Click even if already active to trigger price update
            button.click();

            // Dispatch multiple events to ensure Shopify updates price
            button.dispatchEvent(new Event('change', { bubbles: true }));
            document.dispatchEvent(new CustomEvent('variant:change'));

            found = true;
          }
        });
      }

      if (!found) {
        console.warn('⚠️ No matching variant found for:', preferredMaterial);
      }
    } else {
      console.warn('⚠️ No search terms defined for material:', preferredMaterial);
    }
  }

  // Monitor all variant-related changes with debouncing
  let variantChangeTimeout;
  [...variantPickers, ...materialRadios].forEach(element => {
    element.addEventListener('change', function() {
      console.log('🎯 Variant/Material change detected:', this.name, '=', this.value);

      // Clear previous timeout to debounce rapid changes
      if (variantChangeTimeout) {
        clearTimeout(variantChangeTimeout);
      }

      // Store ColorFlex properties before potential form rebuild
      storeColorFlexProperties();

      // Set up restoration after Shopify processes the change (debounced)
      variantChangeTimeout = setTimeout(() => {
        const currentColorFlexFields = document.querySelectorAll('form[action*="/cart/add"] input[name*="properties"][name*="Custom"], form[action*="/cart/add"] input[name*="properties"][name*="Pattern"], form[action*="/cart/add"] input[name*="properties"][name*="ColorFlex"]');

        // Only restore if properties are actually missing
        if (Object.keys(storedColorFlexProperties).length > 0 && currentColorFlexFields.length === 0) {
          console.log('🔄 Properties missing after variant change - restoring...');
          restoreColorFlexProperties();
          // Re-setup protection after restoration
          setTimeout(() => {
            protectColorFlexProperties();
          }, 100);
        } else {
          console.log('🔄 Properties still present after variant change - no restoration needed');
        }
        variantChangeTimeout = null;
      }, 300); // Give Shopify time to rebuild form
    });
  });

  // Monitor for form changes using MutationObserver with loop prevention
  const productForm = document.querySelector('form[action*="/cart/add"]');
  if (productForm && window.MutationObserver) {
    let isRestoring = false; // Prevent infinite loops

    const observer = new MutationObserver(function(mutations) {
      if (isRestoring) return; // Skip if we're currently restoring properties

      mutations.forEach(function(mutation) {
        if (mutation.type === 'childList') {
          // Check if form was rebuilt (variant fields added/removed)
          const hasVariantInput = productForm.querySelector('input[name="id"]');
          const currentColorFlexFields = productForm.querySelectorAll('input[name*="properties"][name*="Custom"], input[name*="properties"][name*="Pattern"], input[name*="properties"][name*="ColorFlex"]');

          // Only restore if we have stored properties but they're missing from the form
          if (hasVariantInput && Object.keys(storedColorFlexProperties).length > 0 && currentColorFlexFields.length === 0) {
            console.log('🔄 Form rebuild detected via mutation observer - ColorFlex properties missing');
            isRestoring = true;
            setTimeout(() => {
              restoreColorFlexProperties();
              setTimeout(() => {
                isRestoring = false; // Reset flag after restoration
              }, 200);
            }, 100);
          }
        }
      });
    });

    observer.observe(productForm, {
      childList: true,
      subtree: true
    });
    console.log('👀 Form mutation observer activated with loop prevention');
  }

  // Hook into Shopify theme events for variant changes
  document.addEventListener('shopify:section:load', function() {
    console.log('🔄 Shopify section reload detected - restoring ColorFlex properties');
    setTimeout(() => {
      restoreColorFlexProperties();
    }, 100);
  });

  document.addEventListener('variant:change', function() {
    console.log('🔄 Shopify variant:change event detected');
    setTimeout(() => {
      restoreColorFlexProperties();
    }, 100);
  });

  // Listen for custom form update events
  document.addEventListener('product:variant:change', function() {
    console.log('🔄 Product variant change event detected');
    setTimeout(() => {
      restoreColorFlexProperties();
    }, 100);
  });

  // Also capture initial selections if any are already checked
  const checkedMaterial = document.querySelector('input[name*="Wallpaper Type"]:checked, input[name*="Texture"]:checked, input[name*="Material"]:checked');
  if (checkedMaterial) {
    console.log('🎯 Initial material selection detected:', checkedMaterial.value);
  }
}

// Start comprehensive ColorFlex integration system when DOM is ready
