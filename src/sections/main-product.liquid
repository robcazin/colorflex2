<!-- ColorFlex Hidden Form Fields -->
<div id="colorflexFormFields" style="display: none;">
  <!-- Properties for cart restoration script compatibility -->
  <input type="hidden" name="properties[Custom Pattern]" id="colorflex-pattern-name">
  <input type="hidden" name="properties[Pattern Collection]" id="colorflex-collection">
  <input type="hidden" name="properties[Custom Colors]" id="colorflex-custom-colors">
  <input type="hidden" name="properties[ColorFlex Source]" value="ColorFlex Saved Pattern" id="colorflex-source">
  <input type="hidden" name="properties[Thumbnail Key]" id="colorflex-thumbnail-key">
  
  <!-- Additional properties for tracking -->
  <input type="hidden" name="properties[Material Type]" id="colorflex-material-type">
  <input type="hidden" name="properties[ColorFlex Design]" value="Yes" id="colorflex-design">
  <input type="hidden" name="properties[Pattern ID]" id="colorflex-pattern-id">
  <input type="hidden" name="properties[Save Date]" id="colorflex-save-date">
  <input type="hidden" name="properties[Pattern Scale]" id="colorflex-pattern-scale">
</div>

<script>
// ColorFlex Product Page Integration
window.replaceMainProductImage = function(urlParams) {
  const patternName = urlParams.get('pattern_name');
  const collection = urlParams.get('collection');
  const material = urlParams.get('material');
  const customColors = urlParams.get('custom_colors');
  let thumbnail = urlParams.get('thumbnail');
  
  // If no thumbnail in URL, check localStorage
  if (!thumbnail || thumbnail.trim() === '') {
    thumbnail = localStorage.getItem('colorflexCurrentThumbnail');
    if (thumbnail) {
      console.log('🖼️ Retrieved thumbnail from localStorage');
    } else {
      // Try to get thumbnail from saved patterns if pattern name and collection match
      if (patternName && collection) {
        try {
          const savedPatterns = JSON.parse(localStorage.getItem('colorflexSavedPatterns') || '[]');
          const matchingPattern = savedPatterns.find(p => 
            (p.patternName === patternName || p.name === patternName) &&
            (p.collectionName === collection || p.collection === collection)
          );
          if (matchingPattern && matchingPattern.thumbnail) {
            thumbnail = matchingPattern.thumbnail;
            console.log('🖼️ Retrieved thumbnail from saved patterns');
            // Store it in localStorage for future use
            localStorage.setItem('colorflexCurrentThumbnail', thumbnail);
          } else {
            console.warn('⚠️ No thumbnail found in localStorage or saved patterns');
          }
        } catch (error) {
          console.error('❌ Error checking saved patterns:', error);
        }
      }
    }
  }
  
  // Detect if this is a standard pattern (no custom colors or only #ffffff)
  const isStandardPattern = !customColors ||
                            customColors.trim() === '' ||
                            customColors.toLowerCase().includes('#ffffff') ||
                            customColors.toLowerCase() === 'white';

  // Debug logging
  console.log('🎨 ColorFlex Debug:', {
    patternName,
    collection,
    material,
    customColors,
    isStandardPattern,
    thumbnail: thumbnail ? 'Present (' + thumbnail.length + ' chars)' : 'None',
    customColorsType: typeof customColors,
    customColorsLength: customColors ? customColors.length : 'null',
    allParams: Object.fromEntries(urlParams.entries())
  });

  if (!patternName) return;

  // Find the main product image to replace
  const mainImage = document.querySelector('.product__media img, .product-single__photo img, [data-product-image] img, .product__media-wrapper img');

  if (mainImage && thumbnail && thumbnail.trim() !== '') {
    console.log('🖼️ Replacing main product image with custom pattern thumbnail');

    // Replace the src with our custom thumbnail
    mainImage.src = thumbnail;
    mainImage.alt = `Custom ${patternName} pattern from ${collection} collection`;

    // Constrain size: ColorFlex thumbnails must not blow up layout (cap rendered size)
    mainImage.style.maxWidth = 'min(100%, 800px)';
    mainImage.style.maxHeight = 'min(80vh, 800px)';
    mainImage.style.width = 'auto';
    mainImage.style.height = 'auto';
    mainImage.style.objectFit = 'contain';

    // Update any srcset attributes to prevent fallback to original images
    if (mainImage.srcset) {
      mainImage.srcset = thumbnail + ' 1x';
    }

    // Hide variant selectors for all ColorFlex products (both ColorFlex and standard patterns)
    hideElementsForCustomizedProduct();

    // Only show custom colors display for ColorFlex patterns
    if (!isStandardPattern) {
      // Add custom colors display under product name instead of overlay
      addCustomColorsDisplay(patternName, collection, material, customColors);

      // Don't show "Customize Options" button - pattern already customized
      console.log('🎨 ColorFlex pattern detected - showing colors display, hiding customize button');
    } else {
      console.log('🎨 Standard pattern detected - hiding custom colors display and customize button');
    }

    console.log('✅ Main product image replaced with custom pattern thumbnail');
  } else if (!thumbnail || thumbnail.trim() === '') {
    console.log('⚠️ No thumbnail available - showing custom colors display without thumbnail');

    // Hide variant selectors for all ColorFlex products (both ColorFlex and standard patterns)
    hideElementsForCustomizedProduct();

    // Only show custom colors display for ColorFlex patterns
    if (!isStandardPattern) {
      // Still show custom colors display even without thumbnail
      addCustomColorsDisplay(patternName, collection, material, customColors);

      // Don't show "Customize Options" button - pattern already customized
      console.log('🎨 ColorFlex pattern detected (no thumbnail) - showing colors display, hiding customize button');
    } else {
      console.log('🎨 Standard pattern detected - hiding custom colors display and customize button');
    }

  } else {
    console.warn('❌ Could not find main product image to replace');
  }
}

// Add custom colors display under product name
function addCustomColorsDisplay(patternName, collection, material, customColors) {
  // Parse custom colors
  let colorArray = [];
  if (customColors && customColors.trim() !== '') {
    colorArray = customColors.split(',').map(c => c.trim()).filter(c => c);
  }
  
  // Find product title area
  const productTitle = document.querySelector('.product__title, h1, .product-single__title');
  if (!productTitle || document.getElementById('colorflexCustomColors')) return;
  
  // Create custom colors display
  const colorsDisplay = document.createElement('div');
  colorsDisplay.id = 'colorflexCustomColors';
  colorsDisplay.style.cssText = `
    margin: 12px 0;
    padding: 12px 16px;
    background: #2d3748;
    border-radius: 8px;
    color: white;
    font-size: 14px;
    border: 1px solid #4a5568;
  `;
  
  let displayHTML = `
    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;">
      <img src="https://so-animation.com/colorflex/img/camelion-sm-r.jpg" style="width: 32px; height: 32px; border-radius: 50%; border: 2px solid rgba(212, 175, 55, 0.6); box-shadow: 0 2px 6px rgba(0,0,0,0.3);" alt="ColorFlex">
      <div>
        <strong>${patternName}</strong> from ${collection} collection
        ${material ? ' • ' + material.charAt(0).toUpperCase() + material.slice(1) : ''}
      </div>
    </div>
  `;
  
  if (colorArray.length > 0) {
    displayHTML += `
      <div style="margin-top: 8px;">
        <div style="font-size: 12px; margin-bottom: 6px; opacity: 0.9;">Your Custom Colors:</div>
        <div style="display: flex; flex-wrap: wrap; gap: 6px;">
    `;
    
    // Set initial HTML structure
    colorsDisplay.innerHTML = displayHTML + `</div></div>`;
    
    // Load colors data and render badge
    fetch(window.ColorFlexAssets.colorsUrl)
      .then(response => response.json())
      .then(colorsData => {
        console.log('✅ Loaded colors data for badge:', colorsData.length, 'colors');
        
        // CFM.js color lookup function
        const lookupColor = (colorName) => {
          if (!colorName || typeof colorName !== "string") {
            console.warn(`Invalid colorName: ${colorName}, defaulting to #FFFFFF`);
            return "#FFFFFF";
          }
          const cleanedColorName = colorName.replace(/^(SW|SC|SWs|SCs|Sw|Sc|swsw|SWsw|SCsc|SCcs|Swsc|swsc)\d+\s*/i, "").toLowerCase().trim();
          if (/^#[0-9A-F]{6}$/i.test(cleanedColorName)) {
            return cleanedColorName;
          }
          const colorEntry = colorsData.find(c => c && typeof c.color_name === 'string' && c.color_name.toLowerCase() === cleanedColorName);
          if (!colorEntry) {
            console.warn(`Color '${cleanedColorName}' not found in colorsData, defaulting to #FFFFFF`);
            return "#FFFFFF";
          }
          return colorEntry.hex ? `#${colorEntry.hex}` : "#FFFFFF";
        };
        
        // CFM.js toInitialCaps function
        const toInitialCaps = (str) => {
          if (!str || typeof str !== 'string') {
            return '';
          }
          return str
            .toLowerCase()
            .split(' ')
            .map(word => word.charAt(0).toUpperCase() + word.slice(1))
            .join(' ');
        };
        
        // CFM.js getCleanColorName function
        const getCleanColorName = (colorName) => {
          if (!colorName || typeof colorName !== "string") {
            return colorName;
          }
          return colorName.replace(/^(SW|SC|SWs|SCs|Sw|Sc|swsw|SWsw|SCsc|SCcs|Swsc|swsc)\d+\s*/i, "").trim();
        };

        colorArray.forEach(color => {
          const cleanColor = getCleanColorName(color);
          const displayName = toInitialCaps(cleanColor);
          const hexColor = lookupColor(color);
          
          displayHTML += `
            <div style="
              display: flex;
              flex-direction: column;
              align-items: center;
              gap: 4px;
              margin-right: 8px;
            ">
              <div style="
                width: 28px; 
                height: 28px; 
                border-radius: 50%; 
                background-color: ${hexColor}; 
                border: 2px solid rgba(255,255,255,0.5);
                box-shadow: 0 2px 6px rgba(0,0,0,0.4);
                cursor: pointer;
                transition: transform 0.2s ease;
              " 
              title="${displayName}"
              onmouseover="this.style.transform='scale(1.1)'" 
              onmouseout="this.style.transform='scale(1)'">
              </div>
              <div style="
                font-size: 10px;
                text-align: center;
                opacity: 0.8;
                max-width: 60px;
                word-wrap: break-word;
                line-height: 1.1;
                color: #e2e8f0;
              ">${displayName}</div>
            </div>
          `;
        });
        
        // Complete the HTML and insert into DOM
        displayHTML += `
            </div>
          </div>
        `;
        
        colorsDisplay.innerHTML = displayHTML;
      })
      .catch(error => {
        console.error('❌ Failed to load colors data for badge:', error);
        // Fallback to simple display without color conversion
        colorArray.forEach(color => {
          displayHTML += `
            <div style="
              display: flex;
              flex-direction: column;
              align-items: center;
              gap: 4px;
              margin-right: 8px;
            ">
              <div style="
                width: 28px; 
                height: 28px; 
                border-radius: 50%; 
                background-color: ${color}; 
                border: 2px solid rgba(255,255,255,0.5);
                box-shadow: 0 2px 6px rgba(0,0,0,0.4);
                cursor: pointer;
                transition: transform 0.2s ease;
              " 
              title="${color}"
              onmouseover="this.style.transform='scale(1.1)'" 
              onmouseout="this.style.transform='scale(1)'">
              </div>
              <div style="
                font-size: 10px;
                text-align: center;
                opacity: 0.8;
                max-width: 60px;
                word-wrap: break-word;
                line-height: 1.1;
                color: #e2e8f0;
              ">${color}</div>
            </div>
          `;
        });
        
        displayHTML += `
            </div>
          </div>
        `;
        
        colorsDisplay.innerHTML = displayHTML;
      });
  }
  
  // Add download proof button
  
  colorsDisplay.innerHTML = displayHTML;
  
  // Insert after product title
  productTitle.parentNode.insertBefore(colorsDisplay, productTitle.nextSibling);
  console.log('✅ Custom colors display added under product title');

  // Now position material info box right after the colors display
  setTimeout(() => {
    const materialInfoBox = document.getElementById('colorflexMaterialInfo');
    if (materialInfoBox && materialInfoBox.style.display !== 'none') {
      colorsDisplay.parentNode.insertBefore(materialInfoBox, colorsDisplay.nextSibling);
      console.log('✅ Material info box repositioned after custom colors badge');
    }
  }, 100); // Small delay to ensure material info is rendered
}

// Hide description, variant picker, and shipping notice when product is customized from ColorFlex
function hideElementsForCustomizedProduct() {
  console.log('🔧 Hiding elements for customized ColorFlex product...');

  // Hide product description
  const descriptionBlock = document.querySelector('.product__description');
  if (descriptionBlock) {
    descriptionBlock.style.display = 'none';
    console.log('✅ Hidden product description');
  }

  // Hide variant picker (wallpaper type buttons)
  const variantPicker = document.querySelector('variant-radios, variant-selects');
  if (variantPicker) {
    variantPicker.style.display = 'none';
    console.log('✅ Hidden variant picker');
  }

  // Also hide any fieldset containing variants
  const variantFieldset = document.querySelector('fieldset[id*="variant"]');
  if (variantFieldset) {
    variantFieldset.style.display = 'none';
    console.log('✅ Hidden variant fieldset');
  }

  // Hide shipping/delivery info if present
  const shippingInfo = document.querySelector('[class*="shipping"], [class*="delivery"]');
  if (shippingInfo) {
    shippingInfo.style.display = 'none';
    console.log('✅ Hidden shipping info');
  }

  // Hide "Customize Options" button - pattern already customized
  const customizeBtn = document.querySelector('#openColorFlexBtn');
  if (customizeBtn) {
    customizeBtn.style.display = 'none';
    console.log('✅ Hidden Customize Options button (pattern already customized)');
  }
  const customizeBtnContainer = document.querySelector('.product__colorlex-button');
  if (customizeBtnContainer) {
    customizeBtnContainer.style.display = 'none';
    console.log('✅ Hidden Customize button container');
  }

  console.log('✅ Finished hiding elements for customized product');
}

// Show the Customize Colors & Patterns button and enhance it for ColorFlex products
function showCustomizeButton() {
  // Find and enhance the customize button since user has a ColorFlex pattern
  const customizeBtn = document.querySelector('#openColorFlexBtn');
  
  if (customizeBtn) {
    customizeBtn.style.display = '';
    customizeBtn.textContent = '🎨 Customize Options';
    customizeBtn.style.background = 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)';
    customizeBtn.style.color = 'white';
    console.log('✅ Customize Colors & Patterns button enhanced');
  } else {
    // Try finding buttons by text content and enhance them
    const buttons = document.querySelectorAll('button');
    buttons.forEach(btn => {
      const btnText = btn.textContent.toLowerCase();
      if (btnText.includes('customize') || btnText.includes('colors') || btnText.includes('patterns')) {
        btn.style.display = '';
        btn.textContent = '🎨 Customize Options';
        btn.style.background = 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)';
        btn.style.color = 'white';
        btn.style.border = 'none';
        btn.style.borderRadius = '6px';
        btn.style.padding = '12px 20px';
        console.log('✅ Customize button found and enhanced:', btn.textContent);
      }
    });
  }
}

// Download full-resolution proof of custom pattern
function downloadFullResolutionProof(patternName, collection, material) {
  console.log('📄 Downloading full-resolution print-ready proof for:', patternName, collection, material);
  console.log('🔧 PARAM DEBUG: patternName type:', typeof patternName, 'value:', patternName);
  console.log('🔧 PARAM DEBUG: collection type:', typeof collection, 'value:', collection);
  console.log('🔧 PARAM DEBUG: material type:', typeof material, 'value:', material);
  
  // Fix parameter types if needed
  const fixedPatternName = Array.isArray(patternName) ? patternName[0] : patternName;
  const fixedCollection = collection || 'unknown';
  
  console.log('🔧 FIXED PARAMS: patternName:', fixedPatternName, 'collection:', fixedCollection);
  
  // Get all URL parameters for debugging
  const debugParams = new URLSearchParams(window.location.search);
  console.log('🔍 ALL URL PARAMS:', Object.fromEntries(debugParams.entries()));
  
  // Get custom colors from URL parameters
  const customColors = debugParams.get('custom_colors');
  const patternNameFromURL = debugParams.get('pattern_name');
  const collectionFromURL = debugParams.get('collection');
  
  console.log('🔍 URL parameter values:');
  console.log('  - custom_colors:', customColors);
  console.log('  - pattern_name:', patternNameFromURL);
  console.log('  - collection:', collectionFromURL);
  
  // Use URL parameters as fallback if function parameters are invalid
  const finalPatternName = fixedPatternName || patternNameFromURL || 'unknown';
  const finalCollection = fixedCollection !== 'unknown' ? fixedCollection : (collectionFromURL || 'unknown');
  
  console.log('🎯 FINAL PARAMS: patternName:', finalPatternName, 'collection:', finalCollection);
  
  if (!customColors) {
    alert('No custom colors found. Please try again from the ColorFlex customizer.');
    return;
  }
  
  // Parse the custom colors with proper URL decoding
  const colorArray = decodeURIComponent(customColors).split(',').map(c => c.trim()).filter(c => c);
  console.log('🎨 PROOF DEBUG: Raw custom colors:', customColors);
  console.log('🎨 PROOF DEBUG: Decoded custom colors:', decodeURIComponent(customColors));
  console.log('🎨 PROOF DEBUG: Parsed custom colors array:', colorArray);
  console.log('🔧 PROOF DEBUG: Number of colors:', colorArray.length);
  
  // Test color parsing for each color
  colorArray.forEach((color, index) => {
    const parsed = parseColorEnhanced(color);
    console.log(`🎨 PROOF DEBUG: Color ${index + 1}: "${color}" -> RGB:`, parsed);
    if (!parsed) {
      console.error(`❌ PROOF DEBUG: Failed to parse color ${index + 1}: "${color}"`);
    }
  });
  
  
  console.log('🚀 Starting pattern proof generation...');
  console.log('🔧 DEBUG: Checking if generatePatternProof is available:', typeof window.generatePatternProof);
  console.log('🔧 DEBUG: window object keys containing "generate":', Object.keys(window).filter(k => k.includes('generate')));
  
  if (typeof window.generatePatternProof !== 'function') {
    console.error('❌ window.generatePatternProof is not available! Type:', typeof window.generatePatternProof);
    console.log('⏳ Waiting for ColorFlex script to load...');
    
    // Show loading message
    const loadingAlert = 'ColorFlex script is loading... Please wait a moment and try again.';
    alert(loadingAlert);
    
    // Try to wait for the script to load
    let retryCount = 0;
    const maxRetries = 10;
    const retryInterval = setInterval(() => {
      retryCount++;
      console.log(`🔄 Retry ${retryCount}/${maxRetries} - Checking for generatePatternProof...`);
      
      if (typeof window.generatePatternProof === 'function') {
        console.log('✅ Function now available! Retrying proof generation...');
        clearInterval(retryInterval);
        
        // Retry the proof generation
        window.generatePatternProof(finalPatternName, finalCollection, colorArray).then(canvas => {
          console.log('✅ Pattern proof generation complete, downloading...');
          window.downloadPatternProof(canvas, `${finalPatternName}_${finalCollection}_proof.jpg`);
        }).catch(error => {
          console.error('❌ Error in proof generation:', error);
          alert('Error generating proof. Check console for details.');
        });
        
      } else if (retryCount >= maxRetries) {
        console.error('❌ Script failed to load after', maxRetries, 'attempts');
        clearInterval(retryInterval);
        alert('ColorFlex script failed to load. Please refresh the page and try again.');
      }
    }, 500);
    
    return;
  }
  
  // Use the CFM.js proof generation function with fixed parameters
  window.generatePatternProof(finalPatternName, finalCollection, colorArray).then(canvas => {
    console.log('✅ Pattern proof generation complete, downloading...');
    // Download the clean pattern proof using CFM.js function
    window.downloadPatternProof(canvas, `${finalPatternName}_${finalCollection}_proof.jpg`);
  }).catch(error => {
    console.error('❌ Error in proof generation:', error);
    alert('Error generating proof. Check console for details.');
  });
}

