// Enhanced color parsing function that handles various color formats
async function parseColorEnhanced(colorStr) {
  if (!colorStr) return null;
  
  console.log('🔍 Parsing color:', `"${colorStr}"`);
  
  // Handle hex colors
  if (colorStr.startsWith('#')) {
    const hex = colorStr.slice(1);
    if (hex.length === 6) {
      const result = {
        r: parseInt(hex.slice(0, 2), 16),
        g: parseInt(hex.slice(2, 4), 16),
        b: parseInt(hex.slice(4, 6), 16)
      };
      console.log('✅ Parsed hex color:', result);
      return result;
    }
  }
  
  // Load colors from colors.json if not already loaded
  if (!window.colorFlexColors) {
    try {
      console.log('🔄 Loading colors from colors.json...');
      const response = await fetch('{{ "colors.json" | asset_url }}');
      const colorsData = await response.json();
      
      // Create lookup object for fast access
      window.colorFlexColors = {};
      colorsData.forEach(color => {
        const baseName = color.color_name.toLowerCase().trim();
        const rgb = { r: color.red, g: color.green, b: color.blue };
        
        // Add multiple variations for flexible matching
        window.colorFlexColors[baseName] = rgb;
        if (color.sw_number) {
          window.colorFlexColors[color.sw_number.toLowerCase() + ' ' + baseName] = rgb;
          window.colorFlexColors[color.sw_number.toLowerCase()] = rgb;
        }
      });
      console.log('✅ Loaded', Object.keys(window.colorFlexColors).length, 'color variations');
    } catch (error) {
      console.error('❌ Failed to load colors.json:', error);
      window.colorFlexColors = {}; // Fallback to empty object
    }
  }
  
  // Handle named colors
  const colorName = colorStr.toLowerCase().trim();
  
  // Check loaded colors first
  if (window.colorFlexColors && window.colorFlexColors[colorName]) {
    const result = window.colorFlexColors[colorName];
    console.log('✅ Parsed dynamic color:', `"${colorStr}" -> "${colorName}"`, result);
    return result;
  }
  
  // Fallback to hardcoded colors for backwards compatibility
  const namedColors = {
    'honorable blue': { r: 104, g: 131, b: 149 },  // SW6811
    'sw6811 honorable blue': { r: 104, g: 131, b: 149 },
    'alchemy': { r: 189, g: 179, b: 141 },  // SW6395
    'sw6395 alchemy': { r: 189, g: 179, b: 141 },
    'greenfield': { r: 107, g: 122, b: 93 },  // SW6439
    'sw6439 greenfield': { r: 107, g: 122, b: 93 },
    'iron ore': { r: 91, g: 94, b: 100 },  // SW7069
    'sw7069 iron ore': { r: 91, g: 94, b: 100 },
    // New colors for Flowering Fern pattern
    'rembrandt ruby': { r: 115, g: 45, b: 50 },  // SW0033
    'sw0033 rembrandt ruby': { r: 115, g: 45, b: 50 },
    'artifact': { r: 168, g: 146, b: 121 },  // SW6138
    'sw6138 artifact': { r: 168, g: 146, b: 121 },
    'messenger bag': { r: 87, g: 88, b: 93 },  // SW7740
    'sw7740 messenger bag': { r: 87, g: 88, b: 93 },
    // Additional missing colors
    'cordial': { r: 177, g: 44, b: 56 },  // Common cordial color
    'perfect periwinkle': { r: 192, g: 200, b: 220 },  // SW9065
    'sw9065 perfect periwinkle': { r: 192, g: 200, b: 220 },
    'plummy': { r: 121, g: 64, b: 115 },  // SW6558
    'sw6558 plummy': { r: 121, g: 64, b: 115 },
    // Key Largo botanicals colors
    'cottage linen': { r: 248, g: 244, b: 237 },  // SC0001
    'sc0001 cottage linen': { r: 248, g: 244, b: 237 },
    'roycroft rose': { r: 188, g: 127, b: 132 },  // SW2830
    'sw2830 roycroft rose': { r: 188, g: 127, b: 132 },
    'sleepy hollow': { r: 157, g: 171, b: 137 },  // SW6430
    'sw6430 sleepy hollow': { r: 157, g: 171, b: 137 },
    'jasper stone': { r: 158, g: 148, b: 127 },  // SW9133
    'sw9133 jasper stone': { r: 158, g: 148, b: 127 },
    'halcyon green': { r: 179, g: 191, b: 168 },  // SW6213
    'sw6213 halcyon green': { r: 179, g: 191, b: 168 },
    'quietude': { r: 188, g: 195, b: 179 },  // SW6212
    'sw6212 quietude': { r: 188, g: 195, b: 179 },
    'rainwashed': { r: 199, g: 205, b: 192 },  // SW6211
    'sw6211 rainwashed': { r: 199, g: 205, b: 192 },
    // Flowering Fern colors
    'caviar': { r: 52, g: 52, b: 52 },  // SW6990
    'sw6990 caviar': { r: 52, g: 52, b: 52 },
    'bracing blue': { r: 82, g: 125, b: 151 },  // SW6242
    'sw6242 bracing blue': { r: 82, g: 125, b: 151 },
    'ecru': { r: 239, g: 231, b: 218 },  // SW6115
    'sw6115 ecru': { r: 239, g: 231, b: 218 },
    // Bombay collection colors
    'lupine': { r: 98, g: 105, b: 154 },  // SW6810
    'sw6810 lupine': { r: 98, g: 105, b: 154 },
    // Basic colors
    'black': { r: 0, g: 0, b: 0 },
    'white': { r: 255, g: 255, b: 255 },
    'red': { r: 255, g: 0, b: 0 },
    'green': { r: 0, g: 255, b: 0 },
    'blue': { r: 0, g: 0, b: 255 }
  };
  
  if (namedColors[colorName]) {
    const result = namedColors[colorName];
    console.log('✅ Parsed named color:', `"${colorStr}" -> "${colorName}"`, result);
    return result;
  }
  
  // Handle rgb() format
  const rgbMatch = colorStr.match(/rgb\((\d+),\s*(\d+),\s*(\d+)\)/);
  if (rgbMatch) {
    const result = {
      r: parseInt(rgbMatch[1]),
      g: parseInt(rgbMatch[2]),
      b: parseInt(rgbMatch[3])
    };
    console.log('✅ Parsed RGB color:', result);
    return result;
  }
  
  console.warn('❌ Could not parse color:', colorStr);
  // Fallback to a default color
  return { r: 128, g: 128, b: 128 };
}

// Legacy color parsing function (kept for compatibility)
function parseColor(colorStr) {
  return parseColorEnhanced(colorStr);
