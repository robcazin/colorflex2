        button.addEventListener('mouseenter', () => {
          console.log('🖱️ Hover started for: ' + text);
          showTexturePreview(text, preview, canvas, label);
        });
        
        button.addEventListener('mouseleave', () => {
          console.log('🖱️ Hover ended for: ' + text);
          preview.style.display = 'none';
        });
      }
    });
    
    console.log('✅ Variant hover previews set up for ' + hoverCount + ' elements');
    return hoverCount;
  }

  // Generate texture preview on canvas
  function showTexturePreview(text, preview, canvas, label) {
    console.log('🖼️ Creating placeholder for: ' + text);
    
    const ctx = canvas.getContext('2d');
    
    // Determine color based on texture type
    let backgroundColor = '#e2e8f0'; // Default light gray
    let textColor = '#1e293b';
    
    if (text.includes('smooth')) {
      backgroundColor = '#10b981'; // Green
      textColor = '#ffffff';
    } else if (text.includes('rough')) {
      backgroundColor = '#f97316'; // Orange
      textColor = '#ffffff';
    } else if (text.includes('textured')) {
      backgroundColor = '#8b5cf6'; // Purple
      textColor = '#ffffff';
    } else if (text.includes('matte')) {
      backgroundColor = '#64748b'; // Gray
      textColor = '#ffffff';
    } else if (text.includes('glossy')) {
      backgroundColor = '#3b82f6'; // Blue
      textColor = '#ffffff';
    } else if (text.includes('satin')) {
      backgroundColor = '#ec4899'; // Pink
      textColor = '#ffffff';
    }
    
    // Clear and fill background
    ctx.fillStyle = backgroundColor;
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    
    // Generate texture pattern
    ctx.strokeStyle = adjustColor(backgroundColor, -25);
    ctx.lineWidth = 2;
    
    if (text.includes('smooth')) {
      // Clean horizontal lines for smooth texture
      for (let y = 30; y < canvas.height; y += 20) {
        ctx.beginPath();
        ctx.moveTo(20, y);
        ctx.lineTo(canvas.width - 20, y);
        ctx.stroke();
      }
    } else if (text.includes('rough')) {
      // Jagged random lines for rough texture
      ctx.lineWidth = 3;
      for (let i = 0; i < 30; i++) {
        ctx.beginPath();
        ctx.moveTo(Math.random() * canvas.width, Math.random() * canvas.height);
        ctx.lineTo(Math.random() * canvas.width, Math.random() * canvas.height);
        ctx.stroke();
      }
    } else if (text.includes('textured')) {
      // Grid pattern for textured surface
      for (let x = 20; x < canvas.width - 20; x += 30) {
        for (let y = 20; y < canvas.height - 20; y += 30) {
          ctx.strokeRect(x, y, 25, 25);
        }
      }
    } else {
      // Default diagonal pattern
      for (let x = 0; x < canvas.width; x += 20) {
        ctx.beginPath();
        ctx.moveTo(x, 0);
        ctx.lineTo(x + canvas.height, canvas.height);
        ctx.stroke();
      }
    }
    
    // Add text overlay
    ctx.fillStyle = textColor;
    ctx.font = 'bold 16px Arial';
    ctx.textAlign = 'center';
    ctx.fillText('PREVIEW', canvas.width / 2, canvas.height / 2 - 10);
    ctx.font = '14px Arial';
    ctx.fillText('Texture Sample', canvas.width / 2, canvas.height / 2 + 15);
    
    // Update label and show preview
    label.textContent = text.toUpperCase() + ' TEXTURE';
    preview.style.display = 'block';
  }

  // Color adjustment utility
  function adjustColor(hex, percent) {
    const num = parseInt(hex.replace('#', ''), 16);
    const amt = Math.round(2.55 * percent);
    const R = Math.min(255, Math.max(0, (num >> 16) + amt));
    const G = Math.min(255, Math.max(0, (num >> 8 & 0x00FF) + amt));
    const B = Math.min(255, Math.max(0, (num & 0x0000FF) + amt));
    return '#' + ((1 << 24) + (R << 16) + (G << 8) + B).toString(16).slice(1);
  }

  // Initialize all enhancements
  function initEnhancedCustomWallpaperFixes() {
    console.log('🚀 Initializing Enhanced Custom Wallpaper Fixes...');
    
    // Remove download buttons immediately
    const removedCount = removeDownloadButtons();
    
    // Set up hover previews
    const hoverCount = setupHoverPreviews();
    
    console.log('📊 Summary: ' + removedCount + ' buttons removed, ' + hoverCount + ' hover previews set up');
    
    // Secondary scan for late-loading elements
    setTimeout(() => {
      console.log('🔄 Secondary scan for late-loading elements...');
      removeDownloadButtons();
    }, 3000);
    
    // Monitor for dynamic content with mutation observer
    const observer = new MutationObserver((mutations) => {
      let shouldRescan = false;
      mutations.forEach(mutation => {
        if (mutation.addedNodes.length > 0) {
          mutation.addedNodes.forEach(node => {
            if (node.nodeType === 1) { // Element node
              const text = node.textContent || '';
              if (text.includes('download') || text.includes('button') || text.includes('proof')) {
                shouldRescan = true;
              }
            }
          });
        }
      });
      
      if (shouldRescan) {
        console.log('🔄 Content changed, rescanning for download buttons...');
        removeDownloadButtons();
      }
    });
    
    observer.observe(document.body, { 
      childList: true, 
      subtree: true,
      attributes: false,
      characterData: false
    });
    
    console.log('✅ Mutation observer active for dynamic content monitoring');
  }

  // Start enhanced fixes
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initEnhancedCustomWallpaperFixes);
  } else {
    initEnhancedCustomWallpaperFixes();
  }

  console.log('✅ Enhanced Custom Wallpaper Fixes Script Loaded');
  </script>

