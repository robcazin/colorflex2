<product-info
  id="MainProduct-{{ section.id }}"
  class="section-{{ section.id }}-padding gradient color-{{ section.settings.color_scheme }}"
  data-section="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-update-url="true"
  data-url="{{ product.url }}"
  {% if section.settings.image_zoom == 'hover' %}
    data-zoom-on-hover
  {% endif %}
>
  {{ 'section-main-product.css' | asset_url | stylesheet_tag }}
  {{ 'component-accordion.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'component-slider.css' | asset_url | stylesheet_tag }}
  {{ 'component-rating.css' | asset_url | stylesheet_tag }}
  {{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}

  {% unless product.has_only_default_variant %}
    {{ 'component-product-variant-picker.css' | asset_url | stylesheet_tag }}
    {{ 'component-swatch-input.css' | asset_url | stylesheet_tag }}
    {{ 'component-swatch.css' | asset_url | stylesheet_tag }}
  {% endunless %}
  {%- if product.quantity_price_breaks_configured? -%}
    {{ 'component-volume-pricing.css' | asset_url | stylesheet_tag }}
  {%- endif -%}

  {%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
  {%- endstyle -%}

  <script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
  
  <!-- Multi-Step Product Configuration Flow Integration - REMOVED to prevent duplicates (loaded in product.liquid template) -->
  
  <!-- Set up ColorFlex asset URLs for JavaScript -->
  <script>
    window.ColorFlexAssets = {
      colorsUrl: '{{ "colors.json" | asset_url }}',
      collectionsUrl: '{{ "collections.json" | asset_url }}'
    };
  </script>
  {%- if product.quantity_price_breaks_configured? -%}
    <script src="{{ 'show-more.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  {% if section.settings.image_zoom == 'hover' %}
    <script id="EnableZoomOnHover-main" src="{{ 'magnify.js' | asset_url }}" defer="defer"></script>
  {% endif %}
  {%- if request.design_mode -%}
    <script src="{{ 'theme-editor.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  {%- assign first_3d_model = product.media | where: 'media_type', 'model' | first -%}
  {%- if first_3d_model -%}
    {{ 'component-product-model.css' | asset_url | stylesheet_tag }}
    <link
      id="ModelViewerStyle"
      rel="stylesheet"
      href="https://cdn.shopify.com/shopifycloud/model-viewer-ui/assets/v1.0/model-viewer-ui.css"
      media="print"
      onload="this.media='all'"
    >
    <link
      id="ModelViewerOverride"
      rel="stylesheet"
      href="{{ 'component-model-viewer-ui.css' | asset_url }}"
      media="print"
      onload="this.media='all'"
    >
  {%- endif -%}

  {% assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src' %}
  <div class="page-width">
    <div class="product product--{{ section.settings.media_size }} product--{{ section.settings.media_position }} product--{{ section.settings.gallery_layout }} product--mobile-{{ section.settings.mobile_thumbnails }} grid grid--1-col {% if product.media.size > 0 %}grid--2-col-tablet{% else %}product--no-media{% endif %}">
      <div class="grid__item product__media-wrapper">
        {% render 'product-media-gallery', variant_images: variant_images %}
      </div>
      <div class="product__info-wrapper grid__item{% if settings.page_width > 1400 and section.settings.media_size == "small" %} product__info-wrapper--extra-padding{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        <section
          id="ProductInfo-{{ section.id }}"
          class="product__info-container{% if section.settings.enable_sticky_info %} product__column-sticky{% endif %}"
        >
          {%- assign product_form_id = 'product-form-' | append: section.id -%}

          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when '@app' -%}
                {% render block %}
              {%- when 'text' -%}
                <p
                  class="product__text inline-richtext{% if block.settings.text_style == 'uppercase' %} caption-with-letter-spacing{% elsif block.settings.text_style == 'subtitle' %} subtitle{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  {{- block.settings.text -}}
                </p>
              {%- when 'title' -%}
                <div class="product__title" {{ block.shopify_attributes }}>
                  <h1>{{ product.title | escape }}</h1>
                  <a href="{{ product.url }}" class="product__title">
                    <h2 class="h1">
                      {{ product.title | escape }}
                    </h2>
                  </a>
                </div>
              {%- when 'price' -%}
                <div id="price-{{ section.id }}" role="status" {{ block.shopify_attributes }}>
                  {%- render 'price',
                    product: product,
                    use_variant: true,
                    show_badges: true,
                    price_class: 'price--large'
                  -%}
                </div>
                {%- if product.quantity_price_breaks_configured? -%}
                  <div class="volume-pricing-note" id="Volume-Note-{{ section.id }}">
                    <span>{{ 'products.product.volume_pricing.note' | t }}</span>
                  </div>
                {%- endif -%}
                {%- if cart.taxes_included or cart.duties_included -%}
                  <div class="product__tax caption rte">
                    {%- if cart.duties_included and cart.taxes_included -%}
                      {{ 'products.product.duties_and_taxes_included' | t }}
                    {%- elsif cart.taxes_included -%}
                      {{ 'products.product.taxes_included' | t }}
                    {%- elsif cart.duties_included -%}
                      {{ 'products.product.duties_included' | t }}
                    {%- endif -%}
                  </div>
                {%- endif -%}
                <div {{ block.shopify_attributes }}>
                  {%- assign product_form_installment_id = 'product-form-installment-' | append: section.id -%}
                  {%- form 'product', product, id: product_form_installment_id, class: 'installment caption-large' -%}
                    <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                    {{ form | payment_terms }}
                  {%- endform -%}
                </div>

                            <!-- ColorFlex Button Integration -->
              {%- assign layer_count = product.metafields.color_flex.layer_count -%}
              {%- assign pattern_name = product.metafields.custom.pattern.value -%}
              {%- assign collection_name = product.metafields.custom.collection.value -%}
              
              {%- comment -%}
              Show ColorFlex button for ALL patterns that should be viewable in ColorFlex:
              1. ColorFlex customizable patterns (layer_count > 0) 
              2. Standard patterns (layer_count 0/null) for scaling/mockup viewing
              Check for pattern and collection metafields instead of just layer_count
              {%- endcomment -%}
              {%- if pattern_name and collection_name -%}
              <div class="product__colorlex-button" style="margin: 2rem 0; text-align: left;">
                <button type="button" id="openColorFlexBtn">
                  Explore the color possibilities
                </button>
              </div>
              {%- endif -%}

              
              {%- when 'inventory' -%}
                <p
                  class="product__inventory{% if block.settings.text_style == 'uppercase' %} caption-with-letter-spacing{% elsif block.settings.text_style == 'subtitle' %} subtitle{% endif %}{% if product.selected_or_first_available_variant.inventory_management != 'shopify' %} visibility-hidden{% endif %}"
                  {{ block.shopify_attributes }}
                  id="Inventory-{{ section.id }}"
                  role="status"
                >
                  {%- if product.selected_or_first_available_variant.inventory_management == 'shopify' -%}
                    {%- if product.selected_or_first_available_variant.inventory_quantity > 0 -%}
                      {%- if product.selected_or_first_available_variant.inventory_quantity
                          <= block.settings.inventory_threshold
                      -%}
                        <span class="svg-wrapper" style="color: rgb(238, 148, 65)">
                          {{- 'icon-inventory-status.svg' | inline_asset_content -}}
                        </span>
                        {%- if block.settings.show_inventory_quantity -%}
                          {{-
                            'products.product.inventory_low_stock_show_count'
                            | t: quantity: product.selected_or_first_available_variant.inventory_quantity
                          -}}
                        {%- else -%}
                          {{- 'products.product.inventory_low_stock' | t -}}
                        {%- endif -%}
                      {%- else -%}
                        <span class="svg-wrapper" style="color: rgb(62, 214, 96)">
                          {{- 'icon-inventory-status.svg' | inline_asset_content -}}
                        </span>
                        {%- if block.settings.show_inventory_quantity -%}
                          {{-
                            'products.product.inventory_in_stock_show_count'
                            | t: quantity: product.selected_or_first_available_variant.inventory_quantity
                          -}}
                        {%- else -%}
                          {{- 'products.product.inventory_in_stock' | t -}}
                        {%- endif -%}
                      {%- endif -%}
                    {%- else -%}
                      {%- if product.selected_or_first_available_variant.inventory_policy == 'continue' -%}
                        <span class="svg-wrapper" style="color: rgb(62, 214, 96)">
                          {{- 'icon-inventory-status.svg' | inline_asset_content -}}
                        </span>
                        {{- 'products.product.inventory_out_of_stock_continue_selling' | t -}}
                      {%- else -%}
                        <span class="svg-wrapper" style="color: rgb(200, 200, 200)">
                          {{- 'icon-inventory-status.svg' | inline_asset_content -}}
                        </span>
                        {{- 'products.product.inventory_out_of_stock' | t -}}
                      {%- endif -%}
                    {%- endif -%}
                  {%- endif -%}
                </p>
              {%- when 'description' -%}
                {%- if product.description != blank -%}
                  <div class="product__description-stack rte quick-add-hidden" {{ block.shopify_attributes }}>
                    {% render 'product-pattern-description', product: product %}
                  </div>
                {%- endif -%}

              
              
              <script>
document.getElementById('openColorFlexBtn').addEventListener('click', function() {
  console.log('🎨 Launching ColorFlex...');
  
  // Gather product information
  const productType = '{{ product.type }}';
  const productCollection = '{{ collection.handle }}';
  const productTags = '{{ product.tags | join: "," }}';
  const productTitle = '{{ product.title }}';
  
  console.log('📊 Product info:', { productType, productCollection, productTags, productTitle });
  
  // Use product metafields directly - no mapping needed!
  const metaCollection = '{{ product.metafields.custom.collection.value }}';
  const metaPattern = '{{ product.metafields.custom.pattern.value }}';
  
  console.log('📋 Product metafields:', {
    collection: metaCollection,
    pattern: metaPattern,
    all_custom: {{ product.metafields.custom | json }},
    all_metafields: {{ product.metafields | json }}
  });
  
  // Use metafield data directly if available
  let colorFlexCollection = metaCollection || 'english-cottage'; // Use metafield or fallback to first collection
  let colorFlexPattern = metaPattern || null; // Use metafield pattern if available
  
  // FALLBACK: If no pattern metafield, extract from product title
  if (!colorFlexPattern || colorFlexPattern === '') {
    // Extract pattern name from title (remove "Wallpaper" etc)
    const cleanTitle = productTitle
      .replace(/\s*(wallpaper|wall\s*paper)\s*/gi, '')
      .trim();
    colorFlexPattern = cleanTitle;
    console.log(`🔄 No pattern metafield, extracted from title: "${cleanTitle}"`);
  }
  
  if (metaCollection && metaCollection !== '') {
    console.log(`✅ Using metafield collection directly: "${metaCollection}"`);
    console.log(`🚨 METAFIELD OVERRIDE: Product title "${productTitle}" has metafield collection="${metaCollection}"`);
  } else {
    console.log('ℹ️ No metafield collection found, using fallback pattern matching');
    console.log(`🔍 PATTERN MATCHING: Will analyze title "${productTitle}" for collection`);
  }
  
  // PRIORITY 2: Pattern matching fallback (only if no metadata collection)
  if (!metaCollection || metaCollection === '') {
    // Enhanced mapping logic
    const title = productTitle.toLowerCase();
    const type = productType.toLowerCase();
    const tags = productTags.toLowerCase();
    const collection = productCollection.toLowerCase();
  
  // Check in order of specificity - COMPREHENSIVE PATTERN MAPPING
  // BOMBAY COLLECTION - Indian city patterns
  if (title.includes('etawah') || title.includes('delhi') || title.includes('mumbai') || 
      title.includes('pune') || title.includes('calcutta') || title.includes('bangalore') ||
      title.includes('morena') || title.includes('arcot') || title.includes('darjeeling') ||
      title.includes('agra') || title.includes('jaipur') || title.includes('lucknow') || 
      title.includes('kanpur') || title.includes('bombay') || title.includes('diamond harbour')) {
    colorFlexCollection = 'bombay';
  }
  // ENGLISH COTTAGE COLLECTION - British cottage patterns
  else if (title.includes('keswick') || title.includes('lyme regis') || title.includes('maidstone') ||
           title.includes('yarmouth') || title.includes('penzance') || title.includes('crowborough') ||
           title.includes('ashbourn') || title.includes('chippendale') || title.includes('canterbury') ||
           title.includes('dartmouth') || title.includes('cheltenham') || title.includes('northwich') ||
           title.includes('chelmsford') || title.includes('daisey in the middle') || title.includes('baythorn') ||
           title.includes('newton') || title.includes('chester') || title.includes('aye lassie') ||
           title.includes('avesbury')) {
    colorFlexCollection = 'english-cottage';
    console.log('🏠 AVESBURY DETECTED: Setting collection to english-cottage');
  }
  // FARMHOUSE COLLECTION - American farmhouse patterns
  else if (title.includes('cottage') || title.includes('english') || title.includes('manor') ||
           title.includes('farmhouse') || title.includes('chicken') || title.includes('lancaster') ||
           title.includes('root vegetables') || title.includes('farm toile') ||
           type.includes('farmhouse') || collection === 'farmhouse' || tags.includes('farmhouse')) {
    colorFlexCollection = 'farmhouse';
  }
  // BOTANICALS COLLECTION
  else if (title.includes('flowering fern') || title.includes('key largo') || title.includes('shadow dance') ||
           title.includes('tall lilly') || title.includes('dutch stripe') || title.includes('billings') ||
           type.includes('botanical') || collection === 'botanicals' || tags.includes('botanical')) {
    colorFlexCollection = 'botanicals';
  }
  // COORDINATES COLLECTION
  else if (title.includes('coordinate') || title.includes('plaid') || title.includes('check') ||
           title.includes('gingham') || title.includes('tartan') || title.includes('stripe') ||
           title.includes('dakota') || title.includes('baythorn') || title.includes('dottie') ||
           type.includes('coordinate') || tags.includes('coordinate')) {
    colorFlexCollection = 'coordinates';
  }
  // OTHER COLLECTIONS
  else if (title.includes('abundance') || type.includes('abundance') || tags.includes('abundance')) {
    colorFlexCollection = 'abundance';
  }
  else if (title.includes('coverlet') || title.includes('piqua') || title.includes('oxford') ||
           title.includes('franklin') || title.includes('charleston') || title.includes('rosemount')) {
    colorFlexCollection = 'coverlets';
  }
  else if (title.includes('tradition') || title.includes('florencia') || title.includes('agnes') ||
           title.includes('madeline') || title.includes('rosemary') || title.includes('esperanza')) {
    colorFlexCollection = 'traditions';
  }
  else if (title.includes('geometry') || title.includes('riparian') || title.includes('fluvial') ||
           title.includes('meander') || title.includes('oxbow') || title.includes('rapids') ||
           title.includes('allurium')) {
    colorFlexCollection = 'geometry';
  }
  else if (title.includes('concordia') || type.includes('concordia') || tags.includes('concordia')) {
    colorFlexCollection = 'concordia';
  }
  // FOLKSIE COLLECTION - Folk art and primitive patterns
  else if (title.includes('folksie') || title.includes('folk') || title.includes('primitive') ||
           title.includes('handmade') || title.includes('artisan') || title.includes('craft') ||
           title.includes('naive') || title.includes('flame tree') || title.includes('flame') ||
           type.includes('folksie') || tags.includes('folk')) {
    colorFlexCollection = 'folksie';
  }
  // ANCIENT TILES COLLECTION - Historical tile patterns
  else if (title.includes('tripoli') || title.includes('amsterdam') || title.includes('hastings') ||
           title.includes('plymouth') || title.includes('algiers') || title.includes('corsica') ||
           title.includes('izmir') || title.includes('tangier') || title.includes('monaco') ||
           title.includes('harwich') || title.includes('marseille') || title.includes('torquay') ||
           title.includes('osaka') || title.includes('valencia') || title.includes('ancient') ||
           type.includes('ancient-tiles') || tags.includes('ancient') || collection === 'ancient-tiles') {
    colorFlexCollection = 'ancient-tiles';
  }
  // DISHED UP COLLECTION - Colorful patterns
  else if (title.includes('purple') || title.includes('orange') || title.includes('green') ||
           title.includes('red') || title.includes('blue') || title.includes('pink') ||
           title.includes('yellow') || title.includes('burgundy') || title.includes('brown') ||
           title.includes('teal') || title.includes('lime') || title.includes('olive') ||
           title.includes('dished') || title.includes('slate') || title.includes('sage') ||
           title.includes('terra cotta') || type.includes('dished-up') || tags.includes('dished') || 
           collection === 'dished-up') {
    colorFlexCollection = 'dished-up';
  }
  // PAGES COLLECTION - Historical document patterns
  else if (title.includes('page') || title.includes('document') || title.includes('manuscript') ||
           title.includes('parchment') || title.includes('scroll') || type.includes('pages') || 
           tags.includes('pages') || collection === 'pages') {
    colorFlexCollection = 'pages';
  }
  // GALLERIA COLLECTION - Art gallery patterns
  else if (title.includes('galleria') || title.includes('gallery') || title.includes('artistic') ||
           type.includes('galleria') || tags.includes('galleria') || collection === 'galleria') {
    colorFlexCollection = 'galleria';
  }
  } // End of pattern matching fallback
  
  console.log(`🎯 Detected collection: ${colorFlexCollection}`);
  
  // DEBUG: Log specific pattern mappings for verification
  const titleForDebug = productTitle.toLowerCase();
  if (titleForDebug.includes('keswick')) {
    console.log(`✅ KESWICK FIX: Keswick pattern mapped to ${colorFlexCollection} collection`);
  }
  if (titleForDebug.includes('etawah')) {
    console.log('✅ ETAWAH FIX: Etawah pattern correctly mapped to bombay collection');
  }
  if (titleForDebug.includes('morena')) {
    console.log('✅ MORENA FIX: Morena pattern correctly mapped to bombay collection');
  }
  
  // Build the URL
  const baseUrl = '/pages/colorflex';
  const params = new URLSearchParams({
    variant_id: '{{ product.selected_or_first_available_variant.id }}',
    collection: colorFlexCollection,
    product_title: '{{ product.title | url_param_escape }}',
    source: 'product_page'
  });
  
  // Add pattern parameter if available from metafields
  if (colorFlexPattern && colorFlexPattern !== '') {
    params.set('pattern', colorFlexPattern);
    console.log(`✅ Adding pattern parameter: "${colorFlexPattern}"`);
  }
  
  const fullUrl = `${baseUrl}?${params.toString()}`;
  console.log('🔗 Opening URL:', fullUrl);
  
  // Open ColorFlex window - reuse same window if it exists  
  console.log('🪟 Opening ColorFlex in same window (ColorFlexApp)');
  const colorFlexWindow = window.open(
    fullUrl,
    'ColorFlexApp',
    'width=1920,height=1080,scrollbars=yes,resizable=yes,menubar=no,toolbar=no,location=no'
  );
  
  if (colorFlexWindow) {
    colorFlexWindow.focus();
    console.log('✅ ColorFlex window opened successfully');
    
    // Optional: Listen for messages from the ColorFlex window
    window.addEventListener('message', function(event) {
      if (event.source === colorFlexWindow) {
        console.log('📨 Message from ColorFlex:', event.data);
        
        // Handle different message types
        if (event.data.type === 'cart_add_success') {
          // Refresh cart or show notification
          console.log('🛒 Item added to cart successfully');
          
          // Optional: Close the ColorFlex window
          if (event.data.closeWindow) {
            colorFlexWindow.close();
          }
          
          // Optional: Refresh the current page's cart
          if (typeof window.updateCartCount === 'function') {
            window.updateCartCount();
          }
        }
      }
    });
    
  } else {
    console.warn('⚠️ Popup blocked, trying fallback...');
    
    // Fallback: open in same window
    if (confirm('Pop-up was blocked. Open ColorFlex in this window instead?')) {
      window.location.href = fullUrl;
    }
  }
});
              </script>
              
              
                            

              {%- when 'sku' -%}
                <p
                  class="product__sku{% if block.settings.text_style == 'uppercase' %} caption-with-letter-spacing{% elsif block.settings.text_style == 'subtitle' %} subtitle{% endif %}{% if product.selected_or_first_available_variant.sku.size == 0 %} visibility-hidden{% endif %}"
                  id="Sku-{{ section.id }}"
                  role="status"
                  {{ block.shopify_attributes }}
                >
                  <span class="visually-hidden">{{ 'products.product.sku' | t }}:</span>
                  {{- product.selected_or_first_available_variant.sku -}}
                </p>
              {%- when 'custom_liquid' -%}
                {{ block.settings.custom_liquid }}
              {%- when 'collapsible_tab' -%}
                <div class="product__accordion accordion quick-add-hidden" {{ block.shopify_attributes }}>
                  <details id="Details-{{ block.id }}-{{ section.id }}">
                    <summary>
                      <div class="summary__title">
                        {% render 'icon-accordion', icon: block.settings.icon %}
                        <h2 class="h4 accordion__title inline-richtext">
                          {{ block.settings.heading | default: block.settings.page.title | escape }}
                        </h2>
                      </div>
                      {{- 'icon-caret.svg' | inline_asset_content -}}
                    </summary>
                    <div class="accordion__content rte" id="ProductAccordion-{{ block.id }}-{{ section.id }}">
                      {{ block.settings.content }}
                      {{ block.settings.page.content }}
                    </div>
                  </details>
                </div>
              {%- when 'quantity_selector' -%}
                <div
                  id="Quantity-Form-{{ section.id }}"
                  class="product-form__input product-form__quantity{% if settings.inputs_shadow_vertical_offset != 0 and settings.inputs_shadow_vertical_offset < 0 %} product-form__quantity-top{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  {% comment %} TODO: enable theme-check once `item_count_for_variant` is accepted as valid filter {% endcomment %}
                  {% # theme-check-disable %}
                  {%- assign cart_qty = cart
                    | item_count_for_variant: product.selected_or_first_available_variant.id
                  -%}
                  {% # theme-check-enable %}
                  <label class="quantity__label form__label" for="Quantity-{{ section.id }}">
                    {{ 'products.product.quantity.label' | t }}
                    <span class="quantity__rules-cart{% if cart_qty == 0 %} hidden{% endif %}">
                      {%- render 'loading-spinner' -%}
                      <span
                        >(
                        {{- 'products.product.quantity.in_cart_html' | t: quantity: cart_qty -}}
                        )</span
                      >
                    </span>
                  </label>
                  <div class="price-per-item__container">
                    <quantity-input class="quantity" data-url="{{ product.url }}" data-section="{{ section.id }}">
                      <button class="quantity__button" name="minus" type="button">
                        <span class="visually-hidden">
                          {{- 'products.product.quantity.decrease' | t: product: product.title | escape -}}
                        </span>
                        <span class="svg-wrapper">
                          {{- 'icon-minus.svg' | inline_asset_content -}}
                        </span>
                      </button>
                      <input
                        class="quantity__input"
                        type="number"
                        name="quantity"
                        id="Quantity-{{ section.id }}"
                        data-cart-quantity="{{ cart_qty }}"
                        data-min="{{ product.selected_or_first_available_variant.quantity_rule.min }}"
                        min="{{ product.selected_or_first_available_variant.quantity_rule.min }}"
                        {% if product.selected_or_first_available_variant.quantity_rule.max != null %}
                          data-max="{{ product.selected_or_first_available_variant.quantity_rule.max }}"
                          max="{{ product.selected_or_first_available_variant.quantity_rule.max }}"
                        {% endif %}
                        step="{{ product.selected_or_first_available_variant.quantity_rule.increment }}"
                        value="{{ product.selected_or_first_available_variant.quantity_rule.min }}"
                        form="{{ product_form_id }}"
                      >
                      <button class="quantity__button" name="plus" type="button">
                        <span class="visually-hidden">
                          {{- 'products.product.quantity.increase' | t: product: product.title | escape -}}
