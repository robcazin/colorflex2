// Helper function to download the proof image
function downloadProofImage(canvas, filename) {
  canvas.toBlob(function(blob) {
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = filename;
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    URL.revokeObjectURL(url);
    console.log('✅ Proof downloaded:', filename);
  }, 'image/jpeg', 0.98);
}


function populateColorFlexProperties(urlParams) {
  // Populate hidden form fields with ColorFlex data
  const fields = {
    'colorflex-pattern-name': urlParams.get('pattern_name'),
    'colorflex-collection': urlParams.get('collection'),
    'colorflex-custom-colors': urlParams.get('custom_colors') || '',
    'colorflex-material-type': urlParams.get('application') || urlParams.get('material'),
    'colorflex-pattern-id': urlParams.get('pattern_id'),
    'colorflex-save-date': urlParams.get('save_date')
  };
  
  // Move hidden fields into the product form
  const productForm = document.querySelector('form[action*="/cart/add"]');
  const hiddenFieldsContainer = document.getElementById('colorflexFormFields');
  
  if (productForm && hiddenFieldsContainer) {
    // Move each hidden field into the product form
    const hiddenFields = hiddenFieldsContainer.querySelectorAll('input[type="hidden"]');
    hiddenFields.forEach(field => {
      // Set the value if we have data for it
      const value = fields[field.id];
      if (value) {
        field.value = decodeURIComponent(value);
      }
      
      // Move field into the product form
      productForm.appendChild(field);
    });
    
    console.log('✅ ColorFlex properties added to product form');
    console.log('📋 Pattern:', fields['colorflex-pattern-name']);
    console.log('📁 Collection:', fields['colorflex-collection']);
    console.log('🎨 Colors:', fields['colorflex-custom-colors']);
    console.log('📦 Material:', fields['colorflex-material-type']);
  } else {
    console.warn('⚠️ Could not find product form or hidden fields container');
  }
}
