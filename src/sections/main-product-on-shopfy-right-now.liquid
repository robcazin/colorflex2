    `;
    
    preview.appendChild(canvas);
    preview.appendChild(label);
    document.body.appendChild(preview);
    
    // Enhanced button selector - target ALL possible variant/texture buttons
    const allButtons = document.querySelectorAll('fieldset button, [class*="texture"] button, [class*="variant"] button, [class*="option"] button, [class*="material"] button, [class*="finish"] button, button[data-variant], button[data-value], button[data-option], .product-form button, .variant-input button, .option-button, .texture-option, .material-option, input[type="radio"] + label, button:not([class*="add"]):not([class*="buy"]):not([class*="cart"])');
    console.log('🔍 Found ' + allButtons.length + ' potential variant buttons to check');
    
    let hoverCount = 0;
    
    allButtons.forEach((button, index) => {
      const text = (button.textContent || button.innerText || button.getAttribute('title') || button.getAttribute('data-value') || '').trim().toLowerCase();
      
      console.log('🔍 Element ' + index + ': {tag: "' + button.tagName + '", text: "' + text.substring(0, 20) + '", hasPreview: ' + (text.includes('smooth') || text.includes('rough') || text.includes('textured') || text.includes('texture') || text.includes('material') || text.includes('finish')) + '}');
      
      // Check for texture/material related terms
      if (text.includes('smooth') || text.includes('rough') || text.includes('textured') ||
          text.includes('texture') || text.includes('material') || text.includes('finish') ||
          text.includes('matte') || text.includes('glossy') || text.includes('satin')) {
        
        console.log('🎯 Setting up hover for: "' + text + '"');
