    {% comment %} CUSTOM WALLPAPER ENHANCEMENTS {% endcomment %}
  <script>
  // Only run on Custom Wallpaper products or when URL contains pattern parameters
  const urlParams = new URLSearchParams(window.location.search);
  const isCustomWallpaper = window.location.pathname.includes('custom-wallpaper')
  ||
                           urlParams.get('source') === 'colorflex_saved_patterns'
  ||
                           urlParams.get('pattern_name');

  if (isCustomWallpaper) {
    console.log('🎨 CUSTOM WALLPAPER PAGE DETECTED');
    console.log('URL:', window.location.href);
    console.log('Pattern Name:', urlParams.get('pattern_name'));
    
    // AGGRESSIVE Download Proof Button Removal
    function removeDownloadButtons() {
      console.log('🔍 Scanning for download proof buttons...');
      
      const buttons = document.querySelectorAll('button, input[type="button"], 
  input[type="submit"], a[class*="button"]');
      let removed = 0;
      
      buttons.forEach(button => {
        const text = (button.textContent || button.innerText || button.value || 
  '').toLowerCase();
        
        if ((text.includes('download') && (text.includes('proof') || 
  text.includes('resolution'))) ||
            text.includes('full-resolution') ||
            text.trim() === 'download full-resolution proof') {
          
          console.log('🗑️ REMOVING BUTTON:', button.textContent || button.value);
          button.style.display = 'none';
          button.style.visibility = 'hidden';
          button.style.opacity = '0';
          button.remove();
          removed++;
        }
      });
      
      console.log('✅ Removed', removed, 'download buttons');
      return removed;
    }

    // HOVER PREVIEWS for texture buttons
    function setupHoverPreviews() {
      console.log('🖼️ Setting up hover previews...');
      
      // Create preview container
      const preview = document.createElement('div');
      preview.id = 'texturePreview';
      preview.style.cssText = `
        position: fixed;
        top: 50%;
        right: 20px;
        transform: translateY(-50%);
        width: 300px;
        height: 300px;
        background: white;
        border: 3px solid #667eea;
        border-radius: 12px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.3);
        display: none;
        z-index: 10000;
        overflow: hidden;
      `;
      
      const img = document.createElement('canvas');
      img.width = 300;
      img.height = 300;
      img.style.cssText = 'width: 100%; height: 100%; display: block;';
      
      const label = document.createElement('div');
      label.style.cssText = `
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 10px;
        text-align: center;
        font-weight: bold;
      `;
      
      preview.appendChild(img);
      preview.appendChild(label);
      document.body.appendChild(preview);
      
      // Find ALL buttons and check their text
      const allButtons = document.querySelectorAll('button, .btn, 
  [class*="button"], [role="button"]');
      console.log('🔍 Found', allButtons.length, 'total buttons');
      
      allButtons.forEach((btn, i) => {
        const text = (btn.textContent || btn.innerText || '').trim();
        console.log(`Button ${i}: "${text}"`);
        
        if (text.toLowerCase() === 'smooth' || text.toLowerCase() === 'rough' || 
  text.toLowerCase() === 'textured' || 
            text.toLowerCase().includes('texture') || 
  text.toLowerCase().includes('material')) {
          
          console.log('✅ Adding hover to:', text);
          
          btn.addEventListener('mouseenter', (e) => {
            console.log('🖱️ Hover started:', text);
            showPreview(text, img, label, preview);
          });
          
          btn.addEventListener('mouseleave', () => {
            preview.style.display = 'none';
          });
        }
      });
    }

    function showPreview(text, canvas, label, preview) {
      const ctx = canvas.getContext('2d');
      
      // Clear canvas
      ctx.clearRect(0, 0, 300, 300);
      
      // Color based on texture
      let color = '#667eea';
      if (text.toLowerCase().includes('smooth')) color = '#48bb78';
      if (text.toLowerCase().includes('rough')) color = '#ed8936'; 
      if (text.toLowerCase().includes('textured')) color = '#805ad5';
      
      // Create gradient background
      const gradient = ctx.createLinearGradient(0, 0, 300, 300);
      gradient.addColorStop(0, color);
      gradient.addColorStop(1, adjustColor(color, -30));
      
      ctx.fillStyle = gradient;
      ctx.fillRect(0, 0, 300, 300);
      
      // Add texture pattern
      ctx.strokeStyle = 'rgba(255,255,255,0.4)';
      ctx.lineWidth = 2;
      
      if (text.toLowerCase().includes('smooth')) {
        // Horizontal lines for smooth
        for (let y = 0; y < 300; y += 30) {
          ctx.beginPath();
          ctx.moveTo(0, y);
          ctx.lineTo(300, y);
          ctx.stroke();
        }
      } else if (text.toLowerCase().includes('rough')) {
        // Random lines for rough
        for (let i = 0; i < 25; i++) {
          ctx.beginPath();
          ctx.moveTo(Math.random() * 300, Math.random() * 300);
          ctx.lineTo(Math.random() * 300, Math.random() * 300);
          ctx.stroke();
        }
      } else if (text.toLowerCase().includes('textured')) {
        // Grid for textured
        for (let x = 0; x < 300; x += 25) {
          for (let y = 0; y < 300; y += 25) {
            ctx.strokeRect(x, y, 25, 25);
          }
        }
      }
      
      label.textContent = text.toUpperCase();
      preview.style.display = 'block';
    }

    function adjustColor(hex, percent) {
      const num = parseInt(hex.replace('#', ''), 16);
      const amt = Math.round(2.55 * percent);
      const R = Math.min(255, Math.max(0, (num >> 16) + amt));
      const G = Math.min(255, Math.max(0, (num >> 8 & 0x00FF) + amt));
      const B = Math.min(255, Math.max(0, (num & 0x0000FF) + amt));
      return '#' + ((1 << 24) + (R << 16) + (G << 8) + B).toString(16).slice(1);
    }

    // Run everything when page loads
    function initCustomWallpaperFixes() {
      console.log('🚀 CUSTOM WALLPAPER FIXES STARTING...');
      
      // Remove download buttons immediately
      removeDownloadButtons();
      
      // Set up hover previews
      setupHoverPreviews();
      
      // Check again after 2 seconds for late-loading buttons
      setTimeout(() => {
        console.log('🔄 Secondary scan for late-loading buttons...');
        removeDownloadButtons();
      }, 2000);
      
      // Set up mutation observer to catch dynamically added buttons
      const observer = new MutationObserver(() => {
        removeDownloadButtons();
      });
      
      observer.observe(document.body, { 
        childList: true, 
        subtree: true 
      });
    }

    // Start everything
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initCustomWallpaperFixes);
    } else {
      initCustomWallpaperFixes();
    }

    console.log('✅ Custom Wallpaper fixes script loaded');
  }
  </script>

