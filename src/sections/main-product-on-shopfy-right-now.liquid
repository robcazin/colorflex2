      overflow: hidden;
      pointer-events: none;
    `;
    
    // Canvas for texture preview
    const canvas = document.createElement('canvas');
    canvas.width = 300;
    canvas.height = 300;
    canvas.style.cssText = 'width: 100%; height: calc(100% - 50px); display: block;';
    
    // Label for texture name
    const label = document.createElement('div');
    label.style.cssText = `
      position: absolute;
