// Helper function to download the proof image
function downloadProofImage(canvas, filename) {
  canvas.toBlob(function(blob) {
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = filename;
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    URL.revokeObjectURL(url);
    console.log('✅ Proof downloaded:', filename);
  }, 'image/jpeg', 0.98);
}


function populateColorFlexProperties(urlParams) {
  // Get pattern data
  const patternName = urlParams.get('pattern_name');
  const collection = urlParams.get('collection');
  const customColors = urlParams.get('custom_colors') || '';
  
  // Generate cart thumbnail key for restoration script
  const cartThumbnailKey = patternName && collection ? `cart_thumbnail_${patternName}_${collection}` : '';
  
  // Store thumbnail for cart restoration if available
  const thumbnail = localStorage.getItem('colorflexCurrentThumbnail');
  if (thumbnail && cartThumbnailKey) {
    const cartThumbnailData = {
      thumbnail: thumbnail,
      patternName: patternName,
      collection: collection,
      colors: customColors,
      timestamp: Date.now()
    };
    localStorage.setItem(cartThumbnailKey, JSON.stringify(cartThumbnailData));
    console.log('💾 Stored cart thumbnail key:', cartThumbnailKey);
  }
  
  // Populate hidden form fields with ColorFlex data (using names cart restoration script expects)
  const fields = {
    'colorflex-pattern-name': patternName,
    'colorflex-collection': collection,
    'colorflex-custom-colors': customColors,
    'colorflex-thumbnail-key': cartThumbnailKey,
    'colorflex-material-type': urlParams.get('application') || urlParams.get('material'),
    'colorflex-pattern-id': urlParams.get('pattern_id'),
    'colorflex-save-date': urlParams.get('save_date')
  };
  
  // Move hidden fields into the product form
  const productForm = document.querySelector('form[action*="/cart/add"]');
  const hiddenFieldsContainer = document.getElementById('colorflexFormFields');
  
  console.log('🔍 Form debug - Product form found:', !!productForm);
  console.log('🔍 Form debug - Hidden fields container found:', !!hiddenFieldsContainer);
  
  if (productForm && hiddenFieldsContainer) {
    // Move each hidden field into the product form
    const hiddenFields = hiddenFieldsContainer.querySelectorAll('input[type="hidden"]');
    console.log('🔍 Form debug - Found hidden fields:', hiddenFields.length);
    
    hiddenFields.forEach(field => {
      // Set the value if we have data for it
      const value = fields[field.id];
      console.log(`🔍 Setting field "${field.id}" to "${value}"`);
      
      if (value) {
        field.value = decodeURIComponent(value);
      }
      
      // Clone the field instead of moving it (to avoid DOM issues)
      const clonedField = field.cloneNode(true);
      clonedField.id = field.id + '_cart'; // Ensure unique ID
      
      // Move cloned field into the product form
      productForm.appendChild(clonedField);
      
      console.log(`✅ Added field "${clonedField.name}" with value "${clonedField.value}" to cart form`);
    });
    
    // Debug: Show all form fields after addition
    const allFormFields = productForm.querySelectorAll('input');
    console.log(`🔍 Total form fields after ColorFlex addition: ${allFormFields.length}`);
    allFormFields.forEach(field => {
      if (field.name && field.name.includes('properties')) {
        console.log(`  Property field: ${field.name} = "${field.value}"`);
      }
    });
    
    console.log('✅ ColorFlex properties added to product form');
    console.log('📋 Pattern:', fields['colorflex-pattern-name']);
    console.log('📁 Collection:', fields['colorflex-collection']);
    console.log('🎨 Colors:', fields['colorflex-custom-colors']);
    console.log('📦 Material:', fields['colorflex-material-type']);
    console.log('🔑 Thumbnail Key:', fields['colorflex-thumbnail-key']);
    
    // Store thumbnail for cart display (keep it for cart popup)
    // Don't remove immediately - let cart display system handle cleanup
    console.log('🖼️ Thumbnail preserved for cart display');
    
    // Add comprehensive form submission debugging
    productForm.addEventListener('submit', function(e) {
      console.log('🚀 FORM SUBMISSION DEBUG');
      console.log('📝 Form action:', this.action);
      console.log('📝 Form method:', this.method);
      
      const formData = new FormData(this);
      console.log('📋 Form data being submitted:');
      for (let [key, value] of formData.entries()) {
        console.log(`  ${key}: ${value}`);
      }
      
      // Check specifically for quantity and ColorFlex properties
      const quantity = formData.get('quantity');
      const pattern = formData.get('properties[Custom Pattern]') || formData.get('properties[Pattern Name]');
      const colors = formData.get('properties[Custom Colors]') || formData.get('properties[Colors]');
      
      console.log('🔍 KEY FIELDS:');
      console.log('  Quantity:', quantity);
      console.log('  Pattern:', pattern);
      console.log('  Colors:', colors);
      
      if (!quantity || quantity === '1') {
        console.warn('⚠️ Quantity issue detected');
      }
      if (!pattern) {
        console.warn('⚠️ No pattern data detected');
      }
    });
  } else {
    console.warn('⚠️ Could not find product form or hidden fields container');
  }
}

