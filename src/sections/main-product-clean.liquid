// Enhanced color parsing function that handles various color formats
async function parseColorEnhanced(colorStr) {
  if (!colorStr) return null;
  
  console.log('🔍 Parsing color:', `"${colorStr}"`);
  
  // Handle hex colors
  if (colorStr.startsWith('#')) {
    const hex = colorStr.slice(1);
    if (hex.length === 6) {
      const result = {
        r: parseInt(hex.slice(0, 2), 16),
        g: parseInt(hex.slice(2, 4), 16),
        b: parseInt(hex.slice(4, 6), 16)
      };
      console.log('✅ Parsed hex color:', result);
      return result;
    }
  }
  
  // Load colors from colors.json if not already loaded
  if (!window.colorFlexColors) {
