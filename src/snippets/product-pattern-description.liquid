{% comment %}
  Catalog PDP copy: prefer color_flex.collection_description (Airtable master -000 Description in CSV pipeline).
  Fallback to product body when metafield is empty (legacy imports).
{% endcomment %}
{%- assign col_v = product.metafields.color_flex.collection_description.value | default: '' | strip -%}
{%- if col_v != '' -%}
  <div class="product__description rte product__description--colorflex-collection">{{ col_v | newline_to_br }}</div>
{%- elsif product.description != blank -%}
  <div class="product__description rte">{{ product.description }}</div>
{%- endif -%}
