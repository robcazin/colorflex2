/**
 * Hide generic product information that duplicates our ColorFlex pattern display
 */
function hideGenericProductInfo() {
    console.log('🔄 Hiding duplicate product information for ColorFlex pattern');
    
    // Find and hide elements with duplicate texture/pricing info
    setTimeout(() => {
        // Look for text containing texture info
        const allElements = document.querySelectorAll('*');
        allElements.forEach(element => {
            const text = element.textContent || '';
            // Hide elements that show generic texture or pricing info
            if (text.includes('Texture: Smooth') || 
                text.includes('Texture: textured') ||
                text.includes('Texture: Pre-pasted') ||
                text.includes('Texture: Peel and Stick') ||
                text.includes('Texture: Unpasted') ||
                text.includes('Texture: Grass Cloth') ||
                text.includes('$52 wallpaper / $46 fabric') ||
                (text.includes('Texture Price:') && text.includes('wallpaper') && text.includes('fabric'))) {
                
                // Only hide if it's not our ColorFlex pattern display
                if (!element.closest('#colorflexPatternDisplay')) {
                    console.log('🚫 Hiding duplicate element:', text.substring(0, 50));
                    element.style.display = 'none';
                }
            }
        });
    }, 500);
}

/**
 * Fix cart popup thumbnail to show custom pattern image
 */
function fixCartPopupThumbnail() {
    console.log('🖼️ Setting up cart popup thumbnail fix');
    
    // Monitor for cart popups/drawers appearing
    const observer = new MutationObserver(function(mutations) {
        mutations.forEach(function(mutation) {
            mutation.addedNodes.forEach(function(node) {
                if (node.nodeType === 1) { // Element node
                    // Check if this is a cart popup/drawer
                    const cartPopup = node.querySelector ? node.querySelector('.cart-popup, .cart-drawer, .mini-cart, [class*="cart"]') : null;
                    
                    if (cartPopup || (node.classList && (node.classList.contains('cart-popup') || node.classList.contains('cart-drawer')))) {
                        console.log('🛒 Cart popup detected, replacing thumbnail');
                        setTimeout(() => replaceCartThumbnails(), 100);
                    }
                }
            });
        });
    });
    
    observer.observe(document.body, {
        childList: true,
        subtree: true
    });
    
    // Also fix any existing cart elements
    setTimeout(() => replaceCartThumbnails(), 1000);
}

/**
 * Replace cart thumbnails with custom pattern image
 */
function replaceCartThumbnails() {
    const storedThumbnail = localStorage.getItem('colorflexCurrentThumbnail');
    if (!storedThumbnail) return;
    
    console.log('🔄 Replacing cart thumbnails with custom pattern');
    
    // Find cart item images
    const cartImages = document.querySelectorAll(`
        .cart-popup img,
        .cart-drawer img,
        .mini-cart img,
        .cart-item img,
        .line-item img,
        [class*="cart"] img[src*="cdn.shopify"],
        .ajax-cart img
    `);
    
    cartImages.forEach(img => {
        // Check if this is likely a product thumbnail (not icons, etc.)
        if (img.src.includes('cdn.shopify') && (img.width > 50 || img.height > 50)) {
            console.log('🖼️ Replacing cart thumbnail:', img.src.substring(0, 50) + '...');
            img.src = storedThumbnail;
            img.alt = 'Custom ColorFlex Pattern';
            
            // Add styling to indicate custom image
            img.style.border = '2px solid #667eea';
            img.style.borderRadius = '4px';
        }
    });
}

