  {%- comment -%}
    Hide announcement bar on ColorFlex pages and ColorFlex product pages (they have their own promo UI)
  {%- endcomment -%}
  {% if page.handle == 'colorflex' or page.handle == 'colorflex-furniture' or page.handle == 'colorflex-clothing' or product.handle == 'custom-wallpaper' or product.handle == 'custom-fabric' %}
    <style>
      /* Hide Shopify announcement bar on ColorFlex pages and product pages */
      .utility-bar__grid,
      slideshow-component.announcement-bar,
      .announcement-bar__announcement,
      .announcement-bar-slider,
      div[id*="announcement_bar"] {
        display: none !important;
      }

      /* Also hide any parent sections containing announcement bars */
      [id*="shopify-section"][id*="announcement"] {
        display: none !important;
      }
    </style>
  {% endif %}

  </head>

