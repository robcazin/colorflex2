          }

          .snowflake {
            position: absolute;
            top: -50%;
            color: rgba(255, 255, 255, 0.9);
            font-size: 1.5em;
            animation: fall linear infinite, rotate linear infinite;
            text-shadow: 0 0 5px rgba(255, 255, 255, 0.8),
                         0 0 10px rgba(255, 255, 255, 0.6),
                         0 0 15px rgba(255, 255, 255, 0.4);
