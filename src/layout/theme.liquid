<!-- ColorFlex: theme setting can override to direct-launch furniture (test mode). Default false = icon shows My Designs; on Bassett, designs lead to furniture. -->
<script>
(function() {
    'use strict';

    // Theme setting: if true, icon goes straight to furniture page (test). Default false = icon shows My Designs; using a design leads to wallpaper (main) or furniture (Bassett).
    var colorFlexIconLaunchesFurniture = {{ settings.colorflex_icon_launches_furniture | default: false }};

    var isProductPage = {{ template.name | json }} === 'product';

    function updateMenuIcon() {
        var existing = document.getElementById('colorflexMenuIcon');
        if (existing) existing.remove();

        if (isProductPage) return;

        var patterns = JSON.parse(localStorage.getItem('colorflexSavedPatterns') || '[]');
        var showIcon = colorFlexIconLaunchesFurniture || patterns.length > 0;

        if (showIcon) {
            var menuIcon = document.createElement('div');
            menuIcon.id = 'colorflexMenuIcon';
            var cfDataBase = (window.COLORFLEX_DATA_BASE_URL || 'https://s3.us-east-005.backblazeb2.com/cf-data').replace(/\/$/, '');
            menuIcon.innerHTML = patterns.length > 0
                ? '<img src="' + cfDataBase + '/img/camelion-sm-black.jpg" style="width:100%;height:100%;border-radius:50%;"><span style="background:#d4af37;color:#1a202c;font-size:10px;border-radius:10px;padding:2px 4px;position:absolute;top:-8px;right:-8px;min-width:16px;text-align:center;">' + patterns.length + '</span>'
                : '<img src="' + cfDataBase + '/img/camelion-sm-black.jpg" style="width:100%;height:100%;border-radius:50%;">';
            menuIcon.style.cssText = 'position:fixed;top:20px;right:20px;width:70px;height:70px;cursor:pointer;z-index:9999;background:rgba(26,32,44,0.9);padding:4px;border-radius:50%;border:2px solid #d4af37;transition:transform 0.3s ease;display:flex;align-items:center;justify-content:center;overflow:visible;';

            menuIcon.addEventListener('mouseenter', function() { menuIcon.style.transform = 'scale(2.0)'; });
            menuIcon.addEventListener('mouseleave', function() { menuIcon.style.transform = 'scale(1)'; });

            menuIcon.addEventListener('click', function() {
                if (colorFlexIconLaunchesFurniture) {
                    window.location.href = '/pages/colorflex-furniture';
                    return;
                }
                function tryShowModal() {
                    if (window.UnifiedPatternModal && window.UnifiedPatternModal.showSavedPatternsModal) {
                        window.UnifiedPatternModal.showSavedPatternsModal();
                    } else {
                        setTimeout(tryShowModal, 100);
                    }
                }
                tryShowModal();
            });

            menuIcon.title = colorFlexIconLaunchesFurniture ? 'Open ColorFlex Furniture' : ('My ColorFlex Patterns (' + patterns.length + ')');
            document.body.appendChild(menuIcon);
        }
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', updateMenuIcon);
    } else {
        updateMenuIcon();
    }
    window.updateColorFlexMenuIcon = updateMenuIcon;
})();
</script>
