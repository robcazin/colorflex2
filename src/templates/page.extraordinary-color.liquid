<!-- Make cards fully clickable -->
<script>
  document.querySelectorAll('.collection-card').forEach(card => {
    card.addEventListener('click', function(e) {
      if (e.target.tagName !== 'A') {
        const link = this.closest('a');
        if (link) {
          window.location.href = link.href;
        }
      }
    });
  });
</script>
