<script>
/**
 * Standalone Thumbnail Capture Override
 * Enables thumbnail capture for saved patterns
 */

console.log('🎯 Thumbnail Capture Override loaded!');

// Wait for DOM to be ready
document.addEventListener('DOMContentLoaded', function() {
    console.log('🔍 Setting up thumbnail capture override...');
    
    // Function to capture pattern thumbnail
    function capturePatternThumbnail() {
        try {
            console.log('📸 Attempting to capture pattern thumbnail...');
            
            // Wait a bit to ensure pattern is fully rendered with custom colors
            return new Promise((resolve) => {
                // Force pattern re-render before capturing thumbnail
                console.log('🔄 Triggering pattern re-render before capture...');
                
                // Try to trigger pattern update by dispatching events or calling render functions
                const event = new Event('colorflexUpdate', { bubbles: true });
                document.dispatchEvent(event);
                
                // Also try to trigger any ColorFlex render functions if they exist
                if (window.renderPattern) {
                    console.log('🎨 Calling renderPattern()');
                    window.renderPattern();
                } else if (window.updatePattern) {
                    console.log('🎨 Calling updatePattern()');
                    window.updatePattern();
                } else if (window.ColorFlex && window.ColorFlex.render) {
                    console.log('🎨 Calling ColorFlex.render()');
                    window.ColorFlex.render();
                }
                
                setTimeout(() => {
                    // First priority: main ColorFlex preview element
                    let previewElement = document.getElementById('preview');
                    
                    if (!previewElement) {
                        // Fallback selectors if main preview not found
                        const selectors = [
                            '#pattern-preview',
                            '.pattern-preview', 
                            '#colorflex-preview',
                            '.colorflex-preview',
                            '#pattern-display',
                            '.pattern-display',
                            '[id*="preview"]',
                            '[class*="preview"]'
                        ];
                        
                        console.log('🔍 Main #preview not found, trying fallback selectors...');
                        
                        for (const selector of selectors) {
                            previewElement = document.querySelector(selector);
                            if (previewElement) {
                                console.log('📸 Found fallback preview element:', selector, previewElement);
                                break;
                            }
                        }
                    } else {
                        console.log('📸 Found main preview element: #preview', previewElement);
                    }
                    
                    if (!previewElement) {
                        console.warn('⚠️ No pattern preview element found for thumbnail capture');
                        // List all available elements for debugging
                        console.log('🔍 Available elements with "pattern" in ID/class:');
                        document.querySelectorAll('[id*="pattern"], [class*="pattern"]').forEach(el => {
                            console.log('  -', el.tagName, el.id || el.className);
                        });
                        console.log('🔍 Available SVG elements:', document.querySelectorAll('svg').length);
                        console.log('🔍 Available Canvas elements:', document.querySelectorAll('canvas').length);
                        resolve(null);
                        return;
                    }
                    
                    // Look for canvas inside the preview element
                    let canvasElement = previewElement.querySelector('canvas');
                    
                    if (!canvasElement && previewElement.tagName === 'CANVAS') {
                        canvasElement = previewElement;
                    }
                    
                    // Create a canvas to capture the element
                    const canvas = document.createElement('canvas');
                    const ctx = canvas.getContext('2d');
                    
                    // Set thumbnail size (optimized high resolution with JPEG compression)
                    canvas.width = 800;
                    canvas.height = 800;
                    
                    if (canvasElement) {
                        console.log('📸 Capturing from canvas element');
                        try {
                            // Draw the canvas content to our thumbnail canvas
                            ctx.drawImage(canvasElement, 0, 0, 800, 800);
                        } catch (error) {
                            console.warn('❌ Failed to capture canvas:', error);
                            // Fallback to placeholder
                            ctx.fillStyle = '#000';
                            ctx.fillRect(0, 0, 800, 800);
                            ctx.fillStyle = '#888';
                            ctx.font = '12px Arial';
                            ctx.textAlign = 'center';
                            ctx.fillText('Custom Pattern', 100, 90);
                            ctx.fillText('Preview', 100, 110);
                        }
                    } else {
                        console.log('📸 No canvas found, creating placeholder thumbnail');
                        // Create placeholder with pattern info
                        ctx.fillStyle = '#000';
                        ctx.fillRect(0, 0, 200, 200);
                        ctx.fillStyle = '#888';
                        ctx.font = '12px Arial';
                        ctx.textAlign = 'center';
                        ctx.fillText('Custom Pattern', 100, 90);
                        ctx.fillText('Preview', 100, 110);
                    }
                    
                    // Convert to base64 data URL
                    const dataUrl = canvas.toDataURL('image/jpeg', 0.7);
                    console.log('📸 Captured pattern thumbnail (length:', dataUrl.length, ')');
                    resolve(dataUrl);
                }, 1500); // Wait 1.5s for pattern to fully re-render with new colors
            });
        } catch (error) {
            console.error('❌ Failed to capture pattern thumbnail:', error);
            return null;
        }
    }
    
    // Enhanced save button interception
    function interceptSaveButton() {
        const saveBtn = document.getElementById('saveToMyListBtn');
        if (saveBtn && !saveBtn._thumbnailIntercepted) {
            console.log('🎯 Intercepting save button for thumbnail capture...');
            saveBtn._thumbnailIntercepted = true;
            
            const originalClick = saveBtn.onclick;
            saveBtn.onclick = function(event) {
                console.log('🎯 Save button clicked - capturing thumbnail first...');
                
                // Capture thumbnail immediately when save button is clicked
                capturePatternThumbnail().then(thumbnail => {
                    console.log('📸 Thumbnail captured, proceeding with save...');
                    
                    // Override localStorage temporarily for this save
                    const originalSetItem = localStorage.setItem;
                    localStorage.setItem = function(key, value) {
                        if (key === 'colorflexSavedPatterns' && thumbnail) {
                            console.log('🎯 Adding thumbnail to localStorage save...');
                            const patterns = JSON.parse(value);
                            const lastPattern = patterns[patterns.length - 1];
                            if (lastPattern && !lastPattern.thumbnail) {
                                lastPattern.thumbnail = thumbnail;
                                value = JSON.stringify(patterns);
                                console.log('✅ Thumbnail added to pattern:', lastPattern.patternName);
                            }
                        }
                        return originalSetItem.call(this, key, value);
                    };
                    
                    // Call original save function
                    if (originalClick) {
                        originalClick.call(this, event);
                    }
                    
                    // Restore original localStorage after a delay
                    setTimeout(() => {
                        localStorage.setItem = originalSetItem;
                    }, 100);
                    
                }).catch(error => {
                    console.error('❌ Error capturing thumbnail:', error);
                    // Still proceed with save even if thumbnail fails
                    if (originalClick) {
                        originalClick.call(this, event);
                    }
                });
                
                // Prevent default save until thumbnail is captured
                return false;
            };
        }
    }
    
    // Try to intercept save button periodically
    function setupSaveButtonInterception() {
        interceptSaveButton();
        // Keep trying in case the button loads later
        setTimeout(setupSaveButtonInterception, 2000);
    }
    
    setupSaveButtonInterception();
    
    console.log('✅ Thumbnail capture override ready!');
});
</script>

