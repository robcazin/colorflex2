        </div>

        <!-- Pattern Preview -->
        <div style="text-align: center; margin-top: -19.8px;">
          <h3 style="margin-bottom: 1.0rem; font-size: 3rem; font-family: 'Island Moments', cursive !important;">Pattern Preview</h3>
          <div id="preview" style="max-width: 700px; min-height: 200px; background: #000; margin: 0 auto; display: flex; justify-content: center; align-items: center;"></div>
