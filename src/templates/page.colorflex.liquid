// Check for pending pattern load from unified modal (cross-page pattern loading)
function checkForPendingPatternLoad() {
  const pendingData = sessionStorage.getItem('pendingDirectPatternLoad');
  if (pendingData) {
    console.log('🔄 Found pending pattern load data');
    try {
      const patternData = JSON.parse(pendingData);
      console.log('📋 Pending pattern data:', patternData);
      console.log('🎨 Pattern source:', patternData.source || 'unknown');

      if (patternData.source === 'cart_edit') {
        console.log('🛒 Cart edit detected - pattern name:', patternData.patternName, 'collection:', patternData.collectionName);
        console.log('🎨 Custom colors from cart:', patternData.customColors);
      }

      // Clear the pending data to prevent reprocessing
      sessionStorage.removeItem('pendingDirectPatternLoad');

      // Wait for ColorFlex to be fully loaded before applying the pattern
      const applyPendingPattern = () => {
        if (window.loadSavedPatternToUI && typeof window.loadSavedPatternToUI === 'function') {
          console.log('✅ ColorFlex loaded, applying pending pattern...');
          window.loadSavedPatternToUI(patternData);
        } else {
          console.log('⏳ ColorFlex not ready yet, waiting...');
          setTimeout(applyPendingPattern, 500);
        }
      };

      // Start checking for ColorFlex availability after a brief delay
      setTimeout(applyPendingPattern, 1000);

    } catch (error) {
      console.error('❌ Error processing pending pattern load:', error);
      sessionStorage.removeItem('pendingDirectPatternLoad'); // Clean up on error
    }
  } else {
    console.log('📋 No pending pattern load data found');
  }
}

