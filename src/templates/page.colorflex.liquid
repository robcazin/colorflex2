<!-- ColorFlex Page Template -->
<!-- Font imports -->
{% # theme-check-disable RemoteAsset %}
<link href="https://fonts.googleapis.com/css2?family=IM+Fell+English:ital@0;1&family=Island+Moments&family=Special+Elite&display=swap" rel="stylesheet">
{% # theme-check-enable RemoteAsset %}

<!-- All styling now handled by built CSS: color-flex-core.min.css -->

<!-- ColorFlex page: black background to match header -->
<style>
  body:has(.colorflex-section),
  html:has(.colorflex-section) {
    background: #000 !important;
  }
  /* Only target the main container, nothing else */
  #mainContainer {
    margin-top: -24px;
  }
</style>

<!-- Simple Back Button using browser history -->
<div id="backButton" style="
  position: fixed;
  top: 80px;
  left: 20px;
  z-index: 1000;
  background: rgba(26, 32, 44, 0.9);
  border: 2px solid #d4af37;
  border-radius: 50%;
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  font-size: 18px;
  color: #d4af37;
  transition: all 0.3s ease;
" onclick="window.history.back()" title="Go Back">
  ←
</div>

<script>
  // Add hover effect to back button
  document.getElementById('backButton').addEventListener('mouseenter', function() {
    this.style.transform = 'scale(1.1)';
    this.style.background = 'rgba(212, 175, 55, 0.2)';
  });

  document.getElementById('backButton').addEventListener('mouseleave', function() {
    this.style.transform = 'scale(1)';
    this.style.background = 'rgba(26, 32, 44, 0.9)';
  });
</script>

<!-- First-Time Visitor Welcome Modal -->
<div id="welcomeModal" style="
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.85);
  z-index: 10000;
  align-items: center;
  justify-content: center;
">
  <div style="
    background: #000;
    border: 3px solid #d4af37;
    border-radius: 16px;
    padding: 2.5rem;
    max-width: 580px;
    width: 90%;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    position: relative;
    color: white;
  ">
    <!-- Close button -->
    <button id="closeWelcomeModal" style="
      position: absolute;
      top: 15px;
      right: 15px;
      background: transparent;
      border: 2px solid #d4af37;
      color: #d4af37;
      width: 32px;
      height: 32px;
      border-radius: 50%;
      cursor: pointer;
      font-size: 1.2rem;
      line-height: 1;
      transition: all 0.3s ease;
    " onmouseover="this.style.background='rgba(212, 175, 55, 0.2)'" onmouseout="this.style.background='transparent'">
      ×
    </button>

    <h2 style="
      color: #d4af37;
      font-size: 2rem;
      margin-bottom: 1.5rem;
      font-family: 'Island Moments', cursive;
      text-align: center;
    ">Welcome to ColorFlex!</h2>

    <div style="font-size: 1rem; line-height: 1.6; color: #e2e8f0; margin-bottom: 2rem;">
      <p style="margin-bottom: 1rem;">
        <strong style="color: #d4af37;">✨ Customize Your Perfect Pattern</strong><br>
        Choose from our beautiful collections, then personalize every color to match your space perfectly.
      </p>

      <p style="margin-bottom: 1rem;">
        <strong style="color: #d4af37;">🎨 Quick Start Guide:</strong>
      </p>

      <ul style="margin: 0 0 1rem 1.5rem; padding: 0; list-style: none;">
        <li style="margin-bottom: 0.5rem;">
          <span style="color: #d4af37;">1.</span> Click the <strong>Collection</strong> header to switch collections
        </li>
        <li style="margin-bottom: 0.5rem;">
          <span style="color: #d4af37;">2.</span> Browse <strong>Patterns</strong> using thumbnails on the left
        </li>
        <li style="margin-bottom: 0.5rem;">
          <span style="color: #d4af37;">3.</span> Click <strong>Color Layers</strong> to customize each element
        </li>
        <li style="margin-bottom: 0.5rem;">
          <span style="color: #d4af37;">4.</span> Adjust <strong>Scale</strong> and <strong>Room Mockup</strong> to visualize
        </li>
        <li style="margin-bottom: 0.5rem;">
          <span style="color: #d4af37;">5.</span> <strong>Save to My Designs</strong> or select your material!
        </li>
      </ul>

      <p style="margin-bottom: 0; color: #cbd5e0; font-size: 0.9rem; font-style: italic;">
        💡 Tip: Use "My Designs" to view and edit all your saved patterns anytime.
      </p>
    </div>

    <button id="startCustomizing" style="
      width: 100%;
      padding: 0.875rem 1.5rem;
      background: linear-gradient(135deg, #d4af37 0%, #c69a2d 100%);
      border: none;
      border-radius: 8px;
      color: #1a202c;
      font-size: 1.1rem;
      font-weight: bold;
      cursor: pointer;
      transition: all 0.3s ease;
      box-shadow: 0 4px 12px rgba(212, 175, 55, 0.3);
    " onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 16px rgba(212, 175, 55, 0.4)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 12px rgba(212, 175, 55, 0.3)'">
      Start Customizing →
    </button>

    <div style="text-align: center; margin-top: 1rem;">
      <label style="display: flex; align-items: center; justify-content: center; gap: 0.5rem; cursor: pointer; font-size: 0.85rem; color: #a0aec0;">
        <input type="checkbox" id="dontShowAgain" style="cursor: pointer;">
        Don't show this again
      </label>
    </div>
  </div>
</div>

<script>
(function() {
  const modal = document.getElementById('welcomeModal');
  const closeBtn = document.getElementById('closeWelcomeModal');
  const startBtn = document.getElementById('startCustomizing');
  const dontShowCheckbox = document.getElementById('dontShowAgain');

  // Check if user has seen the welcome before
  const hasSeenWelcome = localStorage.getItem('colorflexWelcomeSeen');

  // Show modal only if first visit
  if (!hasSeenWelcome) {
    modal.style.display = 'flex';
  }

  // Close modal function
  function closeModal() {
    modal.style.display = 'none';

    // Save preference if checkbox is checked
    if (dontShowCheckbox.checked) {
      localStorage.setItem('colorflexWelcomeSeen', 'true');
    }
  }

  // Event listeners
  closeBtn.addEventListener('click', closeModal);
  startBtn.addEventListener('click', closeModal);

  // Close on background click
  modal.addEventListener('click', function(e) {
    if (e.target === modal) {
      closeModal();
    }
  });

  // Close on Escape key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && modal.style.display === 'flex') {
      closeModal();
    }
  });
})();
</script>

<!-- Collections Selection Modal -->
<style>
  #collectionsModal .collections-modal-title {
    color: #d4af37 !important;
    font-size: 2rem !important;
    margin-bottom: 1.5rem !important;
    font-family: 'Island Moments', cursive !important;
    text-align: center !important;
  }
  /* Modal content box: tiled pattern background (ensure it isn't overridden by theme CSS) */
  #collectionsModal .collections-modal-content {
    background-color: #000;
    background-image: url(https://so-animation.com/colorflex/img/garden-path-bg.jpg);
    background-repeat: repeat;
    background-size: auto;
  }
</style>
<div id="collectionsModal" style="
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.85);
  z-index: 10001;
  align-items: center;
  justify-content: center;
">
  <div class="collections-modal-content" style="
    border: 3px solid #d4af37;
    border-radius: 16px;
    padding: 2rem;
    max-width: 900px;
    width: 90%;
    max-height: 85vh;
    overflow-y: auto;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    position: relative;
    color: white;
  ">
    <!-- Close button -->
    <button id="closeCollectionsModal" style="
      position: absolute;
      top: 15px;
      right: 15px;
      background: transparent;
      border: 2px solid #d4af37;
      color: #d4af37;
      width: 32px;
      height: 32px;
      border-radius: 50%;
      cursor: pointer;
      font-size: 1.2rem;
      line-height: 1;
      transition: all 0.3s ease;
    " onmouseover="this.style.background='rgba(212, 175, 55, 0.2)'" onmouseout="this.style.background='transparent'">
      ×
    </button>

    <h2 class="collections-modal-title">Select a Collection</h2>

    <!-- Collections Grid -->
    <div id="collectionsGrid" style="
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 1rem;
      margin-top: 1.5rem;
    ">
      <!-- Collections will be populated here by JavaScript -->
    </div>
  </div>
</div>

<script>
(function() {
  const modal = document.getElementById('collectionsModal');
  const closeBtn = document.getElementById('closeCollectionsModal');
  const collectionsGrid = document.getElementById('collectionsGrid');

  // Function to open collections modal
  window.openCollectionsModal = function() {
    // Get collections from window.collectionsData or fallback to appState (set by CFM.js)
    const collections = window.collectionsData || window.appState?.collections || [];

    if (collections.length === 0) {
      console.warn('No collections data available yet. Please wait for ColorFlex to initialize.');
      // Show modal with loading message
      modal.style.display = 'flex';
      collectionsGrid.innerHTML = '<div style="text-align: center; padding: 2rem; color: #a0aec0;">Loading collections...</div>';

      // Retry after a short delay
      setTimeout(() => {
        const retryCollections = window.collectionsData || window.appState?.collections || [];
        if (retryCollections.length > 0) {
          window.openCollectionsModal();
        }
      }, 500);
      return;
    }

    // Clear existing grid
    collectionsGrid.innerHTML = '';

    // Filter out furniture and clothing collections (only show wallpaper collections)
    const wallpaperCollections = collections.filter(c =>
      c.name && !c.name.includes('.fur-') && !c.name.includes('-clo') && !c.name.includes('.clo-')
    );

    // Sort by collection number (designer order), then by name
    const sortedCollections = window.ColorFlexSortCollectionsByNumber
      ? window.ColorFlexSortCollectionsByNumber(wallpaperCollections)
      : [...wallpaperCollections].sort((a, b) => a.name.localeCompare(b.name));

    // Populate collections grid
    sortedCollections.forEach(collection => {
      const collectionCard = document.createElement('div');
      collectionCard.style.cssText = `
        background: #000;
        border: 1px solid rgba(212, 175, 55, 0.25);
        border-radius: 8px;
        padding: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        text-align: center;
        position: relative;
      `;

      // Check if collection has ColorFlex patterns (patterns with layers)
      const hasColorFlexPatterns = collection.patterns && collection.patterns.some(p =>
        p.layers && Array.isArray(p.layers) && p.layers.length > 0
      );

      // Build the card HTML
      let cardHTML = '';

      // Add chameleon icon for ColorFlex-enabled collections
      if (hasColorFlexPatterns) {
        cardHTML += `
          <div style="
            position: absolute;
            top: 8px;
            right: 8px;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            overflow: hidden;
            border: 2px solid #d4af37;
            background: rgba(212, 175, 55, 0.1);
          ">
            <img
              src="https://so-animation.com/colorflex/img/camelion-sm-r.jpg"
              style="width: 100%; height: 100%; object-fit: cover;"
              alt="ColorFlex Enabled"
            >
          </div>
        `;
      }

      cardHTML += `
        <h3 style="
          font-family: 'IM Fell English', serif;
          font-size: 1.2rem;
          color: white;
          margin: 0 0 0.5rem 0;
          text-transform: uppercase;
          ${hasColorFlexPatterns ? 'padding-right: 40px;' : ''}
        ">${collection.name}</h3>
        <div style="
          font-size: 0.85rem;
          color: #a0aec0;
        ">${collection.patterns ? collection.patterns.length : 0} patterns</div>
        ${hasColorFlexPatterns ? `
          <div style="
            font-size: 0.75rem;
            color: #d4af37;
            margin-top: 0.5rem;
            font-weight: bold;
          ">🎨 ColorFlex Enabled</div>
        ` : ''}
      `;

      collectionCard.innerHTML = cardHTML;

      // Hover effects: dim gold background + slightly brighter border
      collectionCard.addEventListener('mouseenter', function() {
        this.style.borderColor = 'rgba(212, 175, 55, 0.5)';
        this.style.background = 'rgba(212, 175, 55, 0.12)';
        this.style.transform = 'translateY(-4px)';
        this.style.boxShadow = '0 8px 16px rgba(212, 175, 55, 0.2)';
      });

      collectionCard.addEventListener('mouseleave', function() {
        this.style.borderColor = 'rgba(212, 175, 55, 0.25)';
        this.style.background = '#000';
        this.style.transform = 'translateY(0)';
        this.style.boxShadow = 'none';
      });

      // Click to select collection
      collectionCard.addEventListener('click', function() {
        const collectionName = collection.name;

        // Try to call switchCollection, with retry if not available yet
        function trySwitchCollection(retryCount) {
          if (window.switchCollection) {
            console.log('✅ Calling window.switchCollection for:', collectionName);
            window.switchCollection(collectionName);
            closeCollectionsModal();
          } else if (retryCount > 0) {
            console.log('⏳ switchCollection not available yet, retrying... (attempts left: ' + retryCount + ')');
            setTimeout(function() {
              trySwitchCollection(retryCount - 1);
            }, 200);
          } else {
            console.error('❌ switchCollection function not available after retries');
            alert('ColorFlex is still loading. Please wait a moment and try again.');
          }
        }

        trySwitchCollection(5); // Try up to 5 times with 200ms delays (1 second total)
      });

      collectionsGrid.appendChild(collectionCard);
    });

    // Show modal
    modal.style.display = 'flex';
  };

  // Function to close modal
  function closeCollectionsModal() {
    modal.style.display = 'none';
  }

  // Event listeners
  closeBtn.addEventListener('click', closeCollectionsModal);

  // Close on background click
  modal.addEventListener('click', function(e) {
    if (e.target === modal) {
      closeCollectionsModal();
    }
  });

  // Close on Escape key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && modal.style.display === 'flex') {
      closeCollectionsModal();
    }
  });
})();
</script>

<!-- Patterns Modal (mobile): thumbnails in popup -->
<div id="patternsModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.9); z-index: 10000; align-items: center; justify-content: center; overflow-y: auto; padding: 1rem;">
  <div style="background: #000; border: 3px solid #d4af37; border-radius: 16px; padding: 1.5rem; max-width: 95vw; max-height: 85vh; overflow-y: auto;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
      <h3 style="color: #d4af37; font-family: 'Island Moments', cursive; margin: 0;">Pick a Pattern</h3>
      <button id="closePatternsModal" style="background: transparent; border: 2px solid #d4af37; color: #d4af37; width: 36px; height: 36px; border-radius: 50%; cursor: pointer; font-size: 1.2rem;">×</button>
    </div>
    <div id="patternsModalContent" style="display: flex; flex-wrap: wrap; justify-content: center; gap: 0.75rem; padding: 0.5rem 0;"></div>
  </div>
</div>

<script>
(function() {
  const patternsModal = document.getElementById('patternsModal');
  const patternsContent = document.getElementById('patternsModalContent');
  const closeBtn = document.getElementById('closePatternsModal');
  const leftSidebar = document.getElementById('leftSidebar');
  const collectionThumbnails = document.getElementById('collectionThumbnails');

  window.openPatternsModal = function() {
    if (!collectionThumbnails || !leftSidebar) return;
    patternsContent.appendChild(collectionThumbnails);
    patternsModal.style.display = 'flex';
  };

  window.closePatternsModal = function() {
    if (!collectionThumbnails || !leftSidebar) return;
    leftSidebar.appendChild(collectionThumbnails);
    patternsModal.style.display = 'none';
  };

  if (closeBtn) closeBtn.addEventListener('click', window.closePatternsModal);
  patternsModal.addEventListener('click', function(e) {
    if (e.target === patternsModal) window.closePatternsModal();
    if (e.target.closest && e.target.closest('.thumbnail')) {
      setTimeout(window.closePatternsModal, 400);
    }
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && patternsModal.style.display === 'flex') window.closePatternsModal();
  });

  // Show mobile bar on narrow viewports; sync collection name
  function updateMobileLayout() {
    const bar = document.getElementById('mobileCollectionBar');
    const mobileText = document.getElementById('mobileCollectionHeaderText');
    const mainHeader = document.getElementById('collectionHeader');
    if (!bar) return;
    if (window.innerWidth <= 768) {
      bar.style.display = 'flex';
      if (mobileText && mainHeader) mobileText.textContent = mainHeader.textContent.replace(/\s*▼\s*$/,'').trim() || 'Collection';
    } else {
      bar.style.display = 'none';
    }
  }
  window.addEventListener('resize', updateMobileLayout);
  setInterval(updateMobileLayout, 1000);
  updateMobileLayout();
})();
</script>

