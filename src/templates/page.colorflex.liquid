    <!-- ColorFlex App -->
    <div id="mainContainer" style="position: relative; min-height: 70vh;">

      <div class="colorflex-main-grid" style="display: grid; grid-template-columns: 1fr 280px 1fr; gap: 1.8rem; max-width: 1500px; margin: 0 auto; margin-left: 160px; padding: 0 0.9rem; position: relative; z-index: 1;">

        <!-- MOVED: Curated Colors Section - Compact Version -->
        <div style="grid-column: 1 / -1; margin-bottom: 0;">
          <section id="curatedColorsSection" style="width: 100%; padding: 0.1125rem 0 0 0; text-align: center;">
