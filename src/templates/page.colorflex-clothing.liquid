      <label style="display: flex; align-items: center; justify-content: center; gap: 0.5rem; cursor: pointer; font-size: 0.85rem; color: #a0aec0;">
        <input type="checkbox" id="dontShowAgain" style="cursor: pointer;">
        Don't show this again
      </label>
    </div>
