</div>

<script>
(function() {
  const modal = document.getElementById('welcomeModal');
  const closeBtn = document.getElementById('closeWelcomeModal');
  const startBtn = document.getElementById('startCustomizing');
  const dontShowCheckbox = document.getElementById('dontShowAgain');

  const hasSeenWelcome = localStorage.getItem('colorflexClothingWelcomeSeen');

  if (!hasSeenWelcome) {
    modal.style.display = 'flex';
  }

  function closeModal() {
    modal.style.display = 'none';
    if (dontShowCheckbox.checked) {
      localStorage.setItem('colorflexClothingWelcomeSeen', 'true');
    }
  }

  closeBtn.addEventListener('click', closeModal);
  startBtn.addEventListener('click', closeModal);

  modal.addEventListener('click', function(e) {
    if (e.target === modal) {
      closeModal();
    }
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && modal.style.display === 'flex') {
      closeModal();
    }
  });
})();
</script>

<!-- Collections Selection Modal -->
<div id="collectionsModal" style="
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.85);
  z-index: 10001;
  align-items: center;
  justify-content: center;
">
  <div style="
    background: linear-gradient(135deg, #1a202c 0%, #2d3748 100%);
    border: 3px solid #4a90e2;
    border-radius: 16px;
    padding: 2rem;
    max-width: 900px;
    width: 90%;
    max-height: 85vh;
    overflow-y: auto;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    position: relative;
    color: white;
  ">
    <!-- Close button -->
    <button id="closeCollectionsModal" style="
      position: absolute;
      top: 15px;
      right: 15px;
      background: transparent;
      border: 2px solid #4a90e2;
      color: #4a90e2;
      width: 32px;
      height: 32px;
      border-radius: 50%;
      cursor: pointer;
      font-size: 1.2rem;
      line-height: 1;
      transition: all 0.3s ease;
    " onmouseover="this.style.background='rgba(74, 144, 226, 0.2)'" onmouseout="this.style.background='transparent'">
      ×
    </button>

    <h2 style="
      color: #4a90e2;
      font-size: 2rem;
      margin-bottom: 1.5rem;
      font-family: 'Island Moments', cursive;
      text-align: center;
    ">Select a Clothing Collection</h2>

    <!-- Collections Grid -->
    <div id="collectionsGrid" style="
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 1rem;
      margin-top: 1.5rem;
    ">
      <!-- Collections will be populated here by JavaScript -->
    </div>
  </div>
</div>

<script>
(function() {
  const modal = document.getElementById('collectionsModal');
  const closeBtn = document.getElementById('closeCollectionsModal');
  const collectionsGrid = document.getElementById('collectionsGrid');

  // Function to open collections modal
  window.openCollectionsModal = function() {
    // Get collections from window.collectionsData or fallback to appState (set by CFM.js)
    const collections = window.collectionsData || window.appState?.collections || [];

    if (collections.length === 0) {
      console.warn('No collections data available yet. Please wait for ColorFlex to initialize.');
      modal.style.display = 'flex';
      collectionsGrid.innerHTML = '<div style="text-align: center; padding: 2rem; color: #a0aec0;">Loading collections...</div>';

      setTimeout(() => {
        const retryCollections = window.collectionsData || window.appState?.collections || [];
        if (retryCollections.length > 0) {
          window.openCollectionsModal();
        }
      }, 500);
      return;
    }

    // Clear existing grid
    collectionsGrid.innerHTML = '';

    // Sort by collection number (designer order), then by name
    const sortedCollections = window.ColorFlexSortCollectionsByNumber
      ? window.ColorFlexSortCollectionsByNumber(collections)
      : [...collections].sort((a, b) => a.name.localeCompare(b.name));

    // Populate collections grid
    sortedCollections.forEach(collection => {
      const collectionCard = document.createElement('div');
      collectionCard.style.cssText = `
        background: #2d3748;
        border: 2px solid transparent;
        border-radius: 8px;
        padding: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        text-align: center;
        position: relative;
      `;

      // Check if collection has ColorFlex patterns
      const hasColorFlexPatterns = collection.patterns && collection.patterns.some(p =>
        p.layers && Array.isArray(p.layers) && p.layers.length > 0
      );

      // Build the card HTML
      let cardHTML = '';

      // Add chameleon icon for ColorFlex-enabled collections
      if (hasColorFlexPatterns) {
        cardHTML += `
          <div style="
            position: absolute;
            top: 8px;
            right: 8px;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            overflow: hidden;
            border: 2px solid #4a90e2;
            background: rgba(74, 144, 226, 0.1);
          ">
            <img
              src="https://so-animation.com/colorflex/img/camelion-sm-r.jpg"
              style="width: 100%; height: 100%; object-fit: cover;"
              alt="ColorFlex Enabled"
            >
          </div>
        `;
      }

      cardHTML += `
        <h3 style="
          font-family: 'IM Fell English', serif;
          font-size: 1.2rem;
          color: white;
          margin: 0 0 0.5rem 0;
          text-transform: uppercase;
          ${hasColorFlexPatterns ? 'padding-right: 40px;' : ''}
        ">${collection.displayName || collection.name}</h3>
        <div style="
          font-size: 0.85rem;
          color: #a0aec0;
        ">${collection.patterns ? collection.patterns.length : 0} patterns</div>
        ${hasColorFlexPatterns ? `
          <div style="
            font-size: 0.75rem;
            color: #4a90e2;
            margin-top: 0.5rem;
            font-weight: bold;
          ">🎨 ColorFlex Enabled</div>
        ` : ''}
      `;

      collectionCard.innerHTML = cardHTML;

      // Hover effects
      collectionCard.addEventListener('mouseenter', function() {
        this.style.borderColor = '#4a90e2';
        this.style.background = '#3d4758';
        this.style.transform = 'translateY(-4px)';
        this.style.boxShadow = '0 8px 16px rgba(74, 144, 226, 0.2)';
      });

      collectionCard.addEventListener('mouseleave', function() {
        this.style.borderColor = 'transparent';
        this.style.background = '#2d3748';
        this.style.transform = 'translateY(0)';
        this.style.boxShadow = 'none';
      });

      // Click to select collection
      collectionCard.addEventListener('click', function() {
        const collectionName = collection.name;

        function trySwitchCollection(retryCount) {
          if (window.switchCollection) {
            console.log('✅ Calling window.switchCollection for:', collectionName);
            window.switchCollection(collectionName);
            closeCollectionsModal();
          } else if (retryCount > 0) {
            console.log('⏳ switchCollection not available yet, retrying... (attempts left: ' + retryCount + ')');
            setTimeout(function() {
              trySwitchCollection(retryCount - 1);
            }, 200);
          } else {
            console.error('❌ switchCollection function not available after retries');
            alert('ColorFlex is still loading. Please wait a moment and try again.');
          }
        }

        trySwitchCollection(5);
      });

      collectionsGrid.appendChild(collectionCard);
    });

    // Show modal
    modal.style.display = 'flex';
  };

  // Function to close modal
  function closeCollectionsModal() {
    modal.style.display = 'none';
  }

  // Event listeners
  closeBtn.addEventListener('click', closeCollectionsModal);

  // Close on background click
  modal.addEventListener('click', function(e) {
    if (e.target === modal) {
      closeCollectionsModal();
    }
  });

  // Close on Escape key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && modal.style.display === 'flex') {
      closeCollectionsModal();
    }
  });
})();
</script>

